    JsonRpcSchemaTevm['tevm_call'],
    JsonRpcSchemaTevm['tevm_dumpState'],
    JsonRpcSchemaTevm['tevm_loadState'],
    JsonRpcSchemaTevm['tevm_getAccount'],
    JsonRpcSchemaTevm['tevm_setAccount'],
    JsonRpcSchemaTevm['tevm_mine']
];
