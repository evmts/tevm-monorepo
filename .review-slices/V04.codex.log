    71			logger.debug({ receiptCount: receipts.length }, 'debugGetRawReceiptsHandler: encoding receipts to RLP')
    72	
    73			// Encode each receipt to RLP using consensus encoding format
    74			// This matches the format used in the receipts trie
    75			const encodedReceipts = receipts.map((receipt) => {
    76				// Consensus encoding: [status/stateRoot, cumulativeGasUsed, logsBloom, logs]
    77				const receiptArray = [
