   507				actualFile: traceOutFile,
   508				referenceFile: traceReferenceFile,
   509				outFile: traceDiffOutFile,
   510			})
   511		}
   512		writeJson(outFile, summary)
   513		console.log(`${suite} ${summary.status}: ${summary.passed}/${summary.total} upstream vectors passed`)
