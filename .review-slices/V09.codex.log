import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs'
import { dirname } from 'node:path'
import { fileURLToPath } from 'node:url'

const STATIC_OPCODES = {
	STOP: 0x00,
	ADD: 0x01,
	MUL: 0x02,
	SUB: 0x03,
	DIV: 0x04,
	SDIV: 0x05,
	MOD: 0x06,
