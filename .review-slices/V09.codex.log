	const txData = {
		...base,
		...(type !== undefined ? { type } : {}),
		gasPrice: toBigInt(transaction.gasPrice ?? '0x0'),
	}
	const tx = type === undefined ? createLegacyTx(txData, opts) : createTx(txData, opts)
	return tx.sign(privateKey)
}

