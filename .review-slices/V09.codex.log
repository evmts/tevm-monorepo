   477			const result = await runVector(
   478				vector,
   479				Boolean(traceOutFile) && (!isolate || vector.id === isolate || vector.name === isolate),
   480			)
   481			if (result.trace) traces.push({ id: result.id, hardfork: result.hardfork, trace: result.trace })
   482			const { trace: _, ...withoutTrace } = result
   483			results.push(withoutTrace)
   484		}
   485	
   486		if (traceOutFile) writeJson(traceOutFile, { suite, status: 'completed', synthetic: false, traces })
   487	
   488		const failed = results.filter((result) => result.status === 'failed').length
   489		const summary = {
   490			suite,
   491			status: failed === 0 ? 'passed' : 'failed',
   492			coverage: 'upstream',
   493			synthetic: false,
   494			fixturesPath,
   495			total: results.length,
   496			passed: results.length - failed,
   497			failed,
   498			skipped: 0,
   499			filters: { hardfork: hardfork ?? null, group: group ?? null, pattern: pattern ?? null, limit: limit ?? null },
   500			isolate: isolate ?? null,
   501			traceCompare,
   502			generatedAt: new Date().toISOString(),
   503			results,
   504		}
