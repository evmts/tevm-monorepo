				maxFee: tx.maxFeePerGas,
				tip: tx.maxPriorityFeePerGas,
			};
		}
		if (isLegacyTx(tx)) {
			return {
				maxFee: tx.gasPrice,
				tip: tx.gasPrice,
			};
		}

