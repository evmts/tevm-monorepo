			withdrawalsRoot: withdrawalsRoot as string,
			blobGasUsed: blobGasUsed as string,
			excessBlobGas: excessBlobGas as string,
			parentBeaconBlockRoot: parentBeaconBlockRoot as string,
			requestsRoot: requestsRoot as string,
		},
		options,
	)

	return blockHeader
}

