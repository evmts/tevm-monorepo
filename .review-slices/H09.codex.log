    89	/**
    90	 * @internal
    91	 * Captures the state of an account, including its storage based on accessed slots
    92	 * @param {import('@tevm/vm').Vm} vm
    93	 * @param {import('@tevm/node').TevmNode['logger']} logger
    94	 * @param {import('@tevm/utils').EthjsAddress} address
    95	 * @param {Set<import('@tevm/utils').Hex>} slots Set of storage slot keys that were accessed
    96	 * @returns {Promise<import('../common/AccountState.js').AccountState | undefined>}
    97	 */
    98	const captureAccountState = async (vm, logger, address, slots = new Set()) => {
    99		try {
   100			// Get account details
   101			const account = await vm.stateManager.getAccount(address)
   102			if (!account) return undefined
   103	
   104			// Get code
   105			const code = await vm.stateManager.getCode(address)
   106	
   107			// Get storage for all accessed slots
   108			/** @type {Record<import('@tevm/utils').Hex, import('@tevm/utils').Hex>} */
   109			const storage = {}
   110			for (const slotHex of slots) {
   111				try {
   112					// Convert hex slot to Uint8Array for getContractStorage
   113					const slotKey = hexToBytes(slotHex)
   114					const value = await vm.stateManager.getStorage(address, slotKey)
   115					storage[slotHex] = bytesToHex(value)
   116				} catch (err) {
   117					logger.error(err, `Error getting storage at slot ${slotHex} for account ${address.toString()}`)
   118				}
   119			}
   120	
   121			return {
   122				storage,
   123				balance: toHex(account.balance),
   124				nonce: Number(account.nonce),
   125				code: code && code.length > 0 ? bytesToHex(code) : '0x',
   126			}
   127		} catch (err) {
   128			logger.error(err, `Error capturing state for account ${address.toString()}`)
   129			return undefined
   130		}
   131	}
   132	
   133	/**
   134	 * @internal
   135	 * Formats the prestate trace result for diffMode
   136	 * @param {import('../common/PrestateTraceResult.js').PrestateTraceResult<true>["pre"]} preState
   137	 * @param {import('../common/PrestateTraceResult.js').PrestateTraceResult<true>["post"]} postState
   138	 * @returns {import('../common/PrestateTraceResult.js').PrestateTraceResult<true>}
   139	 */
   140	const formatDiffResult = (preState, postState) => {
   141		/** @type {import('../common/PrestateTraceResult.js').PrestateTraceResult<true>["post"]} */
   142		const postDiff = {}
   143	
   144		for (const address of Object.keys(postState)) {
   145			const addressHex = /** @type {import('@tevm/utils').Hex} */ (address)
   146			const pre = preState[addressHex]
   147			const post = postState[addressHex]
   148			if (!post) continue
   149	
   150			// Get all unique slot keys from both pre and post
   151			const allSlots = new Set([...Object.keys(pre?.storage ?? {}), ...Object.keys(post.storage ?? {})])
   152			// Build storage diff
   153			/** @type {Record<import('@tevm/utils').Hex, import('@tevm/utils').Hex>} */
   154			let storageDiff = {}
   155			for (const slot of allSlots) {
   156				const slotHex = /** @type {import('@tevm/utils').Hex} */ (slot)
   157				const preValue = pre?.storage?.[slotHex] ?? '0x0'
   158				const postValue = post.storage?.[slotHex] ?? '0x0'
   159	
   160				storageDiff = {
   161					...storageDiff,
   162					...(preValue !== postValue ? { [slotHex]: postValue } : {}),
   163				}
   164			}
   165	
   166			// Compare and capture differences
   167			const postDiffAccount = {
   168				...(pre !== undefined && post.balance !== undefined && pre.balance !== post.balance
   169					? { balance: post.balance }
   170					: {}),
   171				...(pre !== undefined && post.nonce !== undefined && pre.nonce !== post.nonce ? { nonce: post.nonce } : {}),
   172				...(pre !== undefined && post.code !== undefined && pre.code !== post.code ? { code: post.code } : {}),
   173				...(Object.keys(storageDiff).length > 0 ? { storage: storageDiff } : {}),
   174			}
   175	
   176			// Only add to diff if there were any changes
   177			if (Object.keys(postDiffAccount).length > 0) postDiff[addressHex] = postDiffAccount
   178		}
   179	
   180		// Return differentials
   181		return {
   182			pre: preState,
   183			post: postDiff,
   184		}
   185	}

