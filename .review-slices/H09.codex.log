     6	 * @param {import('@tevm/node').TevmNode} client
     7	 * @returns {import('./AnvilProcedure.js').AnvilSnapshotProcedure}
     8	 * @example
     9	 * ```javascript
    10	 * import { createTevmNode } from '@tevm/node'
    11	 * import { anvilSnapshotJsonRpcProcedure } from '@tevm/actions'
    12	 *
    13	 * const client = createTevmNode()
    14	 * const snapshotHandler = anvilSnapshotJsonRpcProcedure(client)
    15	 *
    16	 * const response = await snapshotHandler({
    17	 *   jsonrpc: '2.0',
    18	 *   method: 'anvil_snapshot',
    19	 *   id: 1,
    20	 *   params: []
    21	 * })
    22	 * console.log(response.result) // '0x1'
    23	 * ```
    24	 */
    25	export const anvilSnapshotJsonRpcProcedure = (client) => {
    26		return async (request) => {
    27			try {
    28				const vm = await client.getVm()
    29				const stateRoot = vm.stateManager._baseState.getCurrentStateRoot()
    30				const state = await vm.stateManager.dumpCanonicalGenesis()
    31				const metadata = await captureSnapshotMetadata(client, vm)
