    36				/**
    37				 * @type {import('./AnvilJsonRpcResponse.js').AnvilSnapshotJsonRpcResponse}
    38				 */
    39				const response = {
    40					jsonrpc: '2.0',
    41					method: request.method,
    42					result: /** @type {`0x${string}`} */ (snapshotId),
    43					...(request.id !== undefined ? { id: request.id } : {}),
    44				}
    45				return response
    46			} catch (e) {
    47				client.logger.error(e, 'anvil_snapshot failed')
    48				/**
    49				 * @type {import('./AnvilJsonRpcResponse.js').AnvilSnapshotJsonRpcResponse}
    50				 */
    51				const response = {
    52					jsonrpc: '2.0',
    53					method: request.method,
    54					...(request.id !== undefined ? { id: request.id } : {}),
    55					error: {
    56						// TODO use @tevm/errors
    57						code: /** @type {const} */ ('-32603'),
