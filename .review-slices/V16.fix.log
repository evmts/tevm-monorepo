   186			bunProcess.stdout.on('data', handleStdoutData)
   187	
   188			bunProcess.stderr.on('data', handleStderrData)
   189	
   190			bunProcess.on('exit', handleBunExit)
   191	
   192			bunProcess.on('error', handleBunError)
   193		})
   194	}
