    66			[gnosis.id]: gnosis,
    67			[moonbeam.id]: moonbeam,
    68			[anvil.id]: anvil,
    69			[blast.id]: blast,
    70			[scroll.id]: scroll,
    71		}
    72	
    73		const chain = chains[parseInt(chainId, 10)]
    74	
    75		if (!chain) {
    76			throw new Error(
    77				`Unknown chain id: ${chainId}. Valid chain ids are ${Object.entries(chains)
    78					.map(([id, chain]) => `${id} (${chain.name})`)
    79					.join(', ')}`,
    80			)
    81		}
    82	
    83		const client = createMemoryClient({
    84			common: chain,
    85			loggingLevel: loggingLevel as any,
    86			...(fork?.length
    87				? { fork: { transport: http(fork), ...(forkBlockNumber ? { blockTag: parseForkBlock(forkBlockNumber) } : {}) } }
    88				: {}),
    89		}) as unknown as MemoryClient
    90	
    91		// Add request logging if verbose mode is enabled
    92		if (verbose) {
    93			// Create a proxy around the request function
    94			const originalRequest = client.request
    95			client.request = createLoggingRequestProxy(originalRequest, verbose)
    96		}
    97	
    98		// Create and start the server
    99		const server = createServer(client as any) as unknown as HttpServer
   100	
   101		// Handle graceful shutdown
   102		const handleShutdown = () => {
   103			server.close()
   104			process.exit(0)
   105		}
   106	
   107		process.on('SIGINT', handleShutdown)
   108		process.on('SIGTERM', handleShutdown)
   109	
   110		await new Promise<void>((resolve) => {
   111			server.listen(port, host, () => {
   112				resolve()
   113			})
   114		})
   115	
   116		// Return the client and server for use by action components
   117		return { client, server }
   118	}

