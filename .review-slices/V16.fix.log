    80				}),
    81			),
    82	})
    83	
    84	type Props = {
    85		options: zod.infer<typeof options>
    86	}
    87	
    88	export default function Serve({ options }: Props) {
    89		const [activeTab, setActiveTab] = useState(0)
    90		const [isInteractive, setIsInteractive] = useState(false)
