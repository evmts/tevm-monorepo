   200	export function cleanupProject(projectDir) {
   201		try {
   202			// Use recursive removal for directories
   203			/**
   204			 * @param {string} dir
   205			 */
   206			const removeRecursive = (dir) => {
   207				if (fs.existsSync(dir)) {
   208					fs.readdirSync(dir).forEach((file) => {
   209						const curPath = path.join(dir, file)
   210						if (fs.lstatSync(curPath).isDirectory()) {
   211							// Recursive call for directories
   212							removeRecursive(curPath)
   213						} else {
   214							// Delete file
   215							fs.unlinkSync(curPath)
   216						}
   217					})
   218					fs.rmdirSync(dir)
   219				}
   220			}
   221	
   222			removeRecursive(projectDir)
   223		} catch (error) {
   224			console.error('Failed to clean up project directory:', error)
   225		}
   226	}
