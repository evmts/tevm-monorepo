   143	export async function executeTsFile(projectDir) {
   144		const scriptPath = path.join(projectDir, 'script.ts')
   145	
   146		return new Promise((resolve, reject) => {
   147			let stdout = ''
   148			let stderr = ''
   149	
   150			const bunProcess = spawn('bun', ['run', scriptPath], {
   151				cwd: projectDir,
   152				stdio: ['ignore', 'pipe', 'pipe'],
   153			})
   154			const handleStdoutData = /** @type {(data: any) => void} */ (
   155				(data) => {
   156					stdout += data.toString()
   157				}
   158			)
   159			const handleStderrData = /** @type {(data: any) => void} */ (
   160				(data) => {
   161					stderr += data.toString()
   162				}
   163			)
   164			const handleBunExit = /** @type {(code: number | null) => void} */ (
   165				(code) => {
   166					if (code === 0) {
   167						try {
   168							// Try to parse the output as JSON
   169							const result = JSON.parse(stdout.trim())
   170							resolve(result)
   171						} catch (_error) {
   172							// If parsing fails, return the raw output
   173							resolve(stdout.trim())
   174						}
   175					} else {
   176						reject(new Error(`Execution failed (code ${code}): ${stderr}`))
   177					}
   178				}
   179			)
   180			const handleBunError = /** @type {(error: Error) => void} */ (
   181				(error) => {
   182					reject(new Error(`Failed to execute: ${error.message}`))
   183				}
   184			)
