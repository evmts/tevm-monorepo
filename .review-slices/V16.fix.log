   228	/**
   229	 * Checks if dependencies are installed
   230	 * @param {string} dir - The project directory
   231	 * @returns {Promise<boolean>} - True if dependencies are installed, false otherwise
   232	 */
   233	export async function checkDependenciesInstalled(dir) {
   234		const waitingPath = path.join(dir, '.installing')
   235		const readyPath = path.join(dir, '.ready')
   236	
   237		// Check if dependencies are already installed
   238		if (fs.existsSync(readyPath)) {
   239			return true
   240		}
   241	
   242		// Check if installation is still in progress
   243		if (fs.existsSync(waitingPath)) {
   244			return false
   245		}
   246	
   247		// If neither file exists, likely the installation has completed but the status wasn't updated
   248		return true
   249	}
   250	
   251	/**
   252	 * Waits for dependencies to be installed
   253	 * @param {string} dir - The project directory
   254	 * @param {number} timeout - Timeout in milliseconds
   255	 * @returns {Promise<void>}
   256	 */
   257	export async function waitForDependencies(dir, timeout = 30000) {
   258		const startTime = Date.now()
   259	
   260		// Poll for installation completion
   261		while (Date.now() - startTime < timeout) {
   262			const isInstalled = await checkDependenciesInstalled(dir)
   263			if (isInstalled) {
   264				return
   265			}
   266			await new Promise((resolve) => setTimeout(resolve, 500)) // Check every 500ms
   267		}
   268	
   269		// If we get here, we've timed out
   270		console.warn('Dependency installation timed out, attempting to continue anyway...')
   271	}

