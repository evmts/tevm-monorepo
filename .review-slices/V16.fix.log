   101					<ActionTab actionName="Call" interactive={isInteractive} rpcUrl={rpcUrl} ActionComponent={Call} />
   102				),
   103			},
   104			{
   105				name: 'GetAccount',
   106				component: () => (
   107					<ActionTab actionName="GetAccount" interactive={isInteractive} rpcUrl={rpcUrl} ActionComponent={GetAccount} />
   108				),
   109			},
   110			{
   111				name: 'SetAccount',
   112				component: () => (
   113					<ActionTab actionName="SetAccount" interactive={isInteractive} rpcUrl={rpcUrl} ActionComponent={SetAccount} />
   114				),
   115			},
   116			{ name: 'Logs', component: LogViewer },
   117		]
