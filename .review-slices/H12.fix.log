diff --git a/bundler-packages/base-bundler/src/resolveCacheKey.js b/bundler-packages/base-bundler/src/resolveCacheKey.js
new file mode 100644
index 0000000000000000000000000000000000000000..c3f6461b28d51c94388c703a85094455b0860f6e
--- /dev/null
+++ b/bundler-packages/base-bundler/src/resolveCacheKey.js
@@ -0,0 +1,15 @@
+import { isAbsolute, resolve } from 'node:path'
+
+const formatPath = (filePath) => filePath.replace(/\\/g, '/')
+
+/**
+ * @param {string} modulePath
+ * @param {string} basedir
+ * @returns {string}
+ */
+export const resolveCacheKey = (modulePath, basedir) => {
+	if (modulePath.startsWith('.') || isAbsolute(modulePath)) {
+		return formatPath(resolve(basedir, modulePath))
+	}
+	return modulePath
+}
