     8	 * current working directory and appends the appropriate filename based on the item type.
     9	 *
    10	 * @param {string} entryModuleId - Path to the Solidity file (absolute path)
    11	 * @param {import('./types.js').CachedItem} item - Type of cached item ('dts', 'artifactsJson', or 'mjs')
    12	 * @param {string} cwd - Current working directory
    13	 * @param {string} cacheDir - Cache directory (relative to cwd)
    14	 * @returns {{dir: string, path: string}} Object containing the directory and full path
    15	 *   - dir: Directory where the cached file should be stored
    16	 *   - path: Full path to the cached file including filename
    17	 *
    18	 * @example
    19	 * ```javascript
    20	 * import { getArtifactsPath } from '@tevm/bundler-cache'
    21	 *
    22	 * // Get path for cached TypeScript declarations
    23	 * const { dir, path } = getArtifactsPath(
    24	 *   '/projects/my-dapp/contracts/Token.sol',  // Solidity file path
    25	 *   'dts',                                   // TypeScript declarations
    26	 *   '/projects/my-dapp',                     // Current working directory
    27	 *   '.tevm'                                  // Cache directory
    28	 * )
    29	 *
    30	 * console.log(dir)   // '/projects/my-dapp/.tevm/contracts/Token.sol'
    31	 * console.log(path)  // '/projects/my-dapp/.tevm/contracts/Token.sol/contract.d.ts'
    32	 * ```
    33	 *
    34	 * @internal
    35	 */
    36	export const getArtifactsPath = (entryModuleId, item, cwd, cacheDir) => {
    37		// Select the appropriate filename based on the item type
    38		const fileName = {
    39			dts: 'contract.d.ts', // TypeScript declaration file
    40			artifactsJson: 'artifacts.json', // Solidity compilation artifacts
    41			mjs: 'contract.mjs', // ES module JavaScript file
    42		}[item]
    43	
    44		const cacheRoot = path.resolve(cwd, cacheDir)
    45		const entryPath = path.resolve(cwd, entryModuleId)
    46		const relativeEntryPath = path.relative(path.resolve(cwd), entryPath)
    47		const isOutsideCwd = relativeEntryPath === '..' || relativeEntryPath.startsWith(`..${path.sep}`) || path.isAbsolute(relativeEntryPath)
    48		const normalizedEntryModuleId =
    49			isOutsideCwd
