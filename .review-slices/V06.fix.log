+			const stat = fs.statSync(sourcePath)
+			const content = typeof source?.content === 'string' ? source.content : undefined
+			return [
+				sourcePath,
+				{
+					mtimeMs: stat.mtimeMs,
+					size: stat.size,
+					...(content === undefined ? {} : { contentHash: cacheHash(content) }),
+				},
+			]
+		}),
+	)
+}
