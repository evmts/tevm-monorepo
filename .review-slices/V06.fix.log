    18	 * import { getMetadataPath } from '@tevm/bundler-cache'
    19	 *
    20	 * // Get path for metadata file
    21	 * const { dir, path } = getMetadataPath(
    22	 *   '/projects/my-dapp/contracts/Token.sol',  // Solidity file path
    23	 *   '/projects/my-dapp',                     // Current working directory
    24	 *   '.tevm'                                  // Cache directory
    25	 * )
    26	 *
    27	 * console.log(dir)   // '/projects/my-dapp/.tevm/contracts/Token.sol'
    28	 * console.log(path)  // '/projects/my-dapp/.tevm/contracts/Token.sol/metadata.json'
    29	 * ```
    30	 *
    31	 * @internal
    32	 */
    33	export const getMetadataPath = (entryModuleId, cwd, cacheDir) => {
    34		const cacheRoot = path.resolve(cwd, cacheDir)
    35		const entryPath = path.resolve(cwd, entryModuleId)
    36		const relativeEntryPath = path.relative(path.resolve(cwd), entryPath)
    37		const isOutsideCwd = relativeEntryPath === '..' || relativeEntryPath.startsWith(`..${path.sep}`) || path.isAbsolute(relativeEntryPath)
    38		const normalizedEntryModuleId =
    39			isOutsideCwd
    40				? path.join('__external__', entryPath.replace(/^[A-Za-z]:/, '').split(path.sep).filter(Boolean).join(path.sep))
    41				: relativeEntryPath
    42	
    43		const dir = path.resolve(cacheRoot, normalizedEntryModuleId)
    44		const resolvedPath = path.join(dir, 'metadata.json')
    45	
    46		return { dir, path: resolvedPath }
    47	}

