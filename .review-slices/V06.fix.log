+const writeFileAtomically = async (path, content, fs) => {
+	if (typeof fs.rename !== 'function') {
+		await fs.writeFile(path, content)
+		return
+	}
+	const tmpPath = `${path}.${process.pid}.${Date.now()}.${Math.random().toString(16).slice(2)}.tmp`
