    10	/**
    11	 * Deals ERC20 tokens to an account by overriding the storage of balanceOf(account)
    12	 * @param {import('@tevm/node').TevmNode} node
    13	 * @returns {import('./AnvilHandler.js').AnvilDealHandler}
    14	 */
    15	export const dealHandler =
    16		(node) =>
    17		async ({ erc20, account, amount }) => {
    18			if (!erc20) {
    19				return setAccountHandler(node)({
    20					address: account,
    21					balance: amount,
    22				})
    23			}
    24	
    25			const value = numberToHex(amount, { size: 32 })
    26	
    27			// Get storage slots accessed by balanceOf
    28			const accessListResponse = await ethCreateAccessListProcedure(node)({
    29				method: 'eth_createAccessList',
    30				params: [
    31					{
    32						to: erc20,
    33						data: encodeFunctionData({
    34							abi: ERC20.abi,
    35							functionName: 'balanceOf',
    36							args: [account],
    37						}),
    38					},
    39				],
    40				id: 1,
    41				jsonrpc: '2.0',
    42			})
    43	
    44			if (!accessListResponse.result?.accessList) {
    45				console.error(accessListResponse.error)
    46				throw new Error('Failed to get access list')
    47			}
    48	
    49			// Track all storage slots we modify so we can reset them later if needed
    50			const modifiedSlots = []
    51	
    52			// Try each storage slot until we find the right one
    53			for (const { address, storageKeys } of accessListResponse.result.accessList) {
    54				for (const slot of storageKeys) {
    55					// Get existing storage value
    56					const oldValue = await getStorageAtHandler(node)({
    57						address,
    58						position: slot,
    59						blockTag: 'latest',
    60					})
    61	
    62					// Set new value
    63					await anvilSetStorageAtJsonRpcProcedure(node)({
    64						method: 'anvil_setStorageAt',
    65						params: [address, slot, value],
    66						id: 1,
    67						jsonrpc: '2.0',
    68					})
    69	
    70					// Track modified slot
    71					modifiedSlots.push({ address, slot, oldValue })
    72	
    73					// Check if balance updated correctly - with throwOnFail: false to handle errors
    74					const balanceResponse = await contractHandler(node)({
    75						to: erc20,
    76						abi: ERC20.abi,
    77						functionName: 'balanceOf',
    78						args: [account],
    79						throwOnFail: false,
    80					})
    81	
    82					// Check if the balance call succeeded and matches expected value
    83					if (!balanceResponse.errors && balanceResponse.data === hexToBigInt(value)) {
    84						// Found correct slot, reset all other slots
    85						for (const { address: resetAddr, slot: resetSlot, oldValue: resetValue } of modifiedSlots) {
    86							// Skip the correct slot
    87							if (resetAddr === address && resetSlot === slot) continue
    88	
    89							// Reset any other modified slot
    90							await anvilSetStorageAtJsonRpcProcedure(node)({
    91								method: 'anvil_setStorageAt',
    92								params: [resetAddr, resetSlot, resetValue],
    93								id: 1,
    94								jsonrpc: '2.0',
    95							})
    96						}
    97						// Found correct slot, return success
    98						return {}
    99					}
   100	
   101					// This slot didn't work, revert it immediately
