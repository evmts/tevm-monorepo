     4	/**
     5	 * Handler for anvil_addBalance - adds to an account's ETH balance
     6	 * This is a convenience method that reads the current balance, adds the amount,
     7	 * and sets the new balance.
     8	 *
     9	 * @param {import('@tevm/node').TevmNode} node
    10	 * @returns {import('./AnvilHandler.js').AnvilAddBalanceHandler}
    11	 * @throws {Error} if setting the balance fails
    12	 * @example
    13	 * ```typescript
    14	 * import { createTevmNode } from '@tevm/node'
    15	 * import { anvilAddBalanceHandler } from '@tevm/actions'
    16	 *
    17	 * const node = createTevmNode()
    18	 * const handler = anvilAddBalanceHandler(node)
    19	 *
    20	 * // Add 1 ETH to an account
    21	 * await handler({
    22	 *   address: '0x1234567890123456789012345678901234567890',
    23	 *   amount: 1000000000000000000n // 1 ETH in wei
    24	 * })
    25	 * ```
    26	 */
    27	export const anvilAddBalanceHandler = (node) => {
    28		/**
    29		 * @type {import('./AnvilHandler.js').AnvilAddBalanceHandler}
    30		 */
    31		const handler = async ({ address, amount }) => {
    32			// Get current balance
    33			const currentBalance = await getBalanceHandler(node)({
    34				address,
    35				blockTag: 'latest',
    36			})
    37	
    38			// Convert amount to bigint if it's a hex string
    39			const amountBigInt = typeof amount === 'bigint' ? amount : BigInt(/** @type {`0x${string}`} */ (amount))
    40	
    41			// Calculate new balance
    42			const newBalance = currentBalance + amountBigInt
    43	
    44			// Set the new balance
    45			const result = await setAccountHandler(node)({
    46				address,
    47				balance: newBalance,
    48			})
    49	
    50			// Throw if there were errors
    51			if (result.errors && result.errors.length > 0) {
    52				throw result.errors[0]
    53			}
    54	
    55			// Return null on success per the AnvilAddBalanceResult type
    56			return null
    57		}
    58		return handler
    59	}

