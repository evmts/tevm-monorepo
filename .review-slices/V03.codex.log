   104						params: [address, slot, oldValue],
   105						id: 1,
   106						jsonrpc: '2.0',
   107					})
   108	
   109					// Also remove it from modifiedSlots since we've already reset it
   110					modifiedSlots.pop()
   111				}
   112			}
