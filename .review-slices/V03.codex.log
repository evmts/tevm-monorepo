     4	/**
     5	 * Request handler for anvil_reset JSON-RPC requests.
     6	 * If the node is forked, anvil_reset will reset to the forked block.
     7	 * @param {import('@tevm/node').TevmNode} node
     8	 * @returns {import('./AnvilProcedure.js').AnvilResetProcedure}
     9	 * @example
    10	 * const node = createTevmNode()
    11	 * const resetProcedure = anvilResetJsonRpcProcedure(node)
    12	 * const result = await resetProcedure({ method: 'anvil_reset', params: [], id: 1, jsonrpc: '2.0' })
    13	 * console.log(result) // { result: null, method: 'anvil_reset', jsonrpc: '2.0', id: 1 }
    14	 */
    15	export const anvilResetJsonRpcProcedure = (node) => {
    16		return async (request) => {
    17			const resetParams = /** @type {any} */ (request.params?.[0])
    18			const newForkUrl = resetParams?.forking?.jsonRpcUrl
    19			if (newForkUrl !== undefined) {
    20				if (!node.forkTransport || !('url' in node.forkTransport)) {
    21					return {
    22						jsonrpc: '2.0',
    23						method: request.method,
    24						error: {
    25							code: /** @type {const} */ ('-32602'),
    26							message: 'Cannot update fork URL on a non-forked node.',
    27						},
    28						...(request.id ? { id: request.id } : {}),
    29					}
    30				}
    31				/** @type {any} */
    32				node.forkTransport.url = newForkUrl
    33			}
    34	
    35			// reset filters
    36			const filters = node.getFilters()
    37			filters.forEach((/** @type {any} */ filter) => {
    38				node.removeFilter(filter.id)
    39			})
    40	
    41			// reset impersonated account
    42			node.setImpersonatedAccount(undefined)
    43			node.setAutoImpersonate(false)
    44			node.setNextBlockTimestamp(undefined)
    45			node.setBlockTimestampInterval(undefined)
    46			node.setNextBlockGasLimit(undefined)
    47			node.setNextBlockBaseFeePerGas(undefined)
    48			node.setNextBlockPrevRandao(undefined)
    49			node.setMinGasPrice(undefined)
    50	
    51			const txPool = await node.getTxPool()
    52			await clearTxPool(txPool)
    53	
    54			const vm = await node.getVm()
    55			const newStateManager = vm.stateManager.shallowCopy()
    56			const newBlockchain = vm.blockchain.shallowCopy()
    57			const forkedBlock = vm.blockchain.blocksByTag.get('forked')
    58			if (forkedBlock) {
    59				await newBlockchain.putBlock(forkedBlock)
    60			}
    61			vm.stateManager = /** @type {any}*/ (newStateManager)
    62			vm.evm.stateManager = /** @type {any}*/ (newStateManager)
    63			vm.blockchain = newBlockchain
    64			vm.evm.blockchain = newBlockchain
    65	
    66			// reset receipts manager
    67			/**
    68			 * @type {any} making this any because we are modifying readonly properties
    69			 */
    70			const receiptManager = await node.getReceiptsManager()
    71			// TODO we should add a receiptManager.reset() method
