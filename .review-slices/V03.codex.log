     1	import { AccountCache, CacheType, StorageCache } from '@evmts/zevm/statemanager'
     2	import { ContractCache } from '../ContractCache.js'
     3	import { createBaseState } from '../createBaseState.js'
     4	
     5	/**
     6	 * Returns a new instance of the ForkStateManager with the same opts but no storage copied over.
     7	 *
     8	 * IMPORTANT: The fork cache is NOT copied but instead is shared between the original state
     9	 * and the copied state. This is intentional and safe because:
    10	 * 1. Fork cache is read-only relative to the forked blockchain state at a specific block
    11	 * 2. Sharing the cache improves performance by preventing duplicate remote fetches
    12	 * 3. It enables persistent caching of fork data across VM instances
    13	 *
    14	 * @param {import('../BaseState.js').BaseState} baseState
    15	 * @returns {() => import('../BaseState.js').BaseState}
    16	 */
    17	export const shallowCopy = (baseState) => () => {
    18		const newState = createBaseState(baseState.options)
    19		newState.caches.contracts = new ContractCache()
    20		newState.caches.storage = new StorageCache({
    21			size: 100000,
    22			type: CacheType.LRU,
    23		})
    24		newState.caches.accounts = new AccountCache({
    25			size: 100000,
    26			type: CacheType.LRU,
    27		})
    28	
    29		// Share the fork cache object between instances rather than creating a new one
    30		// This is safe because the fork cache is conceptually read-only
    31		// relative to the forked blockchain at a specific block
    32		if (baseState.forkCache) {
    33			// Directly assign the same fork cache object
    34			newState.forkCache = baseState.forkCache
    35			baseState.logger.debug('Sharing fork cache reference between original and shallow copied state')
    36		}
    37	
    38		return newState
    39	}

