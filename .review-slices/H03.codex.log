    18		const newState = createBaseState(baseState.options)
    19		newState.caches.contracts = new ContractCache()
    20		newState.caches.storage = new StorageCache({
    21			size: 100000,
    22			type: CacheType.LRU,
    23		})
    24		newState.caches.accounts = new AccountCache({
    25			size: 100000,
    26			type: CacheType.LRU,
    27		})
    28	
    29		// Share the fork cache object between instances rather than creating a new one
    30		// This is safe because the fork cache is conceptually read-only
    31		// relative to the forked blockchain at a specific block
    32		if (baseState.forkCache) {
    33			// Directly assign the same fork cache object
    34			newState.forkCache = baseState.forkCache
    35			baseState.logger.debug('Sharing fork cache reference between original and shallow copied state')
    36		}
    37	
    38		return newState
