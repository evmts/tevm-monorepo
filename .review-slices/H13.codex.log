     1	type QueuedUpdate = { type: 'optimistic'; fn: () => Promise<void> } | { type: 'canonical'; fn: () => Promise<void> }
     2	
     3	/**
     4	 * Coordinates state updates to prevent race conditions between optimistic and canonical updates.
     5	 *
     6	 * Race condition: when canonical sync removes optimistic txs from the pool (in createSyncAdapter:storageAdapter:onTx) but before applying
     7	 * the canonical state to stash (in createSyncAdapter:storageAdapter:applyStashUpdates), a pending optimistic update could run and see empty pool +
     8	 * old canonical state, causing UI to briefly flash to incorrect intermediate state.
     9	 *
    10	 * Solution: queue all updates and let canonical updates clear pending optimistic ones since
    11	 * canonical updates naturally trigger fresh optimistic calculations via stash subscribers.
    12	 */
    13	class StateUpdateCoordinator {
    14		private isRunning = false
    15		private queue: QueuedUpdate[] = []
    16	
    17		queueOptimisticUpdate(fn: () => Promise<void>): void {
    18			this.enqueue({ type: 'optimistic', fn })
    19		}
    20	
    21		queueCanonicalUpdate(fn: () => Promise<void>): void {
    22			this.enqueue({ type: 'canonical', fn })
    23		}
    24	
    25		private enqueue(update: QueuedUpdate): void {
    26			// If queueing canonical update, clear pending optimistic updates
    27			// since canonical will trigger fresh optimistic updates anyway
    28			if (update.type === 'canonical') {
    29				this.queue = this.queue.filter((op) => op.type !== 'optimistic')
    30			}
    31	
    32			this.queue.push(update)
    33			this.processQueue()
    34		}
    35	
    36		private async processQueue(): Promise<void> {
    37			if (this.isRunning || this.queue.length === 0) return
    38	
    39			this.isRunning = true
    40	
    41			try {
    42				while (this.queue.length > 0) {
    43					const update = this.queue.shift()!
    44					await update.fn()
    45				}
    46			} finally {
    47				this.isRunning = false
    48			}
    49		}
    50	}
    51	
    52	export const stateUpdateCoordinator = new StateUpdateCoordinator()

