diff --git a/packages/actions/src/internal/resetForkState.js b/packages/actions/src/internal/resetForkState.js
new file mode 100644
index 0000000000000000000000000000000000000000..aae2b5a10a20c396726c5b167c6c0a6f8c622ef6
