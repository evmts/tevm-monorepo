    93	 *   address: `0x${'69'.repeat(20)}`,
    94	 *   nonce: toHex(1n),
    95	 *   balance: toHex(420n),
    96	 * }),
    97	 * console.log(await provider.send('tevm_getAccount', {
    98	 *   address: `0x${'69'.repeat(20)}`,
    99	 * }))
   100	 * //	address: '0x6969696969696969696969696969696969696969',
