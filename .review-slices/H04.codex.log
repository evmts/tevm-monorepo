   441					stringToHex(JSON.stringify(logsForSizing, (_key, value) => (typeof value === 'bigint' ? value.toString() : value))),
   442				).byteLength
   443				if (returnedLogs.length >= this.GET_LOGS_LIMIT || returnedLogsSize >= this.GET_LOGS_LIMIT_MEGABYTES * 1048576) {
   444					break
   445				}
   446			}
   447			return returnedLogs
   448		}
   449	
   450		/**
   451		 * Updates indexes in the database based on the operation type
   452		 * Used internally to maintain transaction hash to receipt mappings
   453		 *
   454		 * @param operation - Whether to save or delete indexes
   455		 * @param type - The type of index to update
   456		 * @param value - The data used to update indexes (typically a block)
   457		 * @returns Promise that resolves when the update is complete
   458		 * @private
   459		 */
   460		private async updateIndex(operation: IndexOperation, type: IndexType.TxHash, value: Block): Promise<void>
   461		private async updateIndex(operation: IndexOperation, type: IndexType, value: any): Promise<void> {
   462			switch (type) {
   463				case IndexType.TxHash: {
   464					const block = value
   465					if (operation === IndexOperation.Save) {
   466						for (const [i, tx] of block.transactions.entries()) {
   467							const index: TxHashIndex = [block.hash(), i]
   468							const encoded = this.rlp(RlpConvert.Encode, RlpType.TxHash, index)
   469							await this.mapDb.put('TxHash', tx.hash(), encoded)
   470						}
   471					} else if (operation === IndexOperation.Delete) {
   472						for (const tx of block.transactions) {
   473							await this.mapDb.delete('TxHash', tx.hash())
   474						}
   475					}
   476					break
   477				}
   478				default:
   479					throw new Error('Unsupported index type')
   480			}
   481		}
   482	
   483		/**
   484		 * Retrieves an index value from the database
   485		 * Used internally to look up transaction hash mappings
   486		 *
   487		 * @param type - The type of index to retrieve
   488		 * @param value - The key to look up (typically a transaction hash)
   489		 * @returns Promise resolving to the index value or null if not found
   490		 * @private
   491		 */
   492		private async getIndex(type: IndexType.TxHash, value: Uint8Array): Promise<TxHashIndex | null>
   493		private async getIndex(type: IndexType, value: Uint8Array): Promise<any | null> {
   494			switch (type) {
   495				case IndexType.TxHash: {
   496					const encoded = await this.mapDb.get('TxHash', value)
   497					if (!encoded) return null
   498					return this.rlp(RlpConvert.Decode, RlpType.TxHash, encoded)
   499				}
   500				default:
   501					throw new Error('Unsupported index type')
   502			}
   503		}
   504	
   505		/**
   506		 * Encodes or decodes data using RLP serialization for database storage
   507		 * Supports different data types and formats based on the parameters
   508		 *
   509		 * @param conversion - Whether to encode or decode
   510		 * @param type - The type of data being processed
   511		 * @param value - The data to encode or decode
   512		 * @returns Encoded bytes or decoded data structures
   513		 * @private
   514		 */
   515		private rlp(conversion: RlpConvert.Encode, type: RlpType, value: rlpOut): Uint8Array
   516		private rlp(conversion: RlpConvert.Decode, type: RlpType.Receipts, values: Uint8Array): TxReceipt[]
   517		private rlp(conversion: RlpConvert.Decode, type: RlpType.Logs, value: rlpLog[]): EthjsLog[]
   518		private rlp(conversion: RlpConvert.Decode, type: RlpType.TxHash, value: Uint8Array): TxHashIndex
   519		private rlp(conversion: RlpConvert, type: RlpType, value: Uint8Array | rlpOut): Uint8Array | rlpOut {
   520			switch (type) {
   521				case RlpType.Receipts: {
   522					if (conversion === RlpConvert.Encode) {
   523						return encodeStoredReceipts(value as TxReceipt[])
   524					}
   525					return decodeStoredReceipts(value as Uint8Array) as TxReceipt[]
   526				}
   527				case RlpType.Logs:
   528					if (conversion === RlpConvert.Encode) {
   529						return encodeReceiptLogs(value as EthjsLog[])
   530					}
   531					return decodeReceiptLogs(value as Uint8Array)
   532				case RlpType.TxHash: {
   533					if (conversion === RlpConvert.Encode) {
   534						return encodeTxHashIndex(value as TxHashIndex)
   535					}
   536					return decodeTxHashIndex(value as Uint8Array)
   537				}
   538				default:
   539					throw new Error('Unknown rlp conversion')
   540			}
   541		}
   542	
   543		/**
   544		 * Calculates a Bloom filter for a set of transaction logs
   545		 * Used for efficient log filtering and lookups
   546		 *
   547		 * @param logs - The logs to include in the bloom filter
   548		 * @returns A Bloom filter containing the log data
   549		 * @private
   550		 */
   551		private logsBloom(logs: rlpLog[]) {
   552			const bloom = new Bloom()
   553			for (let i = 0; i < logs.length; i++) {
   554				const log = logs[i]
   555				if (!log) {
   556					throw new Error('Log is empty')
   557				}
   558				// add the address
   559				bloom.add(log[0])
   560				// add the topics
   561				const topics = log[1]
   562				for (let q = 0; q < topics.length; q++) {
   563					bloom.add(topics[q] as Uint8Array)
   564				}
   565			}
   566			return bloom
   567		}
   568	}

