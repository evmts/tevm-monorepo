     1	/**
     2	 * @internal
     3	 * A simple throttle function
     4	 * @type {import('./ThrottleFn.ts').ThrottleFn}
     5	 */
     6	export const throttle = (func, wait = 100) => {
     7		/**
     8		 * @type {ReturnType<typeof setTimeout> | null}
     9		 */
    10		let timer = null
    11		/**
    12		 * @type {Array<any>}
    13		 */
    14		let params
    15		/**
    16		 * @param {...any[]} args
    17		 */
    18		const throttledFn = (...args) => {
    19			// set the latest args
    20			params = args
    21			if (timer === null) {
    22				// wait til wait time after first call to run the function
    23				timer = setTimeout(() => {
    24					const f = /** @type {any}*/ (func)
    25					const res = f(...params)
    26					timer = null
    27					return res
    28				}, wait)
    29			}
    30		}
    31		return /** @type any*/ (throttledFn)
    32	}

