   439					return logs.filter((log) => {
   440						for (const [i, topic] of topics.entries()) {
   441							if (Array.isArray(topic)) {
   442								// [A, B] = A OR B in this position
   443								if (!topic.find((t) => toHex(t) === toHex(log[1][i] as Uint8Array))) {
   444									return false
   445								}
