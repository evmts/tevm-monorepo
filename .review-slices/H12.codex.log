   127	/**
   128	 * Typesafe wrapper around solc.compile
   129	 * @param {any} solc
   130	 * @param {import("./solcTypes.js").SolcInputDescription} input
   131	 * @returns {import("./solcTypes.js").SolcOutput}
   132	 */
   133	export const solcCompile = (solc, input) => {
   134		try {
   135			return JSON.parse(solc.compile(JSON.stringify(input)))
   136		} catch (_e) {
   137			// temporary hack to fix a bug in ts-plugin
   138			return JSON.parse(_solc.compile(JSON.stringify(input)))
   139		}
   140	}
   141	
   142	/**
   143	 * @param {keyof import("./solcTypes.js").Releases} release
   144	 * @returns {Promise<import("./solcTypes.js").Solc>} An instance of solc
   145	 */
   146	export const createSolc = async (release) => {
   147		const s = await new Promise((resolve, reject) =>
   148			_solc.loadRemoteVersion(releases[release], (/** @type {any}*/ e, /** @type {any}*/ s) => {
   149				if (e) {
   150					reject(e)
   151				} else {
   152					resolve(s)
   153				}
   154			}),
   155		)
   156		return {
   157			...s,
   158			compile: (input) => solcCompile(s, input),
   159		}
   160	}

