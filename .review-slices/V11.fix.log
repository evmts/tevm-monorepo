   197	
   198	const vectorMatches = (vector) => {
   199		const id = vector.id.toLowerCase()
   200		if (isolate && vector.id !== isolate && vector.name !== isolate && !id.includes(isolate.toLowerCase())) return false
   201		if (hardfork && !isHardforkSelected(vector.hardfork, hardfork)) return false
   202		if (pattern && !id.includes(pattern.toLowerCase())) return false
   203		if (group && !id.includes(group.toLowerCase())) return false
   204		return true
   205	}
   206	
   207	const accountToTevm = ([address, account]) => {
   208		const code = normalizeDataHex(account.code)
   209		const storage = Object.fromEntries(
   210			Object.entries(account.storage ?? {})
   211				.filter(([, value]) => toBigInt(value) !== 0n)
   212				.map(([key, value]) => [pad32(key), normalizeHex(value)]),
   213		)
   214		return [
   215			padAddress(address),
   216			{
   217				nonce: toBigInt(account.nonce ?? '0x0'),
   218				balance: toBigInt(account.balance ?? '0x0'),
   219				storageRoot: EMPTY_TRIE_ROOT,
   220				codeHash: code === '0x' ? EMPTY_CODE_HASH : keccak256(hexToBytes(code)),
   221				storage,
   222				...(code !== '0x' ? { deployedBytecode: code } : {}),
   223			},
   224		]
   225	}
   226	
   227	const makeState = (pre) => Object.fromEntries(Object.entries(pre).map(accountToTevm))
   228	
   229	const makeCommon = (fork) =>
   230		createCommon({
   231			...mainnet,
   232			hardfork: commonHardfork(fork),
   233			loggingLevel: 'warn',
   234		})
   235	
   236	const makeBlock = (env, common) => {
   237		const isPoS = common.ethjsCommon.gteHardfork('paris')
   238		return Block.fromBlockData(
   239			{
   240				header: {
   241					parentHash: normalizeDataHex(env.previousHash, `0x${'00'.repeat(32)}`),
   242					coinbase: padAddress(env.currentCoinbase ?? `0x${'00'.repeat(20)}`),
   243					difficulty: isPoS ? 0n : toBigInt(env.currentDifficulty ?? '0x0'),
   244					gasLimit: toBigInt(env.currentGasLimit ?? '0x1fffffffffffff'),
   245					number: toBigInt(env.currentNumber ?? '0x0'),
   246					timestamp: toBigInt(env.currentTimestamp ?? '0x0'),
   247					baseFeePerGas: toBigInt(env.currentBaseFee ?? '0x0'),
   248					mixHash: normalizeDataHex(env.currentRandom, `0x${'00'.repeat(32)}`),
   249				},
   250			},
   251			{ common },
   252		)
   253	}
   254	
   255	const indexed = (values, index, fallback) => {
   256		if (!Array.isArray(values)) return fallback
   257		const value = values[Number(index ?? 0)]
   258		return value === undefined ? fallback : value
   259	}
   260	
   261	const normalizeAccessList = (accessList) => {
   262		if (!Array.isArray(accessList)) return []
   263		return accessList.map((item) => {
   264			if (Array.isArray(item)) return [padAddress(item[0]), item[1]?.map(pad32) ?? []]
   265			return {
   266				address: padAddress(item.address),
   267				storageKeys: (item.storageKeys ?? []).map(pad32),
   268			}
   269		})
   270	}
   271	
   272	const makeTx = (transaction, post, common) => {
   273		const indexes = post.indexes ?? {}
   274		const data = normalizeDataHex(indexed(transaction.data, indexes.data, '0x'))
   275		const gasLimit = toBigInt(indexed(transaction.gasLimit, indexes.gas, '0x0'))
   276		const value = toBigInt(indexed(transaction.value, indexes.value, '0x0'))
   277		const to = transaction.to === '' ? undefined : padAddress(transaction.to)
   278		const base = {
   279			nonce: toBigInt(transaction.nonce ?? '0x0'),
   280			gasLimit,
   281			to,
   282			value,
   283			data,
   284		}
   285		const opts = { common: common.ethjsCommon }
   286		const privateKey = hexToBytes(normalizeDataHex(transaction.secretKey))
   287		if (transaction.maxFeePerGas !== undefined || transaction.maxPriorityFeePerGas !== undefined) {
   288			const tx = createFeeMarket1559Tx(
   289				{
   290					...base,
   291					type: TransactionType.FeeMarketEIP1559,
   292					maxFeePerGas: toBigInt(transaction.maxFeePerGas ?? transaction.gasPrice ?? '0x0'),
   293					maxPriorityFeePerGas: toBigInt(transaction.maxPriorityFeePerGas ?? transaction.gasPrice ?? '0x0'),
   294					accessList: normalizeAccessList(indexed(transaction.accessLists, indexes.accessList, [])),
   295				},
   296				opts,
   297			)
   298			return tx.sign(privateKey)
   299		}
   300		if (transaction.accessLists !== undefined) {
   301			const tx = createAccessList2930Tx(
   302				{
   303					...base,
   304					type: TransactionType.AccessListEIP2930,
   305					gasPrice: toBigInt(transaction.gasPrice ?? '0x0'),
   306					accessList: normalizeAccessList(indexed(transaction.accessLists, indexes.accessList, [])),
   307				},
   308				opts,
   309			)
   310			return tx.sign(privateKey)
   311		}
   312		const type = transaction.type === undefined ? undefined : Number(toBigInt(transaction.type))
   313		const txData = {
   314			...base,
   315			...(type !== undefined ? { type } : {}),
   316			gasPrice: toBigInt(transaction.gasPrice ?? '0x0'),
   317		}
   318		const tx = type === undefined ? createLegacyTx(txData, opts) : createTx(txData, opts)
   319		return tx.sign(privateKey)
   320	}
   321	
   322	const putTrie = async (trie, key, value) => {
   323		await trie.put(hexToBytes(keccak256(hexToBytes(key))), value)
   324	}
   325	
   326	const storageRoot = async (storage = {}) => {
   327		const trie = new Trie()
   328		for (const [key, value] of Object.entries(storage)) {
   329			const bytes = hexToMinimalBytes(value)
   330			if (bytes.length > 0) await putTrie(trie, pad32(key), Rlp.encode(bytes))
   331		}
   332		return bytesToHex(await trie.root())
   333	}
   334	
   335	const isEmptyAccount = (account, root, codeHash) =>
   336		BigInt(account.nonce ?? 0n) === 0n &&
   337		BigInt(account.balance ?? 0n) === 0n &&
   338		root === EMPTY_TRIE_ROOT &&
   339		codeHash === EMPTY_CODE_HASH
   340	
   341	const stateRoot = async (state) => {
   342		const trie = new Trie()
   343		for (const [address, account] of Object.entries(state).sort(([a], [b]) => a.localeCompare(b))) {
   344			const root = await storageRoot(account.storage)
   345			const codeHash =
   346				account.deployedBytecode !== undefined ? keccak256(hexToBytes(account.deployedBytecode)) : account.codeHash
   347			if (isEmptyAccount(account, root, codeHash)) continue
   348			const encoded = Rlp.encode([
   349				hexToMinimalBytes(account.nonce),
   350				hexToMinimalBytes(account.balance),
   351				hexToBytes(root),
   352				hexToBytes(codeHash),
   353			])
   354			await putTrie(trie, address, encoded)
   355		}
   356		return bytesToHex(await trie.root())
   357	}
   358	
   359	const logsHash = (logs) => keccak256(Rlp.encode(logs.map((log) => [log[0], log[1], log[2]])))
   360	
   361	const traceCollector = (vm) => {
   362		const trace = { structLogs: [], gas: 0n, returnValue: '0x', failed: false }
   363		const onStep = (step, next) => {
   364			trace.structLogs.push({
   365				pc: step.pc,
   366				op: step.opcode.name,
   367				gasCost: BigInt(step.opcode.fee) + (step.opcode.dynamicFee ?? 0n),
   368				gas: step.gasLeft,
   369				depth: step.depth,
   370				stack: step.stack.map((value) => numberToHex(value)),
   371			})
   372			next?.()
   373		}
   374		const onAfterMessage = (data, next) => {
   375			if (data.execResult.exceptionError && trace.structLogs.length > 0) {
   376				trace.structLogs[trace.structLogs.length - 1].error = String(data.execResult.exceptionError)
   377			}
   378			next?.()
   379		}
   380		vm.evm.events?.on('step', onStep)
   381		vm.evm.events?.on('afterMessage', onAfterMessage)
   382		return {
   383			trace,
   384			detach: () => {
   385				vm.evm.events?.off('step', onStep)
   386				vm.evm.events?.off('afterMessage', onAfterMessage)
   387			},
   388		}
   389	}
   390	
   391	const runVector = async (vector, shouldTrace) => {
   392		const common = makeCommon(vector.hardfork)
   393		const stateManager = createStateManager({ genesisState: makeState(vector.pre), loggingLevel: 'warn' })
   394		await stateManager.ready()
   395		const blockchain = await createChain({ common })
   396		const evm = await createEvm({ common, stateManager, blockchain })
   397		const vm = createVm({ common, evm, stateManager, blockchain, activatePrecompiles: false })
   398		const block = makeBlock(vector.env, common)
   399		const tx = makeTx(vector.transaction, vector.post, common)
   400		const collector = shouldTrace ? traceCollector(vm) : undefined
   401		try {
   402			const runTxResult = await vm.runTx({ tx, block })
   403			if (collector) {
   404				collector.trace.gas = runTxResult.execResult.executionGasUsed
   405				collector.trace.failed = runTxResult.execResult.exceptionError !== undefined
   406				collector.trace.returnValue = bytesToHex(runTxResult.execResult.returnValue)
   407			}
   408			const dumped = await vm.stateManager.dumpCanonicalGenesis()
   409			const actualStateRoot = await stateRoot(dumped)
   410			const actualLogsHash = logsHash(runTxResult.execResult.logs ?? [])
   411			const expectedStateRoot = normalizeDataHex(vector.post.hash)
   412			const expectedLogsHash = normalizeDataHex(vector.post.logs, actualLogsHash)
   413			const failures = []
   414			if (expectedStateRoot !== actualStateRoot) failures.push('stateRoot')
   415			if (expectedLogsHash !== actualLogsHash) failures.push('logs')
   416			return {
   417				id: vector.id,
   418				name: vector.name,
   419				hardfork: vector.hardfork,
   420				status: failures.length === 0 ? 'passed' : 'failed',
   421				failures,
   422				expected: { stateRoot: expectedStateRoot, logs: expectedLogsHash },
   423				actual: { stateRoot: actualStateRoot, logs: actualLogsHash },
   424				gasUsed: runTxResult.totalGasSpent,
   425				trace: collector?.trace,
   426			}
   427		} catch (error) {
   428			return {
   429				id: vector.id,
   430				name: vector.name,
   431				hardfork: vector.hardfork,
   432				status: 'failed',
   433				failures: ['exception'],
   434				error: error instanceof Error ? error.message : String(error),
   435				trace: collector?.trace,
   436			}
   437		} finally {
   438			collector?.detach()
   439			vm.evm.events?.removeAllListeners()
   440		}
   441	}
   442	
   443	const main = async () => {
   444		if (!fixturesPath || !existsSync(fixturesPath)) {
   445			const summary = failedInputSummary(
   446				fixturesPath
   447					? `Configured upstream fixture path does not exist: ${fixturesPath}`
   448					: 'No upstream fixture corpus configured.',
   449			)
   450			if (traceOutFile) writeJson(traceOutFile, { suite, status: summary.status, traces: [] })

