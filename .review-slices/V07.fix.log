   309				const castedTx = tx as EOACodeEIP7702Transaction
   310				const authorizationList = castedTx.authorizationList
   311				for (let i = 0; i < authorizationList.length; i++) {
   312					// Authority tuple validation
   313					const authTuple = authorizationList[i]
   314					if (!authTuple) continue
   315					const authChainId = authTuple[0]
   316					const authChainIdBN = eip7702BytesToBigInt(authChainId)
   317					if (authChainIdBN !== BIGINT_0 && authChainIdBN !== BigInt(vm.common.ethjsCommon.chainId())) {
   318						// Chain id does not match, continue
