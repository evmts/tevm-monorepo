   343					} catch {
   344						// Invalid signature, continue
   345						continue
   346					}
   347	
   348					const accountMaybeUndefined = (await vm.stateManager.getAccount(authority)) as EthjsAccount | undefined
   349					const accountExists = accountMaybeUndefined !== undefined
   350					const account = accountMaybeUndefined ?? new EthjsAccount()
   351	
   352					// Add authority address to warm addresses
   353					vm.evm.journal.addAlwaysWarmAddress(authority.toString())
   354	
