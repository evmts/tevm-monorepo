    83				await assignWithdrawals(vm)(block)
    84				if (opts.reportPreimages === true && vm.evm.journal.preimages !== undefined) {
    85					for (const [key, preimage] of vm.evm.journal.preimages) {
    86						blockResults.preimages.set(key, preimage)
    87					}
    88				}
    89				await vm.evm.journal.cleanup()
    90			}
    91			// Pay ommers and miners
    92			if (block.common.ethjsCommon.consensusType() === ConsensusType.ProofOfWork) {
    93				await assignBlockRewards(vm)(block)
    94			}
    95	
    96			return blockResults as any
    97		}

