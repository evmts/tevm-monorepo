		? Extract<DerivedRpcSchema<TRpcSchema, TRpcSchemaOverride>[number], { Method: TParameters['method'] }>['ReturnType']
		: unknown,
>(
	args: TParameters,
	options?: EIP1193RequestOptions,
) => Promise<_ReturnType>

