   335			cacheTime: 0,
   336			...normalizedOptions,
   337			transport: createTevmTransport({
   338				...normalizedOptions,
   339				...(common !== undefined ? { common } : {}),
   340			}),
   341			type: 'tevm',
   342			...(common !== undefined ? { chain: common } : {}),
   343		})
