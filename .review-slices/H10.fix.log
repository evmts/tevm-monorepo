   302	export const createMemoryClient = (options) => {
   303		const miningConfig = (() => {
   304			if (options?.miningConfig !== undefined) {
   305				return options.miningConfig
   306			}
   307			const mining = options?.mining
   308			if (mining === undefined) {
   309				return undefined
   310			}
   311			if (typeof mining.interval === 'number') {
   312				return { type: 'interval', blockTime: mining.interval / 1000 }
   313			}
   314			if (typeof mining.auto === 'boolean') {
   315				return { type: mining.auto ? 'auto' : 'manual' }
   316			}
   317			return undefined
   318		})()
