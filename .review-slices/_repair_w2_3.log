		} catch (_e) {
			block = undefined
		}
		if (!block) {
			return {
				...(request.id !== undefined ? { id: request.id } : {}),
				method: request.method,
				jsonrpc: request.jsonrpc,
				result: null,
			}
		}
		const txIndex = hexToNumber(request.params[1])
		const tx = block.transactions[txIndex]
