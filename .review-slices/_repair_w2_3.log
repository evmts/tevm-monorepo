export const anvilDropTransactionJsonRpcProcedure = (client) => {
	return async (request) => {
		const anvilDropTransactionRequest =
			/** @type {import('./AnvilJsonRpcRequest.js').AnvilDropTransactionJsonRpcRequest}*/
			(request)
