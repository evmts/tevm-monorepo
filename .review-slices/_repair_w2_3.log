									: {}),
							...('maxPriorityFeePerGas' in tx ? { maxPriorityFeePerGas: tx.maxPriorityFeePerGas } : {}),
						},
						{
							freeze: false,
							common: vmClone.common.ethjsCommon,
							allowUnlimitedInitCodeSize: true,
						},
					),
				})
			}

