    23		 * Snapshots are placed in __rpc_snapshots__/ subdirectory next to test files (vitest/bun mode)
    24		 * or at custom location (function mode)
    25		 */
    26		private resolveSnapshotPath(resolver?: TestOptions['resolveSnapshotPath']): string {
    27			if (resolver === 'vitest') {
    28				return resolveVitestTestSnapshotPath()
    29			} else if (resolver === 'bun') {
    30				return resolveBunTestSnapshotPath()
    31			} else if (typeof resolver === 'function') {
    32				return resolver()
    33			}
