    35		...(tx.gasPrice ? [normalizeHex(tx.gasPrice)] : []),
    36		...(tx.maxFeePerBlobGas ? [normalizeHex(tx.maxFeePerBlobGas)] : []),
    37		...(tx.maxFeePerGas ? [normalizeHex(tx.maxFeePerGas)] : []),
    38		...(tx.maxPriorityFeePerGas ? [normalizeHex(tx.maxPriorityFeePerGas)] : []),
    39		...(tx.nonce ? [normalizeHex(tx.nonce)] : []),
    40		...(tx.sidecars?.map((sidecar) => Object.values(sidecar).map(normalizeHex)) ?? []),
