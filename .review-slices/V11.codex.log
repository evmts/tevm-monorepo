     2	
     3	/**
     4	 * Resolves snapshot file path from Bun test context using import.meta
     5	 * @returns {string} snapshotPath - Full path to snapshot: testDir/__rpc_snapshots__/testFile.snap.json
     6	 * @throws {Error} If not running in Bun test context (import.meta properties unavailable)
     7	 * @example
     8	 * ```typescript
     9	 * const snapshotPath = resolveBunTestSnapshotPath()
    10	 * // Returns: '/path/to/tests/__rpc_snapshots__/myTest.test.ts.snap.json'
    11	 * ```
    12	 */
    13	export const resolveBunTestSnapshotPath = (): string => {
    14		const bunNotAvailableError = new Error(
    15			'Test file path not available. If `resolveSnapshotPath: "bun"` is used, you should be running in a bun test context.',
    16		)
    17		if (!globalThis.Bun || typeof globalThis.Bun === 'undefined') {
    18			throw bunNotAvailableError
    19		}
    20	
    21		const testPath = globalThis.Bun.main
    22		const testDir = testPath.substring(0, testPath.lastIndexOf('/'))
    23		const testFile = testPath.split('/').pop()
    24		if (!testFile) throw bunNotAvailableError
    25	
    26		return join(testDir, '__rpc_snapshots__', `${testFile}.snap.json`)
    27	}

