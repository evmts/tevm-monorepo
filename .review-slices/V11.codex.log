     4	/**
     5	 * Resolves snapshot file path from vitest test context
     6	 * @returns {string} snapshotPath - Full path to snapshot: testDir/__rpc_snapshots__/testFile.snap.json
     7	 * @throws {Error} If not running in vitest context
     8	 */
     9	export const resolveVitestTestSnapshotPath = (): string => {
    10		const vitestNotAvailableError = new Error(
    11			'Test file path not available. If `resolveSnapshotPath: "vitest"` is used, you should be running in a vitest test context.',
    12		)
    13		if (typeof expect.getState !== 'function') throw vitestNotAvailableError
    14		const testPath = expect.getState().testPath
    15		if (!testPath) throw vitestNotAvailableError
    16	
    17		return join(dirname(testPath), '__rpc_snapshots__', `${basename(testPath)}.snap.json`)
    18	}
