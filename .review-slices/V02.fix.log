    41	export const ethSubscribeHandler = (tevmNode) => {
    42		return async (params) => {
    43			const { subscriptionType } = params
    44			const id = generateRandomId()
    45	
    46			tevmNode.logger.debug({ subscriptionType, id }, 'ethSubscribeHandler: Creating subscription')
    47	
    48			switch (subscriptionType) {
    49				case 'newHeads': {
    50					/**
    51					 * @param {import('@tevm/block').Block} block
    52					 */
    53					const listener = (block) => {
    54						const filter = tevmNode.getFilters().get(id)
    55						if (!filter) {
    56							tevmNode.logger.debug({ id }, 'ethSubscribeHandler: Filter not found for newHeads')
    57							return
    58						}
    59						filter.blocks.push(block)
    60						tevmNode.logger.debug(
    61							{ id, blockNumber: block.header.number },
    62							'ethSubscribeHandler: Added block to subscription',
    63						)
    64					}
    65	
    66					tevmNode.on('newBlock', listener)
    67					tevmNode.setFilter({
    68						id,
    69						type: 'Block',
    70						created: Date.now(),
    71						logs: [],
    72						tx: [],
    73						blocks: [],
    74						installed: {},
    75						err: undefined,
    76						registeredListeners: [listener],
    77					})
    78	
    79					tevmNode.logger.debug({ id }, 'ethSubscribeHandler: Created newHeads subscription')
    80					return id
    81				}
    82	
    83				case 'logs': {
    84					const logsParams = /** @type {import('./EthSubscribeParams.js').EthSubscribeLogsParams} */ (params)
    85					const { filterParams } = logsParams
    86	
    87					/**
    88					 * The newLog event emits raw EthjsLog which is a tuple: [address, topics, data]
    89					 * @param {import('@tevm/utils').EthjsLog} rawLog
    90					 */
    91					const listener = (rawLog) => {
    92						const filter = tevmNode.getFilters().get(id)
    93						if (!filter) {
    94							tevmNode.logger.debug({ id }, 'ethSubscribeHandler: Filter not found for logs')
    95							return
    96						}
    97	
    98						// EthjsLog is a tuple [address, topics, data]
    99						const [addressBytes, topicsBytes, dataBytes] = rawLog
   100						const logAddress = bytesToHex(addressBytes)
   101						const logTopics = topicsBytes.map((t) => bytesToHex(t))
   102	
   103						// Apply address filter if specified
   104						if (filterParams?.address) {
   105							const addresses = isArray(filterParams.address) ? filterParams.address : [filterParams.address]
   106							const normalizedAddresses = addresses.map((addr) => addr.toLowerCase())
   107							if (!normalizedAddresses.includes(logAddress.toLowerCase())) {
   108								return
   109							}
   110						}
   111	
   112						// Apply topics filter if specified
   113						if (filterParams?.topics) {
   114							const topicsMatch = filterParams.topics.every((topicFilter, index) => {
   115								if (topicFilter === null || topicFilter === undefined) {
   116									return true
   117								}
   118								if (!logTopics[index]) {
   119									return false
   120								}
   121								if (isArray(topicFilter)) {
   122									return topicFilter.some((topic) => topic.toLowerCase() === logTopics[index]?.toLowerCase())
   123								}
   124								return topicFilter.toLowerCase() === logTopics[index]?.toLowerCase()
   125							})
   126							if (!topicsMatch) {
   127								return
   128							}
   129						}
   130	
   131						// Convert raw log to the expected format for Filter['logs']
   132						/** @type {import('@tevm/node').FilterLog} */
   133						const formattedLog = {
   134							address: logAddress,
   135							topics: /** @type {[import('@tevm/utils').Hex, ...Array<import('@tevm/utils').Hex>]} */ (logTopics),
   136							data: bytesToHex(dataBytes),
   137							// Note: These fields are not available from the raw log event
   138							// They should be populated when the log is retrieved via eth_getFilterChanges
   139							blockNumber: 0n,
   140							transactionHash: '0x',
   141							logIndex: 0n,
   142							blockHash: '0x',
   143							transactionIndex: 0n,
   144							removed: false,
   145						}
   146	
   147						filter.logs.push(formattedLog)
   148						tevmNode.logger.debug({ id, logAddress, topics: logTopics }, 'ethSubscribeHandler: Added log to subscription')
   149					}
   150	
   151					tevmNode.on('newLog', listener)
   152					tevmNode.setFilter({
   153						id,
   154						type: 'Log',
   155						created: Date.now(),
   156						logs: [],
   157						tx: [],
   158						blocks: [],
   159						logsCriteria: filterParams,
   160						installed: {},
   161						err: undefined,
   162						registeredListeners: [listener],
   163					})
   164	
   165					tevmNode.logger.debug({ id, filterParams }, 'ethSubscribeHandler: Created logs subscription')
   166					return id
   167				}
   168	
   169				case 'newPendingTransactions': {
   170					/**
   171					 * @param {import('@evmts/zevm/tx').TypedTransaction | import('@evmts/zevm/tx').ImpersonatedTx} tx
   172					 */
   173					const listener = (tx) => {
   174						const filter = tevmNode.getFilters().get(id)
   175						if (!filter) {
   176							tevmNode.logger.debug({ id }, 'ethSubscribeHandler: Filter not found for newPendingTransactions')
   177							return
   178						}
   179						filter.tx.push(tx)
   180						tevmNode.logger.debug({ id, txHash: tx.hash() }, 'ethSubscribeHandler: Added tx to subscription')
   181					}
   182	
   183					tevmNode.on('newPendingTransaction', listener)
   184					tevmNode.setFilter({
   185						id,
   186						type: 'PendingTransaction',
   187						created: Date.now(),
   188						logs: [],
   189						tx: [],
   190						blocks: [],
   191						installed: {},
   192						err: undefined,
   193						registeredListeners: [listener],
   194					})
   195	
   196					tevmNode.logger.debug({ id }, 'ethSubscribeHandler: Created newPendingTransactions subscription')
   197					return id
   198				}
   199	
   200				case 'syncing': {
   201					// Syncing subscriptions return sync status changes
   202					// For now, we create a subscription but don't emit events for it
   203					// since Tevm's syncing behavior is different from a full node
   204					tevmNode.setFilter({
   205						id,
   206						type: 'Block', // Use Block type as a placeholder
   207						created: Date.now(),
   208						logs: [],
   209						tx: [],
   210						blocks: [],
   211						installed: {},
   212						err: undefined,
   213						registeredListeners: [],
   214					})
   215	
   216					tevmNode.logger.debug({ id }, 'ethSubscribeHandler: Created syncing subscription (no-op)')
   217					return id
   218				}
   219	
   220				default: {
   221					const err = new InvalidParamsError(
   222						`Invalid subscription type: ${/** @type {any} */ (params).subscriptionType}. Valid types are: newHeads, logs, newPendingTransactions, syncing`,
   223					)
