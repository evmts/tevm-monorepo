    13	 * import { mainnet } from 'tevm/common'
    14	 * import { createStateManager } from 'tevm/state'
    15	 * import { createBlockchain } from 'tevm/blockchain'}
    16	 * import { EthjsAddress } from 'tevm/utils'
    17	 *
    18	 * const evm = createEvm({
    19	 *   common: mainnet.copy(),
    20	 *   stateManager: createStateManager(),
    21	 *   blockchain: createBlockchain(),
    22	 * })
    23	 * ```
    24	 * @see [createEvm](https://tevm.sh/reference/tevm/evm/functions/createevm/)
    25	 */
    26	export class Evm extends EVM {
    27		/**
    28		 * Adds a custom precompile to the EVM.
    29		 * @param {import('./CustomPrecompile.js').CustomPrecompile} precompile
    30		 * @throws {MisconfiguredClientError}
    31		 */
    32		addCustomPrecompile(precompile) {
    33			if (this._customPrecompiles === undefined) {
    34				throw new MisconfiguredClientError(
    35					'Custom precompiles is empty. This is an internal bug as it should always be defined',
    36				)
    37			}
    38			const address = precompileAddress(precompile)
    39			const index = this._customPrecompiles.findIndex((item) => precompileAddress(item) === address)
    40			if (index === -1) {
    41				this._customPrecompiles.push(precompile)
    42			} else {
    43				this._customPrecompiles[index] = precompile
    44			}
    45			this._precompiles = getActivePrecompiles(this.common, this._customPrecompiles)
    46		}
    47	
    48		/**
    49		 * Removes a custom precompile from the EVM.
    50		 * @param {import('./CustomPrecompile.js').CustomPrecompile} precompile
    51		 * @throws {MisconfiguredClientError}
    52		 * @throws {InvalidParamsError}
    53		 */
    54		removeCustomPrecompile(precompile) {
    55			if (this._customPrecompiles === undefined) {
    56				throw new MisconfiguredClientError(
    57					'Custom precompiles is empty. This is an internal bug as it should always be defined',
    58				)
    59			}
    60			const address = precompileAddress(precompile)
    61			const index = this._customPrecompiles.findIndex((item) => precompileAddress(item) === address)
    62			if (index === -1) {
    63				throw new InvalidParamsError('Precompile not found')
    64			}
    65			this._customPrecompiles.splice(index, 1)
