     1	/**
     2	 * Reads Solidity compilation artifacts from the cache asynchronously.
     3	 * This function checks if cached artifacts exist and if they satisfy the requested
     4	 * AST and bytecode inclusion requirements.
     5	 *
     6	 * @param {import('@tevm/compiler').Logger} logger - Logger for error reporting
     7	 * @param {import('@tevm/bundler-cache').Cache} cache - Cache instance to read from
     8	 * @param {string} modulePath - Path to the Solidity module
     9	 * @param {boolean} includeAst - Whether to include AST in the result
    10	 * @param {boolean} includeBytecode - Whether to include bytecode in the result
    11	 * @returns {ReturnType<import('@tevm/bundler-cache').Cache['readArtifacts']>} - The cached artifacts if found and valid, otherwise undefined
    12	 * @throws {Error} - Doesn't throw, but logs errors and returns undefined on failure
    13	 *
    14	 * @example
    15	 * ```javascript
    16	 * import { readCache } from '@tevm/base-bundler'
    17	 * import { createCache } from '@tevm/bundler-cache'
    18	 *
    19	 * const cache = createCache()
    20	 * const logger = console
    21	 *
    22	 * // Read artifacts for Counter.sol
    23	 * const artifacts = await readCache(
    24	 *   logger,
    25	 *   cache,
    26	 *   './contracts/Counter.sol',
    27	 *   true, // include AST
    28	 *   true  // include bytecode
    29	 * )
    30	 *
    31	 * if (artifacts) {
    32	 *   console.log('Cache hit! Using cached artifacts')
    33	 * } else {
    34	 *   console.log('Cache miss. Need to recompile')
    35	 * }
    36	 * ```
    37	 */
    38	export const readCache = async (logger, cache, modulePath, includeAst, includeBytecode) => {
    39		try {
    40			const cachedArtifacts = await cache.readArtifacts(modulePath)
    41	
    42			const isCachedAsts = () => cachedArtifacts?.asts && Object.keys(cachedArtifacts.asts).length > 0
    43			const isCachedBytecode = () =>
    44				Object.values(cachedArtifacts?.artifacts ?? {}).some((artifact) => artifact.evm.deployedBytecode)
    45	
    46			if (!cachedArtifacts) {
    47				return undefined
    48			}
    49			if (includeAst && !isCachedAsts()) {
    50				return undefined
    51			}
    52			if (includeBytecode && !isCachedBytecode()) {
    53				return undefined
    54			}
    55			return cachedArtifacts
    56		} catch (e) {
    57			logger.error(
    58				`there was an error in tevm plugin reading cache for ${modulePath}. Continuing without cache. This may hurt performance`,
    59			)
    60			logger.error(/** @type any */ (e))
    61			return undefined
    62		}
    63	}
     1	/**
     2	 * Writes compilation artifacts and generated code to the cache asynchronously.
     3	 * This function can selectively write artifacts based on the provided flag,
     4	 * and it also writes the generated TypeScript or JavaScript code to the
     5	 * appropriate cache location based on the module type.
     6	 *
     7	 * @param {import('./types.js').Logger} logger - Logger for warning and error reporting
     8	 * @param {import('@tevm/bundler-cache').Cache} cache - Cache instance to write to
     9	 * @param {import('@tevm/compiler').ResolvedArtifacts} artifacts - The compilation artifacts to cache
    10	 * @param {string} code - The generated code content
    11	 * @param {string} modulePath - Path to the Solidity module
    12	 * @param {string} moduleType - Type of module to generate ('dts', 'mjs', 'cjs', 'ts')
    13	 * @param {boolean} writeArtifacts - Whether to write compilation artifacts to cache
    14	 *   This is typically set to false if there was a compilation error, but we still
    15	 *   want to cache error messages in the generated files.
    16	 * @returns {Promise<void>} - A promise that resolves when writing is complete
    17	 * @throws {Error} - Doesn't directly throw, but logs warnings for unsupported module types
    18	 *
    19	 * @example
    20	 * ```javascript
    21	 * import { writeCache } from '@tevm/base-bundler'
    22	 * import { createCache } from '@tevm/bundler-cache'
    23	 *
    24	 * const cache = createCache()
    25	 * const logger = console
    26	 *
    27	 * // After compilation, write results to cache
    28	 * await writeCache(
    29	 *   logger,
    30	 *   cache,
    31	 *   compilationResult, // artifacts from solc compilation
    32	 *   generatedTypeScript, // the generated code
    33	 *   './contracts/Counter.sol',
    34	 *   'dts', // writing .d.ts file
    35	 *   true // write artifacts too
    36	 * )
    37	 * ```
    38	 */
    39	export const writeCache = async (
    40		logger,
    41		cache,
    42		artifacts,
    43		code,
    44		modulePath,
    45		moduleType,
    46		// This is kinda quick and dirty but works for now
    47		// we will skip writing artifacts if there is an error
    48		// but still write dts and mjs files since they always
    49		// fall back to generating an empty file with error messages
    50		writeArtifacts,
    51	) => {
    52		/**
    53		 * @type {Array<Promise<any>>}
    54		 */
    55		const promises = []
    56		if (writeArtifacts) {
    57			promises.push(cache.writeArtifacts(modulePath, artifacts))
    58		}
    59		if (moduleType === 'dts') {
    60			promises.push(cache.writeDts(modulePath, code))
    61		} else if (moduleType === 'mjs') {
    62			promises.push(cache.writeMjs(modulePath, code))
    63		} else {
    64			logger.warn(`No caching for module type ${moduleType}} implemented yet`)
    65		}
    66		await Promise.all(promises)
    67	}

