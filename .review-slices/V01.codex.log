    34				prefetchPromises.push(
    35					stateManager.getStorage(addressObj, keyBytes).catch((error) => {
    36						client.logger.debug(
    37							{
    38								error,
    39								address: address.startsWith('0x') ? address : `0x${address}`,
    40								storageKey: storageKey.startsWith('0x') ? storageKey : `0x${storageKey}`,
    41							},
    42							'Error prefetching storage slot from access list',
    43						)
    44					}),
    45				)
    46			}
    47		}
    48	
    49		// Wait for all prefetch operations to complete
    50		await Promise.all(prefetchPromises)
    51	
    52		client.logger.debug(
    53			{ accessListSize: accessList.size, totalStorageSlotsPreloaded: prefetchPromises.length },
    54			'Prefetched storage slots from access list',
