    10	 * @param {Map<string, Set<string>> | undefined} accessList
    11	 * @returns {Promise<void>}
    12	 */
    13	export const prefetchStorageFromAccessList = async (client, accessList) => {
    14		if (!accessList || accessList.size === 0) return
    15	
    16		const vm = await client.getVm()
    17		const stateManager = vm.stateManager
    18	
    19		// Prefetch all storage slots in parallel
    20		const prefetchPromises = []
    21	
    22		for (const [address, storageKeys] of accessList.entries()) {
    23			if (storageKeys.size === 0) continue
    24	
    25			// Create address object once per address
    26			const addressObj = createAddress(address.startsWith('0x') ? address : `0x${address}`)
    27	
    28			for (const storageKey of storageKeys) {
    29				// Convert storage key to bytes with proper padding to 32 bytes
    30				const hexKey = /** @type {`0x${string}`} */ (storageKey.startsWith('0x') ? storageKey : `0x${storageKey}`)
    31				const keyBytes = hexToBytes(hexKey, { size: 32 })
    32	
