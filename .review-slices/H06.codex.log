     6	
     7	/**
     8	 * Generates an {@link Address} for a contract deployed using the standard CREATE opcode.
     9	 *
    10	 * In Ethereum, contract addresses are deterministically generated based on the deployer's
    11	 * address and their current nonce. This function implements that calculation, following
    12	 * the formula:
    13	 *
    14	 * `address = keccak256(rlp([sender_address, sender_nonce]))[12:]`
    15	 *
    16	 * Where:
    17	 * - rlp is the RLP encoding function
    18	 * - keccak256 is the hash function
    19	 * - [12:] means taking the last 20 bytes of the 32-byte hash
    20	 *
    21	 * This is useful for:
    22	 * - Predicting contract addresses before deployment
    23	 * - Generating contract addresses in test environments
    24	 * - Verifying contract deployment addresses
    25	 *
    26	 * @param {EthjsAddress} from - The address of the account deploying the contract
    27	 * @param {bigint} nonce - The nonce of the deploying account at the time of deployment
    28	 * @returns {Address} The contract address that will be (or was) generated
    29	 * @throws {InvalidAddressError} If the 'from' parameter is not a valid EthjsAddress
    30	 *
    31	 * @example
    32	 * ```javascript
    33	 * import { createAddress, createContractAddress } from '@tevm/address'
    34	 *
    35	 * // Predict a contract's address before deployment
    36	 * const deployerAddress = createAddress('0x8ba1f109551bD432803012645Ac136ddd64DBA72')
    37	 * const deployerNonce = 5n // Current nonce of the deployer
    38	 *
    39	 * const predictedAddress = createContractAddress(deployerAddress, deployerNonce)
    40	 * console.log('Contract will be deployed at:', predictedAddress.toString())
    41	 *
    42	 * // Using with a zero nonce (first deployment from an account)
    43	 * const firstContractAddress = createContractAddress(deployerAddress, 0n)
    44	 * ```
    45	 *
    46	 * @example
    47	 * ```javascript
    48	 * // Example of calculating multiple contract addresses in sequence
    49	 * import { createAddress, createContractAddress } from '@tevm/address'
    50	 *
    51	 * const deployerAddress = createAddress('0x8ba1f109551bD432803012645Ac136ddd64DBA72')
    52	 * const startingNonce = 10n
    53	 *
    54	 * // Calculate addresses for a series of contracts to be deployed
    55	 * const contractAddresses = []
    56	 * for (let i = 0; i < 5; i++) {
    57	 *   const nonce = startingNonce + BigInt(i)
    58	 *   contractAddresses.push(
    59	 *     createContractAddress(deployerAddress, nonce).toString()
    60	 *   )
    61	 * }
    62	 *
    63	 * console.log('Upcoming contract addresses:', contractAddresses)
    64	 * ```
    65	 *
    66	 * @see {@link https://ethereum.org/en/developers/docs/smart-contracts/deploying/#contract-creation-code|Ethereum Contract Creation}
    67	 * @see {@link https://eips.ethereum.org/EIPS/eip-161|EIP-161: State trie clearing} for nonce rules
    68	 */
    69	export const createContractAddress = (from, nonce) => {
    70		if (!(from.bytes instanceof Uint8Array)) {
    71			throw new InvalidAddressError('Expected from to be an Address or ethereumjs Address')
    72		}
    73		if (nonce === 0n) {
    74			return createAddress(keccak256(toRlp([from.bytes, Uint8Array.from([])]), 'bytes').subarray(-20))
    75		}
    76		return createAddress(keccak256(toRlp([from.bytes, numberToBytes(nonce)]), 'bytes').subarray(-20))
    77	}

