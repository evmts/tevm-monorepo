     6	/**
     7	 * Creates an {@link Address} instance from various input formats for safely
     8	 * interacting with Ethereum addresses.
     9	 *
    10	 * This factory function provides a flexible and robust way to create Address
    11	 * objects, handling multiple input formats:
    12	 *
    13	 * - Hex strings (with or without 0x prefix)
    14	 * - Numbers or BigInts (converted to bytes)
    15	 * - Uint8Array (raw bytes)
    16	 * - Existing EthjsAddress or Address instances
    17	 *
    18	 * The created Address objects provide convenience methods and proper EIP-55
    19	 * checksumming for improved safety when working with Ethereum addresses.
    20	 *
    21	 * This is the recommended way to create Address instances throughout TEVM.
    22	 *
    23	 * @param {import("@tevm/utils").AddressLike | number | bigint | string} address - The input to create an address from
    24	 * @returns {Address} An Address instance representing the input
    25	 * @throws {InvalidAddressError} If the input is not a valid address or cannot be converted to one
    26	 *
    27	 * @example
    28	 * ```javascript
    29	 * import { createAddress } from '@tevm/address'
    30	 *
    31	 * // From checksummed or lowercase hex strings (with 0x prefix)
    32	 * const addr1 = createAddress('0x8ba1f109551bD432803012645Ac136ddd64DBA72')
    33	 * const addr2 = createAddress('0x8ba1f109551bd432803012645ac136ddd64dba72')
    34	 *
    35	 * // From unprefixed hex string
    36	 * const addr3 = createAddress('8ba1f109551bd432803012645ac136ddd64dba72')
    37	 *
    38	 * // From zero address
    39	 * const zeroAddr = createAddress(`0x${'00'.repeat(20)}`)
    40	 * console.log(zeroAddr.toString()) // '0x0000000000000000000000000000000000000000'
    41	 *
    42	 * // From numbers (not recommended for real addresses due to potential overflow)
    43	 * const numAddr = createAddress(1) // Convert 1 to address '0x0000000000000000000000000000000000000001'
    44	 *
    45	 * // From bigint (useful for sequential address generation)
    46	 * const bigintAddr = createAddress(42n) // '0x000000000000000000000000000000000000002A'
    47	 *
    48	 * // From bytes
    49	 * const bytesAddr = createAddress(new Uint8Array(20).fill(1))
    50	 * // '0x0101010101010101010101010101010101010101'
    51	 * ```
    52	 *
    53	 * @example
    54	 * ```javascript
    55	 * // Error handling example
    56	 * import { createAddress } from '@tevm/address'
    57	 * import { InvalidAddressError } from '@tevm/errors'
    58	 *
    59	 * try {
    60	 *   // Invalid address (too short)
    61	 *   const address = createAddress('0x123')
    62	 * } catch (error) {
    63	 *   if (error instanceof InvalidAddressError) {
    64	 *     console.error('Invalid address format:', error.message)
    65	 *   } else {
    66	 *     throw error
    67	 *   }
    68	 * }
    69	 * ```
    70	 */
    71	export const createAddress = (address) => {
    72		try {
    73			if (address instanceof EthjsAddress) {
    74				return new Address(address.bytes)
    75			}
    76			if (address instanceof Uint8Array) {
    77				return new Address(address)
    78			}
    79			if (typeof address === 'number' || typeof address === 'bigint') {
    80				return new Address(numberToBytes(address, { size: 20 }))
    81			}
    82			if (typeof address === 'string' && address.startsWith('0x')) {
    83				return new Address(hexToBytes(/** @type {import('viem').Hex}*/ (address), { size: 20 }))
    84			}
    85			if (typeof address === 'string') {
    86				return new Address(hexToBytes(`0x${address}`, { size: 20 }))
    87			}
    88			throw new UnreachableCodeError(address, `Received an unexpected input for createAddress ${address}`)
    89		} catch (e) {
    90			if (e instanceof UnreachableCodeError) {
    91				throw new InvalidAddressError(
    92					'Received an invalid address input type for createAddress. Valid input types include hex string, unprefixed hex, bytes, number, bigint, or EthjsAddress',
    93					{ cause: e },
    94				)
    95			}
    96			throw new InvalidAddressError(`Received an invalid address input: ${/** @type {Error} */ (e).message}`, {
    97				cause: /** @type {Error} */ (e),
    98			})
    99		}
   100	}

