		// because of optimism tx we need to set block hash twice
		if (jsonRpcBlock.hash) {
			baseChain.blocks.set(jsonRpcBlock.hash, block)
		}
		return block
	}
	if (!block) {
		throw new UnknownBlockError(blockId)
	}
	return block
}

