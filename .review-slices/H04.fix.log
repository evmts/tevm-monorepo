		for (let i = 0; i < logs.length; i++) {
			const log = logs[i]
			if (!log) {
				throw new Error('Log is empty')
			}
			// add the address
			bloom.add(log[0])
			// add the topics
			const topics = log[1]
			for (let q = 0; q < topics.length; q++) {
				bloom.add(topics[q] as Uint8Array)
			}
		}
		return bloom
	}
