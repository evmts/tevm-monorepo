    35	/// Read a module (or use provided code), resolve its imports, insert into `ctx.graph`,
    36	/// and return the list of child imports.
    37	pub async fn process_module(
    38	    path: &PathBuf,
    39	    code_opt: Option<String>,
    40	    cfg: &Config,
    41	    state: State,
    42	    _permit: OwnedSemaphorePermit,
    43	) -> Result<String, Vec<ResolveImportsError>> {
    44	    let id = path.to_string_lossy().to_string();
    45	    let mut seen = state.seen.lock().await;
    46	    if !seen.insert(id.clone()) {
    47	        return Ok(id);
    48	    };
    49	    drop(seen);
    50	    let code = if let Some(c) = code_opt {
    51	        c
    52	    } else {
    53	        fs::read_to_string(&path)
    54	            .await
    55	            .map_err(|err| vec![ResolveImportsError::ReadError {
    56	                context_path: path.clone(),
    57	                message: err.to_string(),
    58	            }])?
    59	    };
    60	
    61	    let resolved_imports = resolve_imports_detailed(&path, &code, cfg)?;
    62	    let imported_ids = resolved_imports
    63	        .iter()
    64	        .map(|import| PathBuf::from(&import.absolute))
    65	        .collect();
    66	    let rewritten_code = rewrite_imports(&code, &resolved_imports);
    67	
    68	    state.graph.lock().await.insert(
    69	        path.to_string_lossy().into_owned(),
    70	        ModuleInfo {
    71	            code: rewritten_code,
    72	            raw_code: code,
    73	            imported_ids,
    74	        },
    75	    );
    76	    Ok(id)
    77	}

