    11	fn rewrite_imports(code: &str, imports: &[ResolvedImport]) -> String {
    12	    let mut rewritten = code.to_string();
    13	
    14	    for import in imports {
    15	        let escaped_original = regex::escape(&import.original);
    16	        let patterns = [
    17	            format!(r#"(import\s+["']){}(["'])"#, escaped_original),
    18	            format!(r#"(import\s+[^;]*?\s+from\s+["']){}(["'])"#, escaped_original),
    19	        ];
    20	
    21	        for pattern in patterns {
    22	            if let Ok(re) = Regex::new(&pattern) {
    23	                rewritten = re
    24	                    .replace_all(&rewritten, |caps: &regex::Captures| {
    25	                        format!("{}{}{}", &caps[1], import.updated, &caps[2])
    26	                    })
    27	                    .into_owned();
    28	            }
    29	        }
    30	    }
    31	
    32	    rewritten
    33	}
