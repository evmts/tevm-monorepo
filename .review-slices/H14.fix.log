+        .as_ref()
+        .and_then(|evm| evm.bytecode.as_ref())
+        .and_then(|bytecode| bytecode.object.as_bytes())
+        .cloned()
+}
+
+fn contract_deployed_bytecode(contract: &Contract) -> Option<Bytes> {
+    contract
