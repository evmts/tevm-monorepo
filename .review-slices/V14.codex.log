     1	/**
     2	 * A tree-shakeable version of the `tevmReady` action for viem.
     3	 * Waits for TEVM initialization to complete, which is especially important when forking.
     4	 *
     5	 * This function ensures that the TEVM instance is fully initialized and ready for operations.
     6	 * It resolves to `true` when initialization is complete, and throws an error if initialization fails.
     7	 *
     8	 * The initialization process handles:
     9	 *
    10	 * - Setting up the EVM execution environment
    11	 * - Initializing blockchain state and storage structures
    12	 * - **For forked instances**: Establishing connection to the remote network and loading initial state
    13	 * - Setting up transaction pool and receipt management systems
    14	 * - Loading any persisted state (when using a persister)
    15	 * - Configuring mining modes and other operational parameters
    16	 *
    17	 * **When to use this function:**
    18	 *
    19	 * While all TEVM actions implicitly wait for initialization to complete, explicitly calling
    20	 * `tevmReady()` is recommended in these scenarios:
    21	 *
    22	 * - **Forking environments**: To ensure network connection is established before proceeding
    23	 * - **UI applications**: To show loading indicators during initialization
    24	 * - **Testing**: To separate initialization time from operation time in benchmarks
    25	 * - **Error handling**: To catch initialization failures early with proper error handling
    26	 * - **Complex scripts**: To ensure initialization is complete before proceeding with multiple operations
    27	 *
    28	 * @param {import('viem').Client<import('./TevmTransport.js').TevmTransport<string>>} client - The viem client configured with TEVM transport.
    29	 * @returns {Promise<true>} Resolves to `true` when ready, rejects if initialization fails.
    30	 * @throws {Error} If initialization fails, with details about the specific failure.
    31	 *
    32	 * @example
    33	 * ```typescript
    34	 * import { createMemoryClient, http } from 'tevm'
    35	 * import { optimism } from 'tevm/common'
    36	 *
    37	 * async function main() {
    38	 *   // Create a client that forks from Optimism mainnet
    39	 *   const client = createMemoryClient({
    40	 *     fork: {
    41	 *       transport: http('https://mainnet.optimism.io')({})
    42	 *     },
    43	 *     common: optimism,
    44	 *   })
    45	 *
    46	 *   try {
    47	 *     // Show loading indicator in UI
    48	 *     showLoadingIndicator('Connecting to Optimism...')
    49	 *
    50	 *     // Wait for fork to initialize
    51	 *     await client.tevmReady()
    52	 *
    53	 *     // Hide loading indicator
    54	 *     hideLoadingIndicator()
    55	 *
    56	 *     // Now it's safe to interact with the forked network
    57	 *     const blockNumber = await client.getBlockNumber()
    58	 *     console.log(`Connected to Optimism block ${blockNumber}`)
    59	 *
    60	 *     // Continue with application logic...
    61	 *   } catch (error) {
    62	 *     // Handle initialization errors gracefully
    63	 *     showErrorMessage(`Failed to connect: ${error.message}`)
    64	 *     console.error('TEVM initialization error:', error)
    65	 *   }
    66	 * }
    67	 * ```
    68	 *
    69	 * @example
    70	 * ```typescript
    71	 * // Using with promise.race() for timeout handling
    72	 * import { createMemoryClient, http } from 'tevm'
    73	 *
    74	 * async function initWithTimeout() {
    75	 *   const client = createMemoryClient({
    76	 *     fork: {
    77	 *       transport: http('https://mainnet.ethereum.org')({})
    78	 *     }
    79	 *   })
    80	 *
    81	 *   // Create a timeout promise
    82	 *   const timeout = new Promise((_, reject) => {
    83	 *     setTimeout(() => reject(new Error('Fork initialization timed out')), 30000)
    84	 *   })
    85	 *
    86	 *   try {
    87	 *     // Race initialization against timeout
    88	 *     await Promise.race([
    89	 *       client.tevmReady(),
    90	 *       timeout
    91	 *     ])
    92	 *
    93	 *     console.log('TEVM initialized successfully')
    94	 *     return client
    95	 *   } catch (error) {
    96	 *     console.error('Initialization failed:', error)
    97	 *     throw error
    98	 *   }
    99	 * }
   100	 * ```

