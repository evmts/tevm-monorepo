     3	/**
     4	 * A viem extension that adds TEVM actions to a viem client.
     5	 *
     6	 * This function creates a viem extension that adds the full set of TEVM-specific actions to any viem client
     7	 * that has been configured with the TEVM transport. These actions provide direct access to the Ethereum
     8	 * Virtual Machine's capabilities, including:
     9	 *
    10	 * - Low-level EVM execution (`tevmCall`)
    11	 * - Contract interaction with ABI encoding/decoding (`tevmContract`)
    12	 * - Contract deployment (`tevmDeploy`)
    13	 * - Block mining (`tevmMine`)
    14	 * - Account state management (`tevmGetAccount`, `tevmSetAccount`)
    15	 * - State persistence (`tevmDumpState`, `tevmLoadState`)
    16	 * - Token manipulation (`tevmDeal` for ETH and ERC20 tokens)
    17	 * - Direct VM access (`tevm` for advanced usage)
    18	 *
    19	 * The viem client must already have TEVM support via a `createTevmTransport` transport.
    20	 *
    21	 * Note: If you are building a frontend application, you should use the tree-shakable API instead to optimize bundle size.
    22	 *
    23	 * @returns {(client: import('viem').Client<import('./TevmTransport.js').TevmTransport<string>>) => import('./TevmViemActionsApi.js').TevmViemActionsApi} A viem extension function that adds TEVM actions
    24	 * @throws {Error} If the client doesn't have a TEVM transport configured
    25	 *
    26	 * @example
    27	 * ```typescript
    28	 * import { createClient, http } from 'viem'
    29	 * import { optimism } from 'tevm/common'
    30	 * import { createTevmTransport, tevmViemActions } from 'tevm'
    31	 *
    32	 * // Create a basic viem client with TEVM transport
    33	 * const client = createClient({
    34	 *   transport: createTevmTransport({
    35	 *     fork: {
    36	 *       transport: http('https://mainnet.optimism.io')({})
    37	 *     }
    38	 *   }),
    39	 *   chain: optimism,
    40	 * })
    41	 *
    42	 * // Extend the client with TEVM actions
    43	 * const tevmClient = client.extend(tevmViemActions())
    44	 *
    45	 * async function example() {
    46	 *   // Wait for the client to be ready
    47	 *   await tevmClient.tevmReady()
    48	 *
    49	 *   // Set up an account with ETH
    50	 *   await tevmClient.tevmSetAccount({
    51	 *     address: '0x1234567890123456789012345678901234567890',
    52	 *     balance: 1000000000000000000n // 1 ETH
    53	 *   })
    54	 *
    55	 *   // Get account state including storage
    56	 *   const account = await tevmClient.tevmGetAccount({
    57	 *     address: '0x1234567890123456789012345678901234567890',
    58	 *     returnStorage: true,
    59	 *   })
    60	 *   console.log('Account:', account)
    61	 *
    62	 *   // Deploy a contract
    63	 *   const deployResult = await tevmClient.tevmDeploy({
    64	 *     bytecode: '0x608060405234801561001057600080fd5b50610150806100206000396000f3fe...',
    65	 *     abi: [...],
    66	 *     createTransaction: true // Create an actual transaction, not just a call
    67	 *   })
    68	 *
    69	 *   // Mine the transaction to include it in state
    70	 *   await tevmClient.tevmMine()
    71	 *
    72	 *   console.log('Contract deployed at:', deployResult.createdAddress)
    73	 * }
    74	 *
    75	 * example()
    76	 * ```
    77	 *
    78	 * @see [TEVM Actions Guide](https://tevm.sh/learn/actions/) - Complete documentation of all TEVM actions
    79	 * @see [Viem Client Guide](https://viem.sh/docs/clients/) - Viem client documentation
    80	 * @see {@link TevmViemActionsApi} - The API interface this extension implements
    81	 */
    82	export const tevmViemActions = () => {
    83		/**
    84		 * Internal extension function that adds TEVM actions to a viem client.
    85		 *
    86		 * This function extracts the TEVM API methods from the client's transport and
    87		 * exposes them with the prefix 'tevm' to make them available on the client object.
    88		 *
    89		 * @param {import('viem').Client<import('./TevmTransport.js').TevmTransport<string>>} client - The viem client configured with TEVM transport.
    90		 * @returns {import('./TevmViemActionsApi.js').TevmViemActionsApi} The TEVM actions API interface with all methods.
    91		 * @throws {TypeError} If the client doesn't have a TEVM transport configured.
    92		 * @private
    93		 */
    94		const extension = (client) => {
    95			const { call, contract, deploy, mine, loadState, dumpState, setAccount, getAccount, ready, deal } =
    96				client.transport.tevm.extend(tevmActions())
    97			return {
    98				tevmReady: ready,
    99				tevmCall: call,
   100				tevmContract: contract,
   101				tevmDeploy: deploy,
   102				tevmMine: mine,
   103				tevmLoadState: loadState,
   104				tevmDumpState: dumpState,
   105				tevmSetAccount: setAccount,
   106				tevmGetAccount: getAccount,
   107				tevmDeal: deal,
   108			}
   109		}
   110		return extension
   111	}

