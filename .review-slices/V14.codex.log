     6	/**
     7	 * Creates a custom TEVM Transport for viem clients, integrating an in-memory Ethereum Virtual Machine.
     8	 *
     9	 * A Transport in viem is the intermediary layer responsible for executing outgoing JSON-RPC requests.
    10	 * The TEVM Transport implementation replaces network requests with direct calls to an in-memory EVM,
    11	 * providing several key advantages:
    12	 *
    13	 * - **Local-first operation**: All EVM execution happens directly in the JavaScript runtime
    14	 * - **Zero network latency**: No round-trips to remote nodes for operations
    15	 * - **Deterministic execution**: Full control over the execution environment for testing
    16	 * - **Advanced tracing**: Step-by-step EVM execution with introspection capabilities
    17	 * - **Forking capabilities**: Can lazily load state from remote networks as needed
    18	 * - **Customizable state**: Direct manipulation of accounts, balances, storage, and more
    19	 *
    20	 * The transport can be used with any viem client (wallet, public, or test) and fully supports the
    21	 * EIP-1193 provider interface, making it compatible with the broader Ethereum ecosystem.
    22	 *
    23	 * @param {import('@tevm/node').TevmNodeOptions} options - Configuration options for the underlying TEVM node.
    24	 * @returns {import('./TevmTransport.js').TevmTransport} A configured TEVM transport factory function.
    25	 *
    26	 * @example
    27	 * ```typescript
    28	 * import { createClient, http } from 'viem'
    29	 * import { createTevmTransport } from 'tevm'
    30	 * import { optimism } from 'tevm/common'
    31	 *
    32	 * // Create a client with TEVM transport that forks from Optimism mainnet
    33	 * const client = createClient({
    34	 *   transport: createTevmTransport({
    35	 *     fork: {
    36	 *       transport: http('https://mainnet.optimism.io')({}),
    37	 *       blockTag: 'latest' // Optional: specify block number or hash
    38	 *     },
    39	 *     mining: {
    40	 *       auto: true,        // Optional: enable auto-mining after transactions
    41	 *       interval: 0        // Optional: mine blocks at regular intervals (ms)
    42	 *     }
    43	 *   }),
    44	 *   chain: optimism,
    45	 * })
    46	 *
    47	 * async function example() {
    48	 *   // Ready check ensures fork is initialized
    49	 *   await client.transport.tevm.ready()
    50	 *
    51	 *   const blockNumber = await client.getBlockNumber()
    52	 *   console.log(`Connected to block ${blockNumber}`)
    53	 *
    54	 *   // Access the underlying TEVM node for advanced operations
    55	 *   const node = client.transport.tevm
    56	 *   const vm = await node.getVm()
    57	 *   console.log(`EVM hardfork: ${vm.common.hardfork()}`)
    58	 * }
    59	 *
    60	 * example()
    61	 * ```
    62	 *
    63	 * @see {@link createClient} - Viem function for creating clients
    64	 * @see [Viem Client Docs](https://viem.sh/docs/clients/introduction)
    65	 * @see [Client Guide](https://tevm.sh/learn/clients/)
    66	 * @see [tevm JSON-RPC Guide](https://tevm.sh/learn/json-rpc/)
    67	 * @see [EIP-1193 spec](https://eips.ethereum.org/EIPS/eip-1193)
    68	 * @see [Ethereum JSON-RPC docs](https://ethereum.org/en/developers/docs/apis/json-rpc/)
    69	 * @see [CreateMemoryClient Docs](https://tevm.sh/reference/tevm/memory-client/functions/creatememoryclient/) - For a batteries-included client if not worried about tree shaking
    70	 *
    71	 * @typedef {Object} TevmTransportConfig
    72	 * @property {number} [timeout=20000] - Timeout duration for requests in milliseconds. Default is 20,000 ms. Supplied by viem.
    73	 * @property {number} [retryCount=3] - The maximum number of times to retry a failed request. Default is 3. Supplied by viem.
    74	 * @property {import('viem').Chain} [chain] - Blockchain configuration. Defaults to the chain specified in `options` or the default TEVM chain.
    75	 *
    76	 * ## Key Transport Options
    77	 *
    78	 * - `timeout` (optional, number): Timeout duration for requests in milliseconds. Default is 20,000 ms.
    79	 * - `retryCount` (optional, number): The maximum number of times to retry a failed request. Default is 3.
    80	 * - `chain` (optional, Chain): Blockchain configuration. Defaults to the chain in `options` or TEVM default.
    81	 *
    82	 * ## Key Node Options
    83	 *
    84	 * - `fork` (optional): Configuration for forking from an existing network
    85	 *   - `transport`: An EIP-1193 compatible transport (e.g., from viem's http function)
    86	 *   - `blockTag` (optional): Block number/hash to fork from (defaults to 'latest')
    87	 * - `mining` (optional): Mining configuration
    88	 *   - `auto` (boolean): Whether to automatically mine after transactions
    89	 *   - `interval` (number): Milliseconds between automatic block mining (0 = disabled)
    90	 * - `common` (optional): Chain configuration (recommended for optimal performance)
    91	 * - `persister` (optional): For state persistence between sessions
    92	 *
    93	 * ## Gotchas and Best Practices
    94	 *
    95	 * - When specifying a chain, use TEVM common instead of viem chains. You can create a TEVM common from a viem chain using `createCommon`.
    96	 * - The transport creates an internal cache of TEVM nodes keyed by chain ID, so multiple clients with the same chain ID share state.
    97	 * - For full control over a client's state, either use unique chain IDs or the higher-level `createMemoryClient`.
    98	 * - Access the underlying TEVM node via `client.transport.tevm` for advanced operations.
    99	 */
   100	export const createTevmTransport = (options = {}) => {
   101		/**
   102		 * A map to store and manage TEVM clients keyed by chain ID.
   103		 * @type {Map<number, import('@tevm/node').TevmNode & import('@tevm/decorators').Eip1193RequestProvider & import('@tevm/decorators').TevmSendApi>}
   104		 */
   105		const tevmMap = new Map()
   106	
   107		/**
   108		 * Creates and returns a TEVM transport.
   109		 * @type {import('./TevmTransport.js').TevmTransport}
   110		 */
   111		return ({ timeout = 20_000, retryCount = 3, chain }) => {
   112			const dynamicChain =
   113				chain && 'ethjsCommon' in chain
   114					? /** @type {import('@tevm/common').Common} */ (chain)
   115					: chain !== undefined
   116						? // if user passed in chain instead of common create a common from it with cancun and default eips
   117							createCommon({ ...chain, hardfork: 'prague', loggingLevel: 'warn' })
   118						: undefined
   119			const common = options.common ?? dynamicChain
   120			const id = common?.id ?? -1
   121			const tevm =
   122				tevmMap.get(id) ??
   123				createTevmNode({ ...options, ...(common !== undefined ? { common } : {}) })
   124					.extend(requestEip1193())
   125					.extend(tevmSend())
   126			tevmMap.set(id, tevm)
   127	
   128			return /** @type {any} */ (
   129				createTransport(
   130					{
   131						request: /** @type any */ (tevm.request),
   132						type: 'tevm',
   133						name: /** options?.name ?? */ 'Tevm transport',
   134						key: /* options?.key ?? */ 'tevm',
   135						timeout,
   136						retryCount,
   137						retryDelay: /* options?.retryDelay ?? */ 150,
   138					},
   139					{ tevm },
   140				)
   141			)
   142		}
   143	}

