   250				// Guard against the case if a tx came into the pool without blobs i.e. network wrapper payload
   251				if (blobTx.blobs === undefined) {
   252					throw new InvalidBlobVersionedHashesError('blobs missing for 4844 transaction')
   253				}
   254	
   255				if (this.blobGasUsed + BigInt(blobTx.numBlobs()) * blobGasPerBlob > blobGasLimit) {
   256					throw new BlockGasLimitExceededError('block blob gas limit reached')
   257				}
