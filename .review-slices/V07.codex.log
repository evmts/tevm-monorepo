   343			const headerData = {
   344				...this.headerData,
   345				stateRoot,
   346				transactionsTrie,
   347				...(withdrawalsRoot !== undefined ? { withdrawalsRoot } : {}),
   348				...(blobGasUsed !== undefined ? { blobGasUsed } : {}),
   349				receiptTrie,
   350				logsBloom,
   351				gasUsed,
   352				timestamp,
   353				// correct excessBlobGas should already be part of headerData used above
   354			}
   355	
   356			if (consensusType === ConsensusType.ProofOfWork) {
   357				headerData.nonce = sealOpts?.nonce ?? (headerData.nonce as Uint8Array)
   358				headerData.mixHash = sealOpts?.mixHash ?? (headerData.mixHash as Uint8Array)
   359			}
