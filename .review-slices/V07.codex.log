    38			name: '@tevm/blockchain',
    39			level: options.loggingLevel ?? 'warn',
    40		})
    41		/**
    42		 * @type {import('./BaseChain.js').BaseChain}
    43		 */
    44		const chain = {
    45			logger,
    46			options,
    47			common: options.common,
    48			blocks: new Map(),
    49			blocksByTag: new Map(),
    50			blocksByNumber: new Map(),
    51			ready: () => genesisBlockPromise.then(() => true),
    52		}
    53	
    54		// Add genesis block and forked block to chain
    55		const genesisBlockPromise = (async () => {
    56			if (options.fork?.transport) {
