   302			}
   303			this.blockStatus = { status: BuildStatus.Reverted }
   304		}
   305	
   306		/**
   307		 * This method returns the finalized block.
   308		 * It also:
   309		 *  - Assigns the reward for miner (PoW)
   310		 *  - Commits the checkpoint on the StateManager
