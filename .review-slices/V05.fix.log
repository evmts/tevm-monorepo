    15	const pragmaPattern = /pragma\s+solidity\s+((\^|~|>|>=|<|<=)?\s*(\d+\.\d+\.\d+)\s*);/
    16	const pragmaPatternWithBounds = /pragma\s+solidity\s+(>=?\d+\.\d+\.\d+)\s*<\s*(\d+\.\d+\.\d+)\s*;/
    17	
    18	/**
    19	 * Validates that a Solidity file has a pragma without changing its version constraints.
    20	 * @param {string} solidityCode The Solidity code to update.
    21	 * @param {string} [version] Unused legacy override.
    22	 * @returns {import("effect/Effect").Effect<string, NoPragmaFoundError, never>} The Solidity code.
    23	 */
    24	export const updatePragma = (solidityCode, version) => {
    25		void version
    26		let match = solidityCode.match(pragmaPattern)
    27		if (match?.[3]) {
    28			return succeed(solidityCode)
    29		}
    30		match = solidityCode.match(pragmaPatternWithBounds)
    31		if (match?.[1]) {
    32			return succeed(solidityCode)
    33		}
    34		return fail(new NoPragmaFoundError('No valid pragma statement found.'))
    35	}

