    20	 *     cjs: string,
    21	 *     dts: string,
    22	 *     ts: string,
    23	 *     mjs: string
    24	 *   }
    25	 * }} A nested object mapping contract types and module types to import statements
    26	 */
    27	const importsByModuleType = (contractPackage) => ({
    28		contract: {
    29			cjs: `const { createContract } = require('${contractPackage}')`,
    30			dts: `import type { Contract } from '${contractPackage}'`,
    31			ts: `import { createContract } from '${contractPackage}'`,
    32			mjs: `import { createContract } from '${contractPackage}'`,
    33		},
    34		script: {
    35			cjs: `const { createContract } = require('${contractPackage}')`,
    36			dts: `import type { Contract } from '${contractPackage}'`,
    37			ts: `import { createContract } from '${contractPackage}'`,
    38			mjs: `import { createContract } from '${contractPackage}'`,
    39		},
    40	})
    41	
    42	/**
    43	 * Generates a complete runtime module from Solidity compilation artifacts.
    44	 *
    45	 * This function combines the appropriate import statements with the generated
    46	 * contract body code to create a complete module that exports the Tevm Contract
    47	 * objects. It supports different output formats and can optionally include
    48	 * bytecode for deployable contracts.
    49	 *
    50	 * @param {import("@tevm/compiler").Artifacts} artifacts - Compiled Solidity artifacts
    51	 *   containing ABI, bytecode, and other contract information
    52	 * @param {import('./types.js').ModuleType} moduleType - The target module format
    53	 *   ('cjs', 'dts', 'ts', or 'mjs')
    54	 * @param {boolean} includeBytecode - Whether to include bytecode in the output,
    55	 *   true for script/deployable contracts, false for interface-only contracts
    56	 * @param {'tevm/contract' | '@tevm/contract'} tevmPackage - Package name to import
    57	 *   the createContract function from
    58	 * @returns {import('effect/Effect').Effect<string, never, never>} - Effect that
    59	 *   resolves to the generated module code as a string
    60	 * @throws {Error} If no artifacts are provided or if an invalid module type is specified
    61	 *
    62	 * @example
    63	 * ```javascript
    64	 * import { generateRuntime } from '@tevm/runtime'
    65	 * import { runPromise } from 'effect/Effect'
    66	 *
    67	 * // Generate TypeScript module from artifacts
    68	 * const code = await runPromise(
    69	 *   generateRuntime(
    70	 *     artifacts,         // Solidity compilation results
    71	 *     'ts',              // Generate TypeScript code
    72	 *     true,              // Include bytecode
    73	 *     '@tevm/contract'   // Import from this package
    74	 *   )
    75	 * )
    76	 *
    77	 * console.log(code)
    78	 * ```
    79	 */
    80	export const generateRuntime = (artifacts, moduleType, includeBytecode, tevmPackage) => {
    81		// Validate that artifacts exist
    82		if (!artifacts || Object.keys(artifacts).length === 0) {
    83			return die('No artifacts provided to generateRuntime')
    84		}
    85	
    86		// Determine the appropriate import statements based on module type and bytecode inclusion
    87		const contractType = includeBytecode ? 'script' : 'contract'
    88		const imports = importsByModuleType(tevmPackage)[contractType][moduleType]
    89	
    90		// Validate the module type
    91		if (!imports) {
    92			return die(`Unknown module type: ${moduleType}. Valid module types include 'cjs', 'dts', 'ts', and 'mjs'`)
    93		}
    94	
    95		// Generate the contract body and combine with imports
    96		return generateTevmBody(artifacts, moduleType, includeBytecode).pipe(map((body) => [imports, body].join('\n')))
    97	}

