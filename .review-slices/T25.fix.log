     7	/**
     8	 * Gets the token balance change for a specific token and address by analyzing storage changes
     9	 * @param node - The TevmNode instance
    10	 * @param tokenAddress - The token contract address
    11	 * @param address - The address to check balance change for
    12	 * @param prestateTrace - The prestate trace containing storage changes
    13	 * @returns The balance change and slot information
    14	 */
    15	export const getTokenBalanceChange = async (
    16		node: TevmNode,
    17		tokenAddress: Address,
    18		address: Address,
    19		prestateTrace: PrestateTraceResult<true>,
    20	): Promise<bigint> => {
    21		// Get the current balance - explicitly disable transaction creation for read operations
    22		// to prevent auto-mining conflicts
    23		const currentBalanceResponse = await contractHandler(node)({
    24			...ERC20.withAddress(tokenAddress).read.balanceOf(address),
    25			throwOnFail: false,
    26			createTransaction: false,
    27		})
    28	
    29		if (currentBalanceResponse.errors || currentBalanceResponse.data === undefined) {
    30			throw new Error(
    31				`Failed to get initial balance for token ${tokenAddress} and address ${address} when trying to find the balanceOf slot. Could not retrieve the balance change.\n\n${JSON.stringify(currentBalanceResponse, (_, v) => (typeof v === 'bigint' ? v.toString() : v), 2)}`,
    32			)
    33		}
    34	
    35		const currentBalance = currentBalanceResponse.data
    36	
    37		// Iterate through all addresses that have storage changes
    38		for (const [contractAddress, traceData] of Object.entries(prestateTrace.post)) {
    39			// Skip if no storage changes
    40			if (!traceData.storage) continue
    41	
    42			// For each storage slot that was accessed
    43			for (const [slot, currentValue] of Object.entries(traceData.storage)) {
    44				// Skip early if the value is not the encoded current balance
    45				if (!isEqual(currentValue, numberToHex(currentBalance))) continue
    46	
    47				try {
    48					// Set to a different value to see if it affects the balance
    49					const nextValue = numberToHex(currentBalance + 1n, { size: 32 })
    50					await anvilSetStorageAtJsonRpcProcedure(node)({
    51						method: 'anvil_setStorageAt',
    52						params: [contractAddress as Address, slot as Hex, nextValue],
    53						id: 1,
    54						jsonrpc: '2.0',
    55					})
    56	
    57					// Check if the balance changed - explicitly disable transaction creation for read operations
    58					const nextBalanceResponse = await contractHandler(node)({
    59						...ERC20.withAddress(tokenAddress).read.balanceOf(address),
    60						createTransaction: false,
    61					})
    62	
    63					// If balance didn't change, that's not the slot we're looking for
    64					if (nextBalanceResponse.data === undefined || nextBalanceResponse.data === currentBalance) continue
    65	
    66					// Get the previous balance from the prestate trace
    67					const preSlotValue = prestateTrace.pre[contractAddress as Address]?.storage?.[slot as Hex]
    68					if (preSlotValue === undefined) throw new Error('preSlotValue is undefined') // this can't happen as it was in the post state
    69	
    70					const previousBalance = hexToBigInt(preSlotValue)
    71					return currentBalance - previousBalance
    72				} catch (_) {
    73					// If there's an error, we'll try the next slot
    74				} finally {
    75					// Always restore the original value
    76					await anvilSetStorageAtJsonRpcProcedure(node)({
    77						method: 'anvil_setStorageAt',
    78						params: [contractAddress as Address, slot as Hex, currentValue],
    79						id: 1,
    80						jsonrpc: '2.0',
    81					})
    82				}
    83			}
    84		}
    85	
    86		// If no storage slot affected the balance, that means this account was untouched so its balance didn't change
    87		// or it was touched but only accessed (balance is in pre state but not in post state)
    88		return 0n
    89	}

