    10	/**
    11	 * Replay a transaction with a prestate tracer to figure out the balance changes
    12	 * @param node - The TEVM node
    13	 * @param txHash - The transaction hash
    14	 * @returns Promise with balance change getter functions
    15	 */
    16	export const getDiffMethodsFromPrestateTrace = async (
    17		client: Client | TevmNode,
    18		tx: ContainsTransactionAny | Promise<ContainsTransactionAny>,
    19	): Promise<HandleTransactionResult> => {
    20		const { node, txHash } = await handleTransaction(client, tx)
    21	
    22		const res = await debugTraceTransactionJsonRpcProcedure(node)({
    23			jsonrpc: '2.0',
    24			method: 'debug_traceTransaction',
    25			params: [{ transactionHash: txHash, tracer: 'prestateTracer', tracerConfig: { diffMode: true } }],
    26			id: 1,
    27		})
    28	
    29		const prestateTrace = res.result as PrestateTraceResult<true>
    30	
    31		return {
    32			getBalanceChange: (address: Address) => getBalanceChange(prestateTrace, address.toLowerCase() as Address),
    33			getTokenBalanceChange: (tokenAddress: Address, address: Address) =>
    34				getTokenBalanceChange(
    35					node,
    36					tokenAddress.toLowerCase() as Address,
    37					address.toLowerCase() as Address,
    38					prestateTrace,
    39				),
    40		}
    41	}

