     1	import { createTevmNode, type TevmNode } from '@tevm/node'
     2	import { type Client, type Hex, isHex } from 'viem'
     3	import { waitForTransactionReceipt } from 'viem/actions'
     4	import type { ContainsTransactionAny } from './types.js'
     5	
     6	/**
     7	 * Common result from handling a transaction
     8	 */
     9	export interface HandleTransactionResult {
    10		node: TevmNode
    11		txHash: Hex
    12	}
    13	
    14	/**
    15	 * Handles a transaction to extract the node and transaction hash
    16	 * @param client - The client or node to use for handling the transaction
    17	 * @param tx - The transaction to handle
    18	 * @returns Promise with node and transaction hash
    19	 */
    20	export const handleTransaction = async (
    21		client: Client | TevmNode,
    22		tx: ContainsTransactionAny | Promise<ContainsTransactionAny>,
    23	): Promise<HandleTransactionResult> => {
    24		const res = tx instanceof Promise ? await tx : tx
    25	
    26		const node = 'request' in client ? createTevmNode({ fork: { transport: client } }) : client
    27	
    28		const txHash =
    29			// If it's a transaction receipt
    30			typeof res === 'object' && 'transactionHash' in res
    31				? res.transactionHash
    32				: // If it's a call result
    33					typeof res === 'object' && 'txHash' in res
    34					? res.txHash
    35					: // If it's already a transaction hash
    36						typeof res === 'string' && isHex(res)
    37						? res
    38						: undefined
    39	
    40		if (txHash === undefined) {
    41			throw new Error(
    42				'Transaction hash is undefined, you need to pass a transaction hash, receipt or call result, or a promise that resolves to one of those',
    43			)
    44		}
    45	
    46		// If a client was passed, we assume the tx will get mined consumer side, so we just need to wait for it
    47		if ('request' in client) {
    48			await waitForTransactionReceipt(client, { hash: txHash })
    49		}
    50	
    51		return { node, txHash }
    52	}

