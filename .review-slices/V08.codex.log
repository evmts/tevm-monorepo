    71		 * @returns {Promise<import('./EvmType.js').Evm>}
    72		 */
    73		static create = async (options) => {
    74			const evm = /** @type {any}*/ (await createEVM(options))
    75			evm.addCustomPrecompile = Evm.prototype.addCustomPrecompile.bind(evm)
    76			evm.removeCustomPrecompile = Evm.prototype.removeCustomPrecompile.bind(evm)
    77			return evm
