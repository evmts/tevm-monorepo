   118				}
   119			}
   120	
   121			return {
   122				storage,
   123				balance: toHex(account.balance),
   124				nonce: Number(account.nonce),
   125				code: code && code.length > 0 ? bytesToHex(code) : '0x',
   126			}
   127		} catch (err) {
