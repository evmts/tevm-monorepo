   296		/**
   297		 * @param {string | undefined} [senderFilter]
   298		 * @returns {Promise<{ pending: TxpoolBucket, queued: TxpoolBucket }>}
   299		 */
   300		const classifyTxpool = async (senderFilter) => {
   301			const txPool = await client.getTxPool()
   302			const vm = await client.getVm()
   303			/** @type {TxpoolBucket} */
   304			const pending = {}
   305			/** @type {TxpoolBucket} */
   306			const queued = {}
   307			for (const [sender, txs] of txPool.pool) {
   308				if (senderFilter && sender.toLowerCase() !== senderFilter.toLowerCase()) continue
   309				const account = await vm.stateManager.getAccount(createAddress(sender))
   310				let nextNonce = account?.nonce ?? 0n
   311				for (const tx of txs) {
   312					const innerTx = /** @type {any} */ (tx.tx ?? tx)
   313					const txNonce = BigInt(innerTx.nonce ?? innerTx.txData?.nonce ?? 0n)
   314					const isPending = txNonce === nextNonce
   315					const bucket = isPending ? pending : queued
   316					if (!bucket[sender]) bucket[sender] = {}
   317					bucket[sender][numberToHex(txNonce)] = innerTx
   318					if (isPending) nextNonce++
   319				}
   320			}

