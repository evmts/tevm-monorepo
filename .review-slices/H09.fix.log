   156			if (intervalMiningTimer !== undefined) {
   157				clearInterval(intervalMiningTimer)
   158				intervalMiningTimer = undefined
   159			}
   160		}
   161		/**
   162		 * @param {number} blockTime
   163		 */
   164		const startIntervalMiningTimer = (blockTime) => {
   165			stopIntervalMiningTimer()
   166			if (blockTime <= 0) return
   167			intervalMiningTimer = setInterval(async () => {
   168				if (client.miningConfig.type !== 'interval' || client.miningConfig.blockTime <= 0) return
   169				await mineProcedure(client)(/** @type {any} */ ({ jsonrpc: '2.0', method: 'anvil_mine', params: ['0x1', '0x0'] }))
   170			}, blockTime * 1000)
   171		}
   172		if (client.miningConfig.type === 'interval' && client.miningConfig.blockTime > 0) {
   173			startIntervalMiningTimer(client.miningConfig.blockTime)
   174		}
