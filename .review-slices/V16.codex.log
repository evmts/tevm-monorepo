    27	
    28	export default function CliAction({
    29		formattedResult,
    30		isInteractiveLoading,
    31		isActionLoading,
    32		isInstallingDeps,
    33		interactiveError,
    34		actionError,
    35		targetName,
    36		editorActive = false,
    37	}: CliActionProps) {
    38		// If editor is active, render absolutely nothing
    39		if (editorActive) {
    40			return null
    41		}
    42	
    43		// Priority 1: Show dependency installation
    44		if (isInstallingDeps) {
    45			return (
    46				<Box>
    47					<Text>
    48						<Spinner type="dots" /> Installing dependencies...
    49					</Text>
    50				</Box>
    51			)
    52		}
    53	
    54		// Priority 2: Show loading state
    55		if (isInteractiveLoading || isActionLoading) {
    56			return (
    57				<Box>
    58					<Text>
    59						<Spinner type="dots" /> {isActionLoading && targetName ? `Processing ${targetName}...` : 'Processing...'}
    60					</Text>
    61				</Box>
    62			)
    63		}
    64	
    65		// Priority 3: Show errors if present
    66		if (interactiveError || actionError) {
    67			const error = interactiveError || actionError
    68			return (
    69				<Box>
    70					<Text color="red">{(error as Error).message || 'An error occurred'}</Text>
    71				</Box>
    72			)
    73		}
    74	
    75		// Priority 4: Show just the result
    76		if (formattedResult) {
    77			return (
    78				<Box>
    79					<Text>{formattedResult}</Text>
    80				</Box>
    81			)
    82		}
    83	
    84		// Fallback (should rarely happen)
    85		return null
    86	}

