     4	export interface CliActionProps {
     5		// Results
     6		result?: any
     7		formattedResult?: string
     8	
     9		// Loading states
    10		isInteractiveLoading?: boolean
    11		isActionLoading?: boolean
    12		isInstallingDeps?: boolean
    13	
    14		// Errors
    15		interactiveError?: Error | null
    16		actionError?: Error | null
    17	
    18		// Options and context
