   146					setIsInteractive(false)
   147				}
   148				return
   149			}
   150	
   151			// Tab navigation when not in interactive mode
   152			if (key.tab || key.rightArrow) {
   153				setActiveTab((prev) => (prev + 1) % tabs.length)
   154			} else if ((key.shift && key.tab) || key.leftArrow) {
   155				setActiveTab((prev) => (prev - 1 + tabs.length) % tabs.length)
   156			} else if (key.return && activeTab > 0) {
   157				// Enter on a tab enters interactive mode
   158				setIsInteractive(true)
   159			}
   160		})
   161	
   162		// Display loading state while server is starting
   163		if (isLoading) {
   164			return (
