     1	import { createAddress } from '@tevm/address'
     2	import { ForkError, InternalError } from '@tevm/errors'
     3	import { bytesToHex, hexToBytes } from '@tevm/utils'
     4	import { cloneVmWithBlockTag } from '../Call/cloneVmWithBlock.js'
     5	import { getPendingClient } from '../internal/getPendingClient.js'
     6	import { asLightSelector, ensureLightReady, getLightProof } from './lightClientRead.js'
     7	
     8	/**
     9	 * @param {import('@tevm/node').TevmNode} client
    10	 * @returns {import('./EthHandler.js').EthGetStorageAtHandler}
    11	 */
    12	export const getStorageAtHandler = (client) => async (params) => {
    13		const normalizedPosition = bytesToHex(hexToBytes(params.position, { size: 32 }))
    14		if (client.consensus?.mode === 'light-client') {
    15			ensureLightReady(client, 'eth_getStorageAt')
    16			const selector = asLightSelector(params.blockTag ?? 'latest')
    17			const { proof } = await getLightProof(client, params.address, [normalizedPosition], selector)
    18			const hit = proof.storageProof.find(
    19				/** @param {{ key: import('@tevm/utils').Hex, value?: import('@tevm/utils').Hex }} entry */
    20				(entry) => bytesToHex(hexToBytes(entry.key, { size: 32 })) === normalizedPosition,
    21			)
    22			if (!hit) throw new Error('LIGHT_CLIENT_MALFORMED_UPSTREAM_PROOF: requested storage key missing from proof payload')
    23			return bytesToHex(hexToBytes(hit.value ?? '0x', { size: 32 }))
    24		}
    25		const vm = await client.getVm()
    26		const tag = params.blockTag ?? 'latest'
    27		if (tag === 'pending') {
    28			const mineResult = await getPendingClient(client)
    29			if (mineResult.errors) {
    30				throw mineResult.errors[0]
    31			}
    32			return getStorageAtHandler(mineResult.pendingClient)({ ...params, blockTag: 'latest' })
    33		}
    34		if (tag === 'latest') {
    35			return bytesToHex(
    36				await vm.stateManager.getStorage(createAddress(params.address), hexToBytes(normalizedPosition, { size: 32 })),
    37				{ size: 32 },
    38			)
    39		}
    40		const block = await vm.blockchain.getBlockByTag(tag)
    41		const clonedVm = await cloneVmWithBlockTag(client, block)
    42	
    43		if (clonedVm instanceof ForkError || clonedVm instanceof InternalError) {
    44			throw clonedVm
    45		}
    46	
    47		return getStorageAtHandler({ ...client, getVm: () => Promise.resolve(clonedVm) })({ ...params, blockTag: 'latest' })
    48	}

