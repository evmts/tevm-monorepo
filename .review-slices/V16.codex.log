   171					</Text>
   172				</Box>
   173			)
   174		}
   175	
   176		// Display error state if server failed to start
   177		if (isError) {
   178			return (
   179				<Box flexDirection="column">
   180					<Text color="red">Error starting server: {error instanceof Error ? error.message : String(error)}</Text>
   181				</Box>
   182			)
   183		}
   184	
   185		// Render content based on active tab and interactive state
   186		const renderContent = () => {
   187			// Home tab content - server info
   188			if (activeTab === 0) {
   189				return (
   190					<HomeTab
   191						host={options.host}
   192						port={options.port}
   193						chainId={options.chainId}
   194						fork={options.fork}
   195						verbose={options.verbose}
   196					/>
   197				)
   198			}
   199	
   200			// Action component or Logs tab
   201			const currentTab = tabs[activeTab]
   202			if (currentTab?.component) {
   203				const TabComponent = currentTab.component
   204				return <TabComponent interactive={isInteractive} />
   205			}
   206	
   207			return <Text>Tab content not available</Text>
   208		}
   209	
   210		return (
   211			<Box flexDirection="column">
   212				{/* Only show tabs if not in interactive mode */}
   213				{!isInteractive && (
   214					<Box marginBottom={1}>
   215						{tabs.map((tab, index) => (
   216							<Box key={tab.name} marginRight={2}>
   217								<Text
   218									backgroundColor={activeTab === index ? 'blue' : undefined}
   219									color={activeTab === index ? 'white' : 'gray'}
   220									bold={activeTab === index}

