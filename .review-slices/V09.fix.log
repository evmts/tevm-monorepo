   244		const lines = trace.summary && Object.keys(trace.summary).length > 0 ? [...trace.steps, trace.summary] : trace.steps
   245		mkdirForFile(outFile)
   246		if (format === 'json') {
   247			writeFileSync(outFile, JSON.stringify({ format: 'eip3155', traces: trace.steps, summary: trace.summary }, null, 2))
   248			return
   249		}
   250		writeFileSync(outFile, `${lines.map((line) => JSON.stringify(line)).join('\n')}\n`)
   251	}
   252	
   253	const firstDivergence = (actual, reference) => {
   254		const count = Math.max(actual.steps.length, reference.steps.length)
   255		for (let index = 0; index < count; index++) {
   256			const actualStep = actual.steps[index]
   257			const referenceStep = reference.steps[index]
   258			if (actualStep === undefined || referenceStep === undefined) {
   259				return { index, field: 'length', actual: actualStep ?? null, reference: referenceStep ?? null }
   260			}
   261			for (const field of new Set([...Object.keys(actualStep), ...Object.keys(referenceStep)])) {
   262				if (JSON.stringify(actualStep[field]) !== JSON.stringify(referenceStep[field])) {
   263					return { index, field, actual: actualStep[field] ?? null, reference: referenceStep[field] ?? null }
   264				}
   265			}
   266		}
   267		return null
   268	}
   269	
   270	export const compareNormalizedTraces = ({ actual, reference }) => {
   271		const divergence = firstDivergence(actual, reference)
   272		return {
   273			format: 'eip3155',
   274			status: divergence === null ? 'passed' : 'failed',
   275			comparedSteps: Math.min(actual.steps.length, reference.steps.length),
   276			actualSteps: actual.steps.length,
   277			referenceSteps: reference.steps.length,
   278			firstDivergence: divergence,
   279		}
   280	}
   281	
   282	export const compareTraceFiles = ({ actualFile, referenceFile, outFile, allowMissing = true }) => {
   283		if (!actualFile || !referenceFile || !existsSync(actualFile) || !existsSync(referenceFile)) {
   284			const result = {
   285				format: 'eip3155',
   286				status: 'skipped',
   287				coverage: 'none',
   288				synthetic: false,
   289				reason: 'Actual or reference EIP-3155 trace file is missing.',
   290				actualFile: actualFile ?? null,
   291				referenceFile: referenceFile ?? null,
   292			}
   293			if (outFile) {
   294				mkdirForFile(outFile)
   295				writeFileSync(outFile, JSON.stringify(result, null, 2))
   296			}
   297			if (!allowMissing) throw new Error(result.reason)
   298			return result
   299		}
   300		const actual = readNormalizedTrace(actualFile)
   301		const reference = readNormalizedTrace(referenceFile)
   302		if (actual.steps.length === 0 || reference.steps.length === 0) {
   303			const result = {
   304				format: 'eip3155',
   305				status: 'skipped',
   306				coverage: 'none',
   307				synthetic: false,
   308				reason: 'Actual or reference trace did not contain EIP-3155 opcode steps.',
   309				actualFile,
   310				referenceFile,
   311				actualSteps: actual.steps.length,
   312				referenceSteps: reference.steps.length,
   313			}
   314			if (outFile) {
   315				mkdirForFile(outFile)
   316				writeFileSync(outFile, JSON.stringify(result, null, 2))
   317			}
   318			return result
   319		}
   320		const result = compareNormalizedTraces({ actual, reference })
   321		if (outFile) {
   322			mkdirForFile(outFile)
   323			writeFileSync(outFile, JSON.stringify(result, null, 2))
   324		}
   325		return result
   326	}
   327	
   328	export const runCli = (argv = process.argv.slice(2)) => {
   329		const { command, flags } = parseArgs(argv)
   330		if (command === 'convert') {
   331			const input = flags.get('--input')
   332			const outFile = flags.get('--out')
   333			const format = flags.get('--format') ?? 'jsonl'
   334			if (!input || !outFile) throw new Error('convert requires --input and --out')
   335			writeTrace({ trace: readNormalizedTrace(input), outFile, format })
   336			console.log(`wrote ${outFile}`)
   337			return 0
   338		}
   339		if (command === 'compare') {
   340			const result = compareTraceFiles({
   341				actualFile: flags.get('--actual'),
   342				referenceFile: flags.get('--reference'),
   343				outFile: flags.get('--out'),
   344				allowMissing: flags.get('--require-files') !== 'true',
   345			})
   346			if (flags.get('--out')) console.log(`wrote ${flags.get('--out')}`)
   347			return result.status === 'failed' ? 1 : 0
   348		}
   349		console.log('Usage: trace-tools.mjs convert --input=<trace.json> --out=<trace.jsonl> [--format=jsonl|json]')
   350		console.log('       trace-tools.mjs compare --actual=<trace.jsonl> --reference=<trace.jsonl> --out=<diff.json>')
   351		return command === 'help' ? 0 : 1
   352	}
   353	
   354	if (process.argv[1] && fileURLToPath(import.meta.url) === process.argv[1]) {
   355		try {
   356			process.exit(runCli())
   357		} catch (error) {
   358			console.error(error instanceof Error ? error.message : String(error))
   359			process.exit(1)
   360		}
   361	}

