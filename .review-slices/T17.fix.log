		fromBlock?: BlockTag,
		toBlock?: BlockTag,
	) => Promise<
		Array<
			TContractEventName extends ExtractAbiEventNames<TAbi> ? EthersEventLog<TAbi, TContractEventName> : EventLog | Log
		>
	>
}

