     6	/**
     7	 * Creates a custom TEVM Transport for viem clients, integrating an in-memory Ethereum Virtual Machine.
     8	 *
     9	 * A Transport in viem is the intermediary layer responsible for executing outgoing JSON-RPC requests.
    10	 * The TEVM Transport implementation replaces network requests with direct calls to an in-memory EVM,
    11	 * providing several key advantages:
    12	 *
    13	 * - **Local-first operation**: All EVM execution happens directly in the JavaScript runtime
    14	 * - **Zero network latency**: No round-trips to remote nodes for operations
    15	 * - **Deterministic execution**: Full control over the execution environment for testing
    16	 * - **Advanced tracing**: Step-by-step EVM execution with introspection capabilities
    17	 * - **Forking capabilities**: Can lazily load state from remote networks as needed
    18	 * - **Customizable state**: Direct manipulation of accounts, balances, storage, and more
    19	 *
    20	 * The transport can be used with any viem client (wallet, public, or test) and fully supports the
    21	 * EIP-1193 provider interface, making it compatible with the broader Ethereum ecosystem.
    22	 *
    23	 * @param {import('@tevm/node').TevmNodeOptions} options - Configuration options for the underlying TEVM node.
    24	 * @returns {import('./TevmTransport.js').TevmTransport} A configured TEVM transport factory function.
    25	 *
    26	 * @example
    27	 * ```typescript
    28	 * import { createClient, http } from 'viem'
    29	 * import { createTevmTransport } from 'tevm'
    30	 * import { optimism } from 'tevm/common'
    31	 *
    32	 * // Create a client with TEVM transport that forks from Optimism mainnet
    33	 * const client = createClient({
    34	 *   transport: createTevmTransport({
    35	 *     fork: {
    36	 *       transport: http('https://mainnet.optimism.io')({}),
    37	 *       blockTag: 'latest' // Optional: specify block number or hash
    38	 *     },
    39	 *     mining: {
    40	 *       auto: true,        // Optional: enable auto-mining after transactions
    41	 *       interval: 0        // Optional: mine blocks at regular intervals (ms)
    42	 *     }
    43	 *   }),
    44	 *   chain: optimism,
    45	 * })
    46	 *
    47	 * async function example() {
    48	 *   // Ready check ensures fork is initialized
    49	 *   await client.transport.tevm.ready()
    50	 *
    51	 *   const blockNumber = await client.getBlockNumber()
    52	 *   console.log(`Connected to block ${blockNumber}`)
    53	 *
    54	 *   // Access the underlying TEVM node for advanced operations
    55	 *   const node = client.transport.tevm
    56	 *   const vm = await node.getVm()
    57	 *   console.log(`EVM hardfork: ${vm.common.hardfork()}`)
    58	 * }
