     1	import { mineHandler } from '@tevm/actions'
     2	
     3	/**
     4	 * A tree-shakeable version of the `tevmMine` action for viem.
     5	 * Mines new blocks in the TEVM blockchain, finalizing pending transactions and updating blockchain state.
     6	 *
     7	 * In TEVM, transactions (like contract deployments, transfers, or contract calls with `createTransaction: true`)
     8	 * are processed immediately but don't affect the blockchain state until they're included in a mined block.
     9	 * This function advances the blockchain by mining blocks containing any pending transactions.
    10	 *
    11	 * **Key Mining Concepts:**
    12	 * - Mining finalizes transactions and updates the canonical blockchain state
    13	 * - All pending transactions are included in blocks when mining
    14	 * - Block timestamps advance according to the specified interval
    15	 * - Mining creates new blocks regardless of whether there are pending transactions
    16	 * - The returned block hashes can be used to query block information or transaction receipts
    17	 *
    18	 * **Mining Modes in TEVM:**
    19	 * 1. **Manual Mining**: Default mode where you explicitly call `tevmMine` to mine blocks
    20	 * 2. **Auto Mining**: When enabled, automatically mines after every transaction
    21	 * 3. **Interval Mining**: When enabled, mines blocks at a specified time interval
    22	 *
    23	 * The manual mining mode gives you precise control over when state changes take effect, making it
    24	 * ideal for step-by-step testing and debugging scenarios.
    25	 *
    26	 * @param {import('viem').Client<import('./TevmTransport.js').TevmTransport<string>>} client - The viem client configured with TEVM transport.
    27	 * @param {import('@tevm/actions').MineParams} [params] - Optional parameters for mining blocks.
    28	 * @returns {Promise<import('@tevm/actions').MineResult>} The result of mining blocks, including an array of block hashes.
    29	 *
    30	 * @example
    31	 * ```typescript
    32	 * import { tevmMine } from 'tevm/actions'
    33	 * import { createClient, http, parseEther } from 'viem'
    34	 * import { optimism } from 'tevm/common'
    35	 * import { createTevmTransport } from 'tevm'
    36	 *
    37	 * const client = createClient({
    38	 *   transport: createTevmTransport({
    39	 *     fork: { transport: http('https://mainnet.optimism.io')({}) },
    40	 *     mining: { auto: false } // Explicit manual mining mode
    41	 *   }),
    42	 *   chain: optimism,
    43	 * })
    44	 *
    45	 * async function example() {
    46	 *   // Set up two accounts
    47	 *   const sender = '0x1234567890123456789012345678901234567890'
    48	 *   const recipient = '0x0987654321098765432109876543210987654321'
    49	 *
    50	 *   // Give sender some ETH
    51	 *   await client.setBalance({
    52	 *     address: sender,
    53	 *     value: parseEther('10')
    54	 *   })
    55	 *
    56	 *   // Send transaction (processed but not yet in state)
    57	 *   const txHash = await client.sendTransaction({
    58	 *     from: sender,
    59	 *     to: recipient,
    60	 *     value: parseEther('1')
    61	 *   })
    62	 *
    63	 *   // Balances don't reflect the transfer yet
    64	 *   console.log('Pre-mine recipient balance:',
    65	 *     await client.getBalance({ address: recipient })) // 0n
    66	 *
    67	 *   // Mine a single block to include the transaction
    68	 *   const result = await tevmMine(client)
    69	 *   console.log('Mined block hash:', result.blockHashes[0])
    70	 *
    71	 *   // Now balances reflect the transfer
    72	 *   console.log('Post-mine recipient balance:',
    73	 *     await client.getBalance({ address: recipient })) // 1000000000000000000n (1 ETH)
    74	 *
    75	 *   // Get transaction receipt after mining
    76	 *   const receipt = await client.getTransactionReceipt({ hash: txHash })
    77	 *   console.log('Transaction mined in block:', receipt.blockNumber)
    78	 *
    79	 *   // Mine multiple blocks with custom timestamp intervals
    80	 *   const moreBlocks = await tevmMine(client, {
    81	 *     blockCount: 5,        // Mine 5 blocks
    82	 *     interval: 10          // 10 second intervals between blocks
    83	 *   })
    84	 *
    85	 *   // Block timestamps will be 10 seconds apart
    86	 *   for (const hash of moreBlocks.blockHashes) {
    87	 *     const block = await client.getBlock({ blockHash: hash })
    88	 *     console.log(`Block ${block.number}: timestamp ${block.timestamp}`)
    89	 *   }
    90	 * }
    91	 * ```
    92	 *
    93	 * @example
    94	 * ```typescript
    95	 * // Configure different mining modes when creating the client
    96	 * import { createMemoryClient, http } from 'tevm'
    97	 *
    98	 * // Auto-mining mode (mines after every transaction)
    99	 * const autoMineClient = createMemoryClient({
   100	 *   mining: { auto: true },
   101	 *   fork: { transport: http('https://mainnet.optimism.io')({}) }
   102	 * })
   103	 *
   104	 * // Interval mining mode (mines every 5 seconds)
   105	 * const intervalMineClient = createMemoryClient({
   106	 *   mining: { interval: 5000 }, // milliseconds
   107	 *   fork: { transport: http('https://mainnet.optimism.io')({}) }
   108	 * })
   109	 *
   110	 * // Manual mining mode (explicit mining required)
   111	 * const manualMineClient = createMemoryClient({
   112	 *   mining: { auto: false, interval: 0 }, // explicitly disable auto modes
   113	 *   fork: { transport: http('https://mainnet.optimism.io')({}) }
   114	 * })
   115	 * ```
   116	 *
   117	 * @see [MineParams](https://tevm.sh/reference/tevm/actions/type-aliases/mineparams/) for options reference.
   118	 * @see [MineResult](https://tevm.sh/reference/tevm/actions/type-aliases/mineresult/) for return values reference.
   119	 * @see [TEVM Actions Guide](https://tevm.sh/learn/actions/)
   120	 * @see [createMemoryClient](https://tevm.sh/reference/tevm/memory-client/functions/creatememoryclient/) for configuring mining modes.
   121	 */
   122	export const tevmMine = async (client, params) => {
