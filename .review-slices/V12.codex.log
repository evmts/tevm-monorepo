     6	/**
     7	 * Creates a {@link MemoryClient} - a fully-featured Ethereum development and testing environment.
     8	 *
     9	 * The MemoryClient is an all-in-one solution that combines:
    10	 * - A complete in-memory Ethereum Virtual Machine implementation
    11	 * - Full support for viem's wallet, test, and public actions
    12	 * - TEVM-specific actions for advanced state manipulation and tracing
    13	 * - Automatic handling of JSON-RPC requests through viem's client interface
    14	 *
    15	 * This provides an integrated environment for local Ethereum development with capabilities like:
    16	 * - Executing and debugging smart contracts without deploying to a testnet
    17	 * - Forking from existing networks with state caching for realistic testing
    18	 * - Direct manipulation of blockchain state for complex test scenarios
    19	 * - Complete control over mining and transaction processing
    20	 * - Compatibility with standard Ethereum tooling and libraries
    21	 *
    22	 * @type {import('./CreateMemoryClientFn.js').CreateMemoryClientFn}
    23	 *
    24	 * @example
    25	 * ```typescript
    26	 * import { createMemoryClient, http } from "tevm";
    27	 * import { optimism } from "tevm/common";
    28	 *
    29	 * // Create a memory client that forks from Optimism mainnet
    30	 * const client = createMemoryClient({
    31	 *   fork: {
    32	 *     transport: http("https://mainnet.optimism.io")({}),
    33	 *   },
    34	 *   common: optimism,
    35	 *   mining: { auto: true }, // Automatically mine blocks after transactions
    36	 * });
    37	 *
    38	 * // Wait for fork initialization to complete
    39	 * await client.tevmReady();
    40	 *
    41	 * // Use standard viem actions
    42	 * const blockNumber = await client.getBlockNumber();
    43	 * console.log(`Connected to Optimism block ${blockNumber}`);
    44	 *
    45	 * // Use TEVM-specific actions
    46	 * await client.tevmSetAccount({
    47	 *   address: "0x123...",
    48	 *   balance: 10000000000000000000n // 10 ETH
    49	 * });
    50	 * ```
    51	 *
    52	 * @see [Client Guide](https://tevm.sh/learn/clients/)
    53	 * @see [Actions Guide](https://tevm.sh/learn/actions/)
    54	 * @see [Reference Docs](https://tevm.sh/reference/tevm/memory-client/functions/creatememoryclient/)
    55	 * @see [Viem client docs](https://viem.sh/docs/clients/introduction)
    56	 *
    57	 * ## Key Configuration Options
    58	 *
    59	 * ```typescript
    60	 * createMemoryClient({
    61	 *   // Chain configuration (use tevm/common chains, not viem/chains)
    62	 *   common: optimism,
    63	 *
    64	 *   // Forking from an existing network
    65	 *   fork: {
    66	 *     transport: http("https://mainnet.optimism.io")({}),
    67	 *     blockTag: 'latest', // or specific block number/hash
    68	 *   },
    69	 *
    70	 *   // Mining configuration
    71	 *   mining: {
    72	 *     auto: true,      // Auto-mine after each transaction
    73	 *     interval: 5000,  // Mine blocks every 5 seconds (in ms)
    74	 *   },
    75	 *
    76	 *   // State persistence
    77	 *   persister: createSyncPersister({
    78	 *     storage: localStorage, // or any synchronous storage
    79	 *   }),
    80	 *
    81	 *   // Chain configuration
    82	 *   hardfork: 'prague', // Default and recommended
    83	 *
    84	 *   // EVM execution logging
    85	 *   logging: {
    86	 *     logLevel: 'debug',
    87	 *   },
    88	 * })
    89	 * ```
    90	 *
    91	 * ## Actions API
    92	 *
    93	 * MemoryClient combines multiple action types in a single interface:
    94	 *
    95	 * ### 1. TEVM-specific actions
    96	 * ```typescript
    97	 * // Account and state manipulation
    98	 * await client.tevmSetAccount({ address: "0x123...", balance: 100n });
    99	 * await client.tevmGetAccount({ address: "0x123..." });
   100	 *
   101	 * // Contract interactions
   102	 * await client.tevmContract({
   103	 *   abi: [...],
   104	 *   functionName: "transfer",
   105	 *   args: ["0x456...", 1000n]
   106	 * });
   107	 *
   108	 * // Contract deployment
   109	 * const result = await client.tevmDeploy({
   110	 *   abi: [...],
   111	 *   bytecode: "0x...",
   112	 *   args: ["Constructor", "Args"]
   113	 * });
   114	 *
   115	 * // Mining control
   116	 * await client.tevmMine({ blockCount: 5, interval: 10 });
   117	 *
   118	 * // State persistence
   119	 * const state = await client.tevmDumpState();
   120	 * await client.tevmLoadState(state);
   121	 * ```
   122	 *
   123	 * ### 2. Viem public actions
   124	 * ```typescript
   125	 * const balance = await client.getBalance({ address: "0x123..." });
   126	 * const blockNumber = await client.getBlockNumber();
   127	 * const code = await client.getCode({ address: "0x123..." });
   128	 * const logs = await client.getLogs({ address: "0x123..." });
   129	 * ```
   130	 *
   131	 * ### 3. Viem test actions
   132	 * ```typescript
   133	 * await client.setBalance({ address: "0x123...", value: 100n });
   134	 * await client.impersonateAccount({ address: "0x123..." });
   135	 * await client.mine({ blocks: 1 });
   136	 * await client.setStorageAt({ address, index, value });
   137	 * ```
   138	 *
   139	 * ### 4. Viem wallet actions
   140	 * ```typescript
   141	 * const hash = await client.sendTransaction({
   142	 *   from: "0x123...",
   143	 *   to: "0x456...",
   144	 *   value: 1000n
   145	 * });
   146	 * ```
   147	 *
   148	 * ## Forking Networks
   149	 *
   150	 * The MemoryClient can fork from any EVM-compatible network, creating a local copy that
   151	 * lazily loads state from the remote network as needed:
   152	 *
   153	 * ```typescript
   154	 * import { createMemoryClient, http } from "tevm";
   155	 * import { optimism } from "tevm/common";
   156	 *
   157	 * const forkedClient = createMemoryClient({
   158	 *   // Fork specification
   159	 *   fork: {
   160	 *     transport: http("https://mainnet.optimism.io")({}),
   161	 *     blockTag: '0xa6a63cd70fbbe396321ca6fe79e1b6735760c03538208b50d7e3a5dac5226435',
   162	 *   },
   163	 *   // Always specify chain configuration for optimal performance
   164	 *   common: optimism,
   165	 * });
   166	 * ```
   167	 *
   168	 * The `common` object extends the viem chain interface with EVM-specific information.
   169	 * Always use `tevm/common` chains rather than `viem/chains` when working with TEVM.
   170	 *
   171	 * ## Mining Modes
   172	 *
   173	 * TEVM supports three mining modes:
   174	 *
   175	 * ```typescript
   176	 * // 1. Manual mining (default)
   177	 * const client = createMemoryClient({ mining: { auto: false } });
   178	 * await client.sendTransaction(...);  // Transaction is pending
   179	 * await client.tevmMine();            // Now transaction is processed
   180	 *
   181	 * // 2. Auto-mining (mine after every transaction)
   182	 * const autoClient = createMemoryClient({ mining: { auto: true } });
   183	 * await autoClient.sendTransaction(...);  // Automatically mined
   184	 *
   185	 * // 3. Interval mining (mine periodically)
   186	 * const intervalClient = createMemoryClient({
   187	 *   mining: { interval: 5000 }  // Mine every 5 seconds
   188	 * });
   189	 * ```
   190	 *
   191	 * ## Server Mode
   192	 *
   193	 * TEVM can be exposed as an HTTP JSON-RPC server with `@tevm/server`:
   194	 *
   195	 * ```typescript
   196	 * import { createServer } from "tevm/server";
   197	 * import { createMemoryClient } from "tevm";
   198	 *
   199	 * const memoryClient = createMemoryClient();
   200	 * const server = createServer({
   201	 *   request: memoryClient.request,
   202	 * });
   203	 *
   204	 * server.listen(8545, () => console.log("TEVM running on port 8545"));
   205	 * ```
   206	 *
   207	 * This allows any Ethereum tool or library to connect to your TEVM instance:
   208	 *
   209	 * ```typescript
   210	 * import { createPublicClient, http } from "viem";
   211	 * import { mainnet } from "viem/chains";
   212	 *
   213	 * const publicClient = createPublicClient({
   214	 *   chain: mainnet,
   215	 *   transport: http("http://localhost:8545"),
   216	 * });
   217	 *
   218	 * console.log(await publicClient.getChainId());
   219	 * ```
   220	 *
   221	 * ## State Persistence
   222	 *
   223	 * TEVM state can be persisted between sessions with the `persister` option:
   224	 *
   225	 * ```typescript
   226	 * import { createMemoryClient } from "tevm";
   227	 * import { createSyncPersister } from "tevm/sync-storage-persister";
   228	 *
   229	 * // Browser example with localStorage
   230	 * const browserClient = createMemoryClient({
   231	 *   persister: createSyncPersister({
   232	 *     storage: localStorage,
   233	 *     key: 'my-tevm-state'
   234	 *   }),
   235	 * });
   236	 *
   237	 * // Node.js example with file system
   238	 * import { FileStorage } from "tevm/sync-storage-persister/node";
   239	 * const nodeClient = createMemoryClient({
   240	 *   persister: createSyncPersister({
   241	 *     storage: new FileStorage('./tevm-state.json'),
   242	 *   }),
   243	 * });
   244	 * ```
   245	 *
   246	 * ## Direct Solidity Imports
   247	 *
   248	 * When used with the TEVM bundler plugins, you can import Solidity files directly:
   249	 *
   250	 * ```typescript
   251	 * import { createMemoryClient } from "tevm";
   252	 * import { MyERC721 } from './MyERC721.sol';
   253	 *
   254	 * const client = createMemoryClient();
   255	 *
   256	 * // Deploy the contract
   257	 * const deployed = await client.tevmDeploy(
   258	 *   MyERC721.deploy("My NFT", "NFT")
   259	 * );
   260	 * await client.tevmMine();
   261	 *
   262	 * // Create contract instance with the deployed address
   263	 * const nft = MyERC721.withAddress(deployed.createdAddress);
   264	 *
   265	 * // Call contract methods
   266	 * await client.tevmContract({
   267	 *   ...nft.write.mint('0x123...', 1),
   268	 *   from: '0x123...',
   269	 * });
   270	 *
   271	 * await client.tevmMine();
   272	 *
   273	 * const balance = await client.tevmContract(nft.read.balanceOf('0x123...'));
   274	 * console.log(balance); // 1n
   275	 * ```
   276	 *
   277	 * This requires setting up one of the TEVM bundler plugins (vite, webpack, esbuild, etc.).
   278	 *
   279	 * ## Network Support
   280	 *
   281	 * TEVM officially supports:
   282	 * - Ethereum mainnet and testnets
   283	 * - OP Stack chains (Optimism, Base, etc.)
   284	 *
   285	 * Other EVM chains are likely to work but not officially tested. Chain configuration
   286	 * is available through `tevm/common`.
   287	 *
   288	 * ## Advanced EVM Features
   289	 *
   290	 * TEVM includes advanced EVM features, with the following enabled by default:
   291	 * - EIP-1559 Fee Market
   292	 * - EIP-4895 (Beacon chain withdrawals)
   293	 * - EIP-4844 (Blob transactions)
   294	 * - EIP-4788 (Beacon root in EVM)
   295	 *
   296	 * ## Optimizing Bundle Size
   297	 *
   298	 * For UI applications concerned with bundle size, use tree-shakeable actions with `createTevmNode()`
   299	 * and individual actions from `tevm/actions`. See the [actions API guide](https://tevm.sh/learn/actions/)
   300	 * for details.
   301	 */
   302	export const createMemoryClient = (options) => {
   303		const common = (() => {
   304			if (options?.common !== undefined) {
   305				return options.common
   306			}
   307			if (options?.fork?.transport) {
   308				// we don't want to return default chain if forking because we don't know chain id yet
   309				return undefined
   310			}
   311			// but if not forking we know common will be default
   312			return tevmDefault
   313		})()
   314		const memoryClient = createClient({
   315			...options,
   316			cacheTime: 0,
   317			transport: createTevmTransport({
   318				...options,
   319				...(common !== undefined ? { common } : {}),
   320			}),
   321			type: 'tevm',
   322			...(common !== undefined ? { chain: common } : {}),
   323		})
   324			.extend(tevmViemActions())
   325			.extend(publicActions)
   326			.extend(walletActions)
   327			.extend(testActions({ mode: 'anvil' }))
   328		return /** @type {any} */ (memoryClient)
   329	}

