    13	export const putContractStorage = (baseState) => async (address, key, value) => {
    14		if (key.length !== 32) {
    15			throw new InternalError(`Storage key must be 32 bytes long. Received ${key}`)
    16		}
    17	
    18		const account = await getAccount(baseState)(address)
    19		if (!account) {
    20			throw new InternalError(
    21				'cannot putContractStorage on non existing acccount! Consider checking if account exists first',
    22			)
    23		}
    24		baseState.caches.storage.put(address, key, stripZeros(value))
    25	}

