     1	import type { EvmType as Evm } from '@tevm/evm'
     2	import { EthjsAccount, EthjsAddress, type Hex, hexToBytes } from '@tevm/utils'
     3	import { DAOConfig } from './DAOConfig.js'
     4	
     5	/**
     6	 * Apply the DAO fork changes to the VM
     7	 */
     8	export async function applyDAOHardfork(evm: Evm) {
     9		const state = evm.stateManager
    10	
    11		/* DAO account list */
    12		const DAOAccountList = DAOConfig.DAOAccounts
    13		const DAORefundContract = DAOConfig.DAORefundContract
    14	
    15		const DAORefundContractAddress = new EthjsAddress(hexToBytes(`0x${DAORefundContract}`))
    16		if ((await state.getAccount(DAORefundContractAddress)) === undefined) {
    17			await evm.journal.putAccount(DAORefundContractAddress, new EthjsAccount() as any)
    18		}
    19		let DAORefundAccount = (await state.getAccount(DAORefundContractAddress)) as EthjsAccount | undefined
    20		if (DAORefundAccount === undefined) {
    21			DAORefundAccount = new EthjsAccount()
    22		}
    23	
    24		for (const addr of DAOAccountList) {
    25			// retrieve the account and add it to the DAO's Refund accounts' balance.
    26			const address = new EthjsAddress(hexToBytes(addr as Hex))
    27			let account = (await state.getAccount(address)) as EthjsAccount | undefined
    28			if (account === undefined) {
    29				account = new EthjsAccount()
    30			}
    31			DAORefundAccount.balance += account.balance
    32			// clear the accounts' balance
    33			account.balance = 0n
    34			await evm.journal.putAccount(address, account as any)
    35		}
    36	
    37		// finally, put the Refund Account
    38		await evm.journal.putAccount(DAORefundContractAddress, DAORefundAccount as any)
    39	}

