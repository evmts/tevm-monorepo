     1	import { bytesToHex } from 'viem'
     2	import { generateCanonicalGenesis } from './generateCannonicalGenesis.js'
     3	
     4	/**
     5	 * Error thrown if state root doesn't exist
     6	 */
     7	export class NoStateRootExistsError extends Error {
     8		/**
     9		 * @override
    10		 * @type {'NoStateRootExistsError'}
    11		 */
    12		name = 'NoStateRootExistsError'
    13		/**
    14		 * @type {'NoStateRootExistsError'}
    15		 */
    16		_tag = 'NoStateRootExistsError'
    17	}
    18	
    19	/**
    20	 * Changes the currently loaded state root
    21	 * @type {import("../state-types/index.js").StateAction<'setStateRoot'>}
    22	 */
    23	export const setStateRoot = (baseState) => async (root) => {
    24		if (
    25			baseState.caches.accounts._checkpoints > 0 ||
    26			baseState.caches.storage._checkpoints > 0 ||
    27			baseState.caches.contracts._checkpoints > 0
    28		) {
    29			throw new Error('Attempted to setStateRoot with uncommitted checkpoints')
    30		}
    31		const genesis = baseState.stateRoots.get(bytesToHex(root))
    32		// TODO we need to handle the fok case here
    33		if (!genesis) {
    34			throw new NoStateRootExistsError(`State root for ${bytesToHex(root)} does not exist`)
    35		}
    36		const oldStateRoot = baseState.getCurrentStateRoot()
    37		try {
    38			baseState.setCurrentStateRoot(bytesToHex(root))
    39			const generateFn = generateCanonicalGenesis(baseState)
    40			if (generateFn) {
    41				await generateFn(genesis)
    42			}
    43			baseState.logger.debug({ oldStateRoot, newStateRoot: root }, 'state root changed')
    44			return
    45		} catch (e) {
    46			baseState.setCurrentStateRoot(oldStateRoot)
    47			throw e
    48		}
    49	}

