     5	/**
     6	 * Adds value to the cache for the `account`
     7	 * corresponding to `address` at the provided `key`.
     8	 * Cannot be more than 32 bytes. Leading zeros are stripped.
     9	 * If it is empty or filled with zeros, deletes the value.
    10	 * @param {import('../BaseState.js').BaseState} baseState
    11	 * @returns {(address: import('@tevm/utils').EthjsAddress, key: Uint8Array, value: Uint8Array) => Promise<void>}
