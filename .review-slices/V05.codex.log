    82		if (!artifacts || Object.keys(artifacts).length === 0) {
    83			return die('No artifacts provided to generateRuntime')
    84		}
    85	
    86		// Determine the appropriate import statements based on module type and bytecode inclusion
    87		const contractType = includeBytecode ? 'script' : 'contract'
    88		const imports = importsByModuleType(tevmPackage)[contractType][moduleType]
    89	
    90		// Validate the module type
    91		if (!imports) {
    92			return die(`Unknown module type: ${moduleType}. Valid module types include 'cjs', 'dts', 'ts', and 'mjs'`)
    93		}
    94	
    95		// Generate the contract body and combine with imports
    96		return generateTevmBody(artifacts, moduleType, includeBytecode).pipe(map((body) => [imports, body].join('\n')))
    97	}

