    88					// Generate type declaration for interface-only contracts (no bytecode)
    89					return [
    90						// Define constants for ABI and name with const assertions
    91						`const _abi${contractName} = ${JSON.stringify(contract.humanReadableAbi)} as const;`,
    92						`const _name${contractName} = ${JSON.stringify(contractName)} as const;`,
