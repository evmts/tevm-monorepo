     4	
     5	/**
     6	 * Returns a new instance of the ForkStateManager with the same opts and all storage copied over.
     7	 *
     8	 * IMPORTANT: The fork cache is NOT copied but instead is shared between the original state
     9	 * and the copied state. This is intentional and safe because:
    10	 * 1. Fork cache is read-only relative to the forked blockchain state at a specific block
    11	 * 2. Sharing the cache improves performance by preventing duplicate remote fetches
    12	 * 3. It enables persistent caching of fork data across VM instances
    13	 *
    14	 * @param {import('../BaseState.js').BaseState} baseState
    15	 * @returns {() => Promise<import('../BaseState.js').BaseState>}
    16	 */
    17	export const deepCopy = (baseState) => async () => {
    18		await baseState.ready()
    19		if (
    20			baseState.caches.accounts._checkpoints > 0 ||
    21			baseState.caches.storage._checkpoints > 0 ||
    22			baseState.caches.contracts._checkpoints > 0
    23		) {
    24			throw new InternalError('Attempted to deepCopy state with uncommitted checkpoints')
    25		}
    26		const newState = createBaseState({
    27			...baseState.options,
    28			genesisState: await dumpCanonicalGenesis(baseState)(),
    29			stateRoots: new Map(baseState.stateRoots),
    30			currentStateRoot: baseState.getCurrentStateRoot(),
    31		})
    32	
    33		await newState.ready()
    34	
    35		// Share the fork cache object between instances rather than copying it
    36		// This is safe because the fork cache is conceptually read-only
    37		// relative to the forked blockchain at a specific block
    38		if (baseState.forkCache) {
    39			// Directly assign the same fork cache object
    40			newState.forkCache = baseState.forkCache
    41			baseState.logger.debug('Sharing fork cache reference between original and copied state')
    42		}
    43	
    44		baseState.logger.debug("Successfully deepCopy'd StateManager with shared fork cache")
    45		return newState
    46	}

