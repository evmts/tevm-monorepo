   224	 *
   225	 * const balance = await tevm.runContractCall(
   226	 *   MyERC721.read.balanceOf({
   227	 *     caller: address,
   228	 *   }),
   229	 * );
   230	 * console.log(balance); // 1n
   231	 * ```
   232	 */
