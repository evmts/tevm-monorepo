     3	/**
     4	 * A tree-shakeable version of the `tevmCall` action for viem.
     5	 * Executes a low-level call against the Ethereum Virtual Machine (EVM). This function provides enhanced control over the
     6	 * execution environment compared to the standard `eth_call` JSON-RPC method.
     7	 *
     8	 * By default, this is a read-only operation that doesn't modify the blockchain state after execution completes.
     9	 * However, state modifications can be enabled with the following options:
    10	 * - `addToMempool`: Add the transaction to the mempool (must be manually mined later)
    11	 * - `addToBlockchain`: Add the transaction to the mempool AND automatically mine it
    12	 * - `createTransaction`: [DEPRECATED] Use addToMempool instead
    13	 *
    14	 * Important: Tevm defaults to a manual mining mode, which means transactions are not included in the blockchain
    15	 * until you explicitly mine them. Use `addToBlockchain: true` if you want transactions to be immediately mined.
    16	 *
    17	 * The function supports advanced EVM features such as:
    18	 * - Account impersonation (executing as any address without requiring private keys)
    19	 * - Detailed execution tracing with step-by-step opcode inspection
    20	 * - Gas limit and price customization
    21	 * - Balance/nonce checks can be skipped for testing scenarios
    22	 * - Full revert reason messages and traces
    23	 *
    24	 * @example
    25	 * ```typescript
    26	 * import { createClient, http } from 'viem'
    27	 * import { tevmCall } from 'tevm/actions'
    28	 * import { optimism } from 'tevm/common'
    29	 * import { createTevmTransport } from 'tevm'
    30	 *
    31	 * const client = createClient({
    32	 *   transport: createTevmTransport({
    33	 *     fork: { transport: http('https://mainnet.optimism.io')({}) }
    34	 *   }),
    35	 *   chain: optimism,
    36	 * })
    37	 *
    38	 * async function example() {
    39	 *   // Execute a read-only call to a contract
    40	 *   const readResult = await tevmCall(client, {
    41	 *     to: '0x123...',             // Target contract address
    42	 *     data: '0x123...',           // Encoded function call (e.g. from encodeFunctionData)
    43	 *     from: '0x123...',           // Sender address (can be any address when impersonating)
    44	 *     gas: 1000000,               // Gas limit for the call
    45	 *     gasPrice: 1n,               // Gas price in wei
    46	 *     skipBalance: true,          // Skip balance checks (useful for testing)
    47	 *     onStep: (step, next) => {   // Optional: trace EVM execution steps
    48	 *       console.log(`Executing ${step.opcode.name} at PC=${step.pc}`);
    49	 *       next();
    50	 *     }
    51	 *   })
    52	 *
    53	 *   // Submit a transaction to the mempool (requires manual mining)
    54	 *   const txResult = await tevmCall(client, {
    55	 *     to: '0x456...',
