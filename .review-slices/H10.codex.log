    17	 * @returns {Promise<void>}
    18	 */
    19	export const addPredeploy = async ({ vm, nonce, balance, storageRoot, deployedBytecode, address }) => {
    20		const ethjsAddress = createAddress(address)
    21		await vm.stateManager.putAccount(
    22			ethjsAddress,
    23			createAccount({
    24				...(nonce !== undefined ? { nonce } : {}),
