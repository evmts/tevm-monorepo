     5	/**
     6	 * Request handler for JSON-RPC requests to Tevm.
     7	 *
     8	 * This implementation of the Tevm requestProcedure spec
     9	 * implements it via the ethereumjs VM.
    10	 *
    11	 * @param {import('@tevm/node').TevmNode} client
    12	 * @returns {import('./tevm-request-handler/TevmJsonRpcRequestHandler.js').TevmJsonRpcRequestHandler}
    13	 * @example
    14	 * ```typescript
    15	 * const blockNumberResponse = await tevm.request({
    16	 *  method: 'eth_blockNumber',
    17	 *  params: []
    18	 *  id: 1
    19	 *  jsonrpc: '2.0'
    20	 * })
    21	 * const accountResponse = await tevm.request({
    22	 *  method: 'tevm_getAccount',
    23	 *  params: [{address: '0x123...'}]
    24	 *  id: 1
    25	 *  jsonrpc: '2.0'
    26	 * })
    27	 * ```
    28	 * @see {@link createHandlers} where handlers are defined
    29	 */
    30	export const requestProcedure = (client) => {
    31		const handlers = createHandlers(client)
    32		return async (request) => {
    33			const method = /** @type {string} */ (request.method)
    34			const isLightPreReadyAllowed =
    35				client.consensus?.mode === 'light-client' &&
    36				(method === 'eth_chainId' || method === 'tevm_lightSyncStatus' || method === 'zevm_lightSyncStatus')
    37			if (!isLightPreReadyAllowed) {
    38				await client.ready()
    39			}
    40			client.logger.debug({ request }, 'JSON-RPC request received')
    41			if (!(method in handlers)) {
    42				if (isBlockedMethod(method)) {
    43					const err = new MethodNotSupportedError(
    44						`UnsupportedMethodError: Method ${/** @type any*/ (request).method} is blocked by scope`,
    45					)
    46					return /** @type {any}*/ ({
    47						id: /** @type any*/ (request).id ?? null,
    48						method: /** @type any*/ (request).method,
    49						jsonrpc: '2.0',
    50						error: {
    51							code: err.code,
    52							message: err.message,
    53						},
    54					})
    55				}
    56				if (rpcMethodStatusByMethod.get(method) === 'missing') {
    57					const err = new MethodNotFoundError(
    58						`UnimplementedMethodError: Method ${/** @type any*/ (request).method} is typed but not yet implemented`,
    59					)
    60					return /** @type {any}*/ ({
    61						id: /** @type any*/ (request).id ?? null,
    62						method: /** @type any*/ (request).method,
    63						jsonrpc: '2.0',
    64						error: {
    65							code: err.code,
    66							message: err.message,
    67						},
    68					})
    69				}
    70				const err = new MethodNotFoundError(`UnsupportedMethodError: Unknown method ${/**@type any*/ (request).method}`)
    71				return /** @type {any}*/ ({
    72					id: /** @type any*/ (request).id ?? null,
    73					method: /** @type any*/ (request).method,
    74					jsonrpc: '2.0',
    75					error: {
    76						code: err.code,
    77						message: err.message,
    78					},
    79				})
    80			}
    81			return /** @type {(request: any) => any} */ (handlers[/** @type {keyof typeof handlers} */ (method)])(request)
    82		}
    83	}

