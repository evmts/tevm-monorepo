	const blockHashAfterForking = '0x246f4ec5f0b5d25129b3941c4e74338fecb4fa3e5523ee436d97ef7e17ecd135'

	it('should fetch a block by number', async () => {
		const transport = transports.optimism
		const common = optimism.copy()

