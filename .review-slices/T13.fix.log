			if (jsonRpcBlock.hash) {
				chain.blocks.set(jsonRpcBlock.hash, block)
			}
		} else {
			await putBlock(chain)(
				options.genesisBlock ?? createGenesisBlock(options.genesisStateRoot ?? KECCAK256_RLP, options.common),
			)
		}
