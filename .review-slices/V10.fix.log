+	const candidates = [fileName, path.resolve(cwd, fileName)]
+	for (const candidate of candidates) {
+		try {
+			const version = lsHost.getScriptVersion?.(candidate)
+			if (version !== undefined) {
+				return version
+			}
+		} catch (_e) {
+			// Fall through to the next candidate.
+		}
+	}
+	return undefined
+}
