			}
			return fs.readFile(dtsPath, 'utf8')
		},

		/**
		 * Synchronously writes ES module (.mjs) file to the cache
		 * @param {string} entryModuleId - Path to the Solidity file
		 * @param {string} mjsFile - Content of the ES module file
