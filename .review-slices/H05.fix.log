   118	 *   const updatedState = new Map(currentState)
   119	 *
   120	 *   // Apply each change from the state diff
   121	 *   for (const [stem, changes] of Object.entries(diff.stateDiff)) {
   122	 *     for (const [key, value] of Object.entries(changes)) {
   123	 *       const fullKey = stem + key
   124	 *       if (value === null) {
   125	 *         updatedState.delete(fullKey)
   126	 *       } else {
   127	 *         updatedState.set(fullKey, value)
   128	 *       }
   129	 *     }
   130	 *   }
   131	 *
   132	 *   return updatedState
   133	 * }
   134	 * ```
