    92	
    93		/**
    94		 * Static constructor to create a block header from a RLP-serialized header
    95		 *
    96		 * @param serializedHeaderData
    97		 * @param opts
    98		 */
    99		public static fromRLPSerializedHeader(serializedHeaderData: Uint8Array, opts: BlockOptions) {
   100			const values = Rlp.decode(serializedHeaderData)
   101			if (!Array.isArray(values)) {
   102				throw new Error('Invalid serialized header input. Must be array')
   103			}
   104			return BlockHeader.fromValuesArray(values as Uint8Array[], opts)
   105		}
   106	
   107		/**
   108		 * Static constructor to create a block header from an array of Bytes values
   109		 *
   110		 * @param values
   111		 * @param opts
   112		 */
   113		public static fromValuesArray(values: BlockHeaderBytes, opts: BlockOptions) {
   114			const headerData = valuesArrayToHeaderData(values)
   115			const { baseFeePerGas, withdrawalsRoot, excessBlobGas, blobGasUsed, parentBeaconBlockRoot, requestsRoot } =
   116				headerData
   117			const header = BlockHeader.fromHeaderData(headerData, opts)
   118			if (header.common.ethjsCommon.isActivatedEIP(1559) && baseFeePerGas === undefined) {
   119				throw new Error('invalid header. baseFeePerGas should be provided')
   120			}
   121			if (header.common.ethjsCommon.isActivatedEIP(4895) && withdrawalsRoot === undefined) {
   122				throw new Error('invalid header. withdrawalsRoot should be provided')
   123			}
   124			if (header.common.ethjsCommon.isActivatedEIP(4844)) {
   125				if (excessBlobGas === undefined) {
   126					throw new Error('invalid header. excessBlobGas should be provided')
   127				}
   128				if (blobGasUsed === undefined) {
   129					throw new Error('invalid header. blobGasUsed should be provided')
   130				}
   131			}
   132			if (header.common.ethjsCommon.isActivatedEIP(4788) && parentBeaconBlockRoot === undefined) {
   133				throw new Error('invalid header. parentBeaconBlockRoot should be provided')
   134			}
