    33	
    34	/// This function scans the provided code for import statements and resolves each import
    35	/// path to an absolute file path, taking into account remappings and library paths.
    36	///
    37	/// # Arguments
    38	/// * `absolute_path` - The absolute path of the file containing the imports
    39	/// * `code` - The source code to scan for imports
    40	/// * `remappings` - Map of import path prefixes to replacement values
    41	/// * `libs` - Additional library paths to search for imports
    42	///
    43	/// # Returns
    44	/// * `Ok(Vec<PathBuf>)` - all imports
    45	/// * `Err(ResolveImportsError)` - either a parse failure or aggregation of resolution errors
    46	pub fn resolve_imports(
    47	    context_path: &Path,
    48	    code: &str,
    49	    cfg: &Config,
    50	) -> Result<Vec<PathBuf>, Vec<ResolveImportsError>> {
    51	    let mut imports = Vec::new();
    52	    let mut unique_imports = std::collections::HashSet::new();
    53	    let mut errors = vec![];
    54	
    55	    let arena = solar::ast::Arena::new();
    56	
    57	    let _ = SOLAR_SESSION
    58	        .enter(|| -> Result<_, ErrorGuaranteed> {
    59	            let mut parser = Parser::from_source_code(
    60	                &SOLAR_SESSION,
    61	                &arena,
    62	                FileName::Real(context_path.to_path_buf()),
    63	                code.to_string(),
    64	            )?;
    65	            let ast = parser.parse_file().map_err(|err| err.emit())?;
    66	            for item in ast.items.iter() {
    67	                if let solar::ast::ItemKind::Import(import_dir) = &item.kind {
    68	                    match resolve_import_path(
    69	                        context_path.to_path_buf(),
    70	                        import_dir.path.value.as_str(),
    71	                        cfg,
    72	                    ) {
    73	                        Ok(p) => {
    74	                            // Only add the import if it hasn't been seen before
    75	                            let path_str = p.to_string_lossy().to_string();
    76	                            if unique_imports.insert(path_str) {
    77	                                imports.push(p);
    78	                            }
    79	                        },
    80	                        Err(cause) => errors.push(ResolveImportsError::PathResolutionError {
    81	                            context_path: context_path.to_path_buf(),
    82	                            cause,
    83	                        }),
    84	                    };
    85	                }
    86	            }
    87	            Ok(())
    88	        })
    89	        .map_err(|cause| {
    90	            errors.push(ResolveImportsError::ParseError {
    91	                context_path: context_path.to_path_buf(),
    92	                cause,
    93	            })
    94	        });
    95	
    96	    // If we have errors or if we didn't find any imports when we expected to,
    97	    // return an error
    98	    if !errors.is_empty() || (imports.is_empty() && code.contains("import ")) {
    99	        // If we have no explicit errors but failed to find imports that exist in the code,
   100	        // create a generic error
   101	        if errors.is_empty() && imports.is_empty() && code.contains("import ") {
   102	            errors.push(ResolveImportsError::PathResolutionError {
   103	                context_path: context_path.to_path_buf(),
   104	                cause: crate::resolve_import_path::ResolveImportPathError::NotFoundAbsolutePath {
   105	                    import_path: "No imports could be resolved".to_string(),
   106	                    causes: vec![],
   107	                },
   108	            });
   109	        }
   110	        return Err(errors);
   111	    }
   112	    Ok(imports)
   113	}
