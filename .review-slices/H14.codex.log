    36	/// Creates a module map by processing a source file and all its imports recursively with maximum concurrency
    37	///
    38	/// This function processes a source file and all of its imported dependencies concurrently,
    39	/// creating a map of absolute file paths to ModuleInfo objects containing the source code
    40	/// and list of imported dependencies for each module.
    41	///
    42	/// # Arguments
    43	/// * `absolute_path` - The absolute path of the entry file to process
    44	/// * `raw_code` - The source code of the entry file
    45	/// * `remappings` - Map of import path prefixes to replacement values
    46	/// * `libs` - Additional library paths to search for imports
    47	///
    48	/// # Returns
    49	/// * `Ok(HashMap<String, ModuleInfo>)` - Map of absolute file paths to module information
    50	/// * `Err(Vec<ModuleResolutionError>)` - Collection of errors encountered during processing
    51	pub async fn module_factory(
    52	    entrypoint_path: PathBuf,
    53	    raw_code: &str,
    54	    cfg: Config,
    55	) -> Result<HashMap<String, ModuleInfo>, Vec<ResolveImportsError>> {
    56	    let state = State::new(get_max_concurrent_reads());
    57	
    58	    let entrypoint_id = process_module(
    59	        &entrypoint_path.to_path_buf(),
    60	        Some(raw_code.to_string()),
    61	        &cfg,
    62	        state.clone(),
    63	        state.sem.clone().acquire_owned().await.unwrap(),
    64	    )
    65	    .await?;
    66	
    67	    if state.graph.lock().await.get(&entrypoint_id).expect(
    68	        "UnexpectedError: The entrypoint never got inserted. This indicates a bug in the program.",
    69	    ).imported_ids.is_empty() {
    70	        let graph = state.graph.lock().await.clone();
    71	        return Ok(graph);
    72	    }
    73	
    74	    let mut in_flight = FuturesUnordered::new();
    75	
    76	    for entrypoint_import in state.graph.lock().await.get(&entrypoint_id).expect(
    77	        "UnexpectedError: The entrypoint never got inserted. This indicates a bug in the program.",
    78	    ).imported_ids.iter() {
    79	        let state2 = state.clone();
    80	        let permit = state2.sem.clone().acquire_owned().await.unwrap();
    81	        let cfg2 = cfg.clone();
    82	        let entrypoint_import2 = entrypoint_import.to_path_buf();
    83	        in_flight.push(task::spawn(async move {
    84	            process_module(&entrypoint_import2, None, &cfg2, state2.clone(), permit).await
    85	        }));
    86	    }
    87	
    88	    while let Some(joined) = in_flight.next().await {
    89	        match joined {
    90	            Ok(Ok(next_module_id)) => {
    91	                // Get imported_ids safely with proper borrowing
    92	                let imported_ids = {
    93	                    let graph = state.graph.lock().await;
    94	                    match graph.get(&next_module_id) {
    95	                        Some(info) => info.imported_ids.clone(),
    96	                        None => {
    97	                            // Module wasn't inserted for some reason
    98	                            println!("Warning: Module {} not found in graph", next_module_id);
    99	                            continue;
   100	                        }
   101	                    }
   102	                };
   103	
   104	                for imp in imported_ids.iter() {
   105	                    let imp2 = imp.to_path_buf();
   106	                    let mut seen = state.seen.lock().await;
   107	                    if !seen.insert(imp2.to_string_lossy().to_string()) {
   108	                        continue;
   109	                    }
   110	                    drop(seen);
   111	                    let state2 = state.clone();
   112	                    let cfg2 = cfg.clone();
   113	                    let permit = state2.sem.clone().acquire_owned().await.unwrap();
   114	                    in_flight.push(task::spawn(async move {
   115	                        process_module(&imp2, None, &cfg2, state2, permit).await
   116	                    }))
   117	                }
   118	            }
   119	            Ok(Err(err)) => {
   120	                return Err(vec![ResolveImportsError::PathResolutionError {
   121	                    context_path: PathBuf::from("Unknown path"),
   122	                    cause:
   123	                        crate::resolve_import_path::ResolveImportPathError::NotFoundAbsolutePath {
   124	                            import_path: format!("Process module error: {:?}", err),
   125	                            causes: vec![],
   126	                        },
   127	                }]);
   128	            }
   129	            Err(err) => {
   130	                return Err(vec![ResolveImportsError::PathResolutionError {
   131	                    context_path: PathBuf::from("Unknown path"),
   132	                    cause:
   133	                        crate::resolve_import_path::ResolveImportPathError::NotFoundAbsolutePath {
