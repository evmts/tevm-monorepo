    71	 *     'ts',              // Generate TypeScript code
    72	 *     true,              // Include bytecode
    73	 *     '@tevm/contract'   // Import from this package
    74	 *   )
    75	 * )
    76	 *
    77	 * console.log(code)
    78	 * ```
    79	 */
    80	export const generateRuntime = (artifacts, moduleType, includeBytecode, tevmPackage) => {
    81		// Validate that artifacts exist
    82		if (!artifacts || Object.keys(artifacts).length === 0) {
    83			return die('No artifacts provided to generateRuntime')
    84		}
    85	
    86		// Determine the appropriate import statements based on module type and bytecode inclusion
