    20	
    21	/// Resolves an import path to an absolute file path
    22	///
    23	/// # Arguments
    24	/// * `context_path` - The absolute path of the file containing the import
    25	/// * `import_path` - The raw import path to resolve
    26	/// * `cfg` - Configuration containing remappings and library paths
    27	///
    28	/// # Returns
    29	/// * `Ok(PathBuf)` - The resolved absolute path
    30	/// * `Err(ResolveImportPathError)` - Error encountered during resolution
    31	pub fn resolve_import_path(
    32	    context_path: PathBuf,
    33	    import_path: &str,
    34	    cfg: &Config,
    35	) -> Result<PathBuf, ResolveImportPathError> {
    36	    // Extract the directory from the file path
    37	    let dir_path = if context_path.is_file() || !context_path.exists() {
    38	        context_path.parent().unwrap_or(&context_path).to_path_buf()
    39	    } else {
    40	        context_path.clone()
    41	    };
    42	
    43	    // Try resolving relative path
    44	    let imp_path = Path::new(import_path);
    45	    if let Some(c) = imp_path.components().next() {
    46	        if matches!(c, Component::CurDir | Component::ParentDir) {
    47	            let joined = dir_path.join(&imp_path);
    48	            let mut normalized = PathBuf::new();
    49	            for comp in joined.components() {
    50	                match comp {
    51	                    Component::CurDir => { /* skip `.` */ }
    52	                    Component::ParentDir => {
    53	                        normalized.pop();
    54	                    }
    55	                    Component::RootDir => {
    56	                        normalized.push(PathBuf::from(std::path::MAIN_SEPARATOR.to_string()));
    57	                    }
    58	                    Component::Prefix(prefix) => {
    59	                        normalized.push(prefix.as_os_str());
    60	                    }
    61	                    Component::Normal(os_str) => {
    62	                        normalized.push(os_str);
    63	                    }
    64	                }
    65	            }
    66	            return Ok(normalized);
    67	        }
    68	    }
    69	
    70	    // Try resolving remappings
    71	    for (k, v) in cfg.remappings.iter() {
    72	        if let Some(rest) = import_path.strip_prefix(k) {
    73	            return Ok(PathBuf::from(v).join(rest));
    74	        }
    75	    }
    76	
    77	    // Finally try using node.js resolution
    78	    let mut causes = Vec::with_capacity(cfg.libs.len() + 1);
    79	    for lib in once(dir_path).chain(cfg.libs.to_vec()) {
    80	        match resolve_from(import_path, lib) {
    81	            Ok(res) => return Ok(res),
    82	            Err(err) => causes.push(err),
    83	            // Finally try using node.js resolution
    84	        };
    85	    }
    86	
    87	    Err(ResolveImportPathError::NotFoundAbsolutePath {
    88	        import_path: import_path.to_string(),
    89	        causes,
    90	    })
    91	}
