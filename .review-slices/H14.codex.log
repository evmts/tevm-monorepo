     9	/// Read a module (or use provided code), resolve its imports, insert into `ctx.graph`,
    10	/// and return the list of child imports.
    11	pub async fn process_module(
    12	    path: &PathBuf,
    13	    code_opt: Option<String>,
    14	    cfg: &Config,
    15	    state: State,
    16	    _permit: OwnedSemaphorePermit,
    17	) -> Result<String, Vec<ResolveImportsError>> {
    18	    let id = path.to_string_lossy().to_string();
    19	    let mut seen = state.seen.lock().await;
    20	    if !seen.insert(id.clone()) {
    21	        return Ok(id);
    22	    };
    23	    drop(seen);
    24	    let code = if let Some(c) = code_opt {
    25	        c
    26	    } else {
    27	        fs::read_to_string(&path)
    28	            .await
    29	            .map_err(|err| vec![ResolveImportsError::ReadError {
    30	                context_path: path.clone(),
    31	                message: err.to_string(),
    32	            }])?
    33	    };
    34	
    35	    state.graph.lock().await.insert(
    36	        path.to_string_lossy().into_owned(),
    37	        ModuleInfo {
    38	            imported_ids: resolve_imports(&path, &code, cfg)?,
    39	            code,
    40	        },
    41	    );
    42	    Ok(id)
    43	}

