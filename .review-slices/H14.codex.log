    11	fn get_max_concurrent_reads() -> usize {
    12	    // 1) Base it on CPU count
    13	    let cores = num_cpus::get();
    14	
    15	    // 2) On Unix, also factor in the file descriptor limit
    16	    #[cfg(unix)]
    17	    {
    18	        // Safety: calling libc getrlimit is safe if arguments are valid
    19	        unsafe {
    20	            let mut lim = libc::rlimit {
    21	                rlim_cur: 0,
    22	                rlim_max: 0,
    23	            };
    24	            if libc::getrlimit(libc::RLIMIT_NOFILE, &mut lim) == 0 {
    25	                let fd_limit = lim.rlim_cur as usize;
    26	                // compute 2×cores, cap at fd_limit/4, ensure at least 2
    27	                return std::cmp::min(cores * 2, fd_limit / 4).max(2);
    28	            }
    29	        }
    30	    }
    31	
    32	    // 3) Fallback for Unix if getrlimit failed, or non-Unix platforms
    33	    (cores * 2).max(2)
    34	}
