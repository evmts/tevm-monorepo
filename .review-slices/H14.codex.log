   697	            ("src/main.sol", "import 'remapped/module.sol';\nimport 'mylib/BaseContract.sol';\n// Main contract"),
   698	            ("lib/external/module.sol", "// External module via remapping"),
   699	            ("lib/mylib/BaseContract.sol", "// Base contract via remapping")
   700	        ]).unwrap();
   701	
   702	        // Print directory structure for debugging
   703	        println!("Root directory: {}", root_dir.display());
   704	        println!(
   705	            "Main file exists: {}",
   706	            root_dir.join("src/main.sol").exists()
   707	        );
   708	        println!(
   709	            "External module exists: {}",
   710	            root_dir.join("lib/external/module.sol").exists()
   711	        );
   712	        println!(
   713	            "Base contract exists: {}",
   714	            root_dir.join("lib/mylib/BaseContract.sol").exists()
   715	        );
   716	
   717	        // Read absolute path with canonical form
   718	        let absolute_path = std::fs::canonicalize(root_dir.join("src/main.sol")).unwrap();
   719	        let raw_code =
   720	            "import 'remapped/module.sol';\nimport 'mylib/BaseContract.sol';\n// Main contract";
   721	
   722	        // Setup multiple remappings
   723	        let mut remappings = HashMap::new();
   724	        remappings.insert(
   725	            "remapped/".to_string(),
   726	            root_dir.join("lib/external/").display().to_string(),
   727	        );
   728	        remappings.insert(
   729	            "mylib/".to_string(),
   730	            root_dir.join("lib/mylib/").display().to_string(),
   731	        );
   732	
   733	        // Convert remappings to the expected format
   734	        let remappings_vec: Vec<(String, String)> =
   735	            remappings.into_iter().map(|(k, v)| (k, v)).collect();
   736	
   737	        // Run the test
   738	        let result = module_factory(
   739	            absolute_path.clone(),
   740	            raw_code,
