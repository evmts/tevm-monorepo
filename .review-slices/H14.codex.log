    83	            .map(|abi| serde_json::to_value(abi).unwrap_or(serde_json::Value::Array(vec![])))
    84	            .unwrap_or(serde_json::Value::Array(vec![]));
    85	            
    86	        let tevm_contract = TevmContract {
    87	            bytecode: bytecode_hex,
    88	            deployed_bytecode: deployed_bytecode_hex,
    89	            name: name.clone(),
    90	            human_readable_abi: format_abi(&abi_value),
    91	        };
    92	        tevm_contracts.insert(name, tevm_contract);
    93	    }
    94	
    95	    if tevm_contracts.is_empty() {
    96	        return "// No contracts found in the solc output".to_string();
    97	    }
    98	
    99	    // Create a JSON string version of all contracts
   100	    let contracts_json = serde_json::to_string_pretty(&tevm_contracts).unwrap_or_default();
   101	
   102	    // Generate code based on module type
   103	    match module_type {
   104	        ModuleType::Cjs => {
   105	            let mut output = format!("const {{ createContract }} = require('{}');\n\n", package);
   106	
   107	            for (name, contract) in &tevm_contracts {
   108	                let contract_json = serde_json::to_string_pretty(contract).unwrap_or_default();
   109	                output.push_str(&format!("const _{0} = {1};\n\n", name, contract_json));
   110	                output.push_str(&format!("/**\n * Contract implementation for {0}\n * @see [contract docs](https://tevm.sh/learn/contracts/) for more documentation\n */\n", name));
   111	                output.push_str(&format!(
   112	                    "module.exports.{0} = createContract(_{0});\n\n",
   113	                    name
   114	                ));
   115	            }
   116	
   117	            output.push_str(&format!("module.exports.artifacts = {};\n", contracts_json));
   118	            output
   119	        }
   120	
   121	        ModuleType::Ts => {
   122	            let mut output = format!("import {{ createContract }} from '{}';\n\n", package);
   123	
   124	            for (name, contract) in &tevm_contracts {
   125	                let contract_json = serde_json::to_string_pretty(contract).unwrap_or_default();
   126	                output.push_str(&format!(
   127	                    "const _{0} = {1} as const;\n\n",
   128	                    name, contract_json
   129	                ));
   130	                output.push_str(&format!("/**\n * Contract implementation for {0}\n * @see [contract docs](https://tevm.sh/learn/contracts/) for more documentation\n */\n", name));
   131	                output.push_str(&format!(
   132	                    "export const {0} = createContract(_{0});\n\n",
   133	                    name
   134	                ));
   135	            }
   136	
   137	            output.push_str(&format!("export const artifacts = {};\n", contracts_json));
   138	            output
   139	        }
   140	
   141	        ModuleType::Mjs => {
   142	            let mut output = format!("import {{ createContract }} from '{}';\n\n", package);
   143	
   144	            for (name, contract) in &tevm_contracts {
   145	                let contract_json = serde_json::to_string_pretty(contract).unwrap_or_default();
   146	                output.push_str(&format!("const _{0} = {1};\n\n", name, contract_json));
   147	                output.push_str(&format!("/**\n * Contract implementation for {0}\n * @see [contract docs](https://tevm.sh/learn/contracts/) for more documentation\n */\n", name));
   148	                output.push_str(&format!(
   149	                    "export const {0} = createContract(_{0});\n\n",
   150	                    name
   151	                ));
   152	            }
   153	
   154	            output.push_str(&format!("export const artifacts = {};\n", contracts_json));
   155	            output
   156	        }
   157	
   158	        ModuleType::Dts => {
   159	            let mut output = format!("import type {{ Contract }} from '{}';\n\n", package);
   160	
   161	            for (name, _) in &tevm_contracts {
   162	                output.push_str(&format!(
   163	                    "// Contract name type\ndeclare const _name{0}: \"{0}\";\n",
   164	                    name
   165	                ));
   166	                output.push_str(&format!(
   167	                    "// ABI type\ndeclare const _abi{0}: any[];\n\n",
   168	                    name
   169	                ));
   170	                output.push_str(&format!(
   171	                    "/**\n * Contract type definition for {0}\n * @see [contract docs](https://tevm.sh/learn/contracts/) for more documentation\n */\n", name
   172	                ));
   173	                output.push_str(&format!(
   174	                    "export const {0}: Contract<\n  typeof _name{0},\n  typeof _abi{0},\n  undefined,\n  `0x${{string}}`,\n  `0x${{string}}`,\n  undefined\n>;\n\n",
   175	                    name
   176	                ));
   177	            }
   178	
   179	            output.push_str("export const artifacts: Record<string, any>;\n");
   180	            output
   181	        }
   182	    }
   183	}
