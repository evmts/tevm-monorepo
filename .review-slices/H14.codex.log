    17	#[derive(Debug)]
    18	pub enum ResolveImportsError {
    19	    /// Error that occurred during parsing of the source file
    20	    ParseError {
    21	        context_path: PathBuf,
    22	        cause: ErrorGuaranteed,
    23	    },
    24	    PathResolutionError {
    25	        context_path: PathBuf,
    26	        cause: ResolveImportPathError,
    27	    },
    28	    ReadError {
    29	        context_path: PathBuf,
    30	        message: String,
