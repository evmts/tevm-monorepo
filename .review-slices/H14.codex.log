   628	// NAPI bindings for JS/TS interop
   629	
   630	/// Generate the JavaScript runtime code for a Solidity contract
   631	/// Now using Foundry Contract type
   632	#[napi]
   633	pub fn generate_runtime_js(
   634	    contracts_json: String,
   635	    module_type: String,
   636	    use_scoped_package: bool,
   637	) -> napi::Result<String> {
   638	    // Parse contracts from JSON into foundry Contract format
   639	    let contracts: Vec<(String, Contract)> = serde_json::from_str(&contracts_json)?;
   640	
   641	    // Parse module type
   642	    let module_type = match module_type.to_lowercase().as_str() {
   643	        "ts" => ModuleType::Ts,
   644	        "cjs" => ModuleType::Cjs,
   645	        "mjs" => ModuleType::Mjs,
   646	        "dts" => ModuleType::Dts,
   647	        _ => {
   648	            return Err(napi::Error::new(
   649	                napi::Status::InvalidArg,
   650	                format!("Invalid module type: {}", module_type),
   651	            ))
   652	        }
   653	    };
   654	
   655	    // Determine package type
   656	    let contract_package = if use_scoped_package {
   657	        ContractPackage::TevmContractScoped
   658	    } else {
   659	        ContractPackage::TevmContract
   660	    };
   661	
   662	    // Generate the runtime code with the new type
   663	    let result = generate_runtime(contracts, module_type, contract_package);
   664	
   665	    Ok(result)
   666	}

