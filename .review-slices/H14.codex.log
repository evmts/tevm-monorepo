   190	    /// Helper function to create a vector of foundry-style Contract objects for testing
   191	    fn create_test_contracts(
   192	        contracts_data: Vec<(String, serde_json::Value, String, String)>,
   193	    ) -> Vec<(String, Contract)> {
   194	        let mut contracts = Vec::new();
   195	
   196	        for (name, abi, _bytecode, _deployed_bytecode) in contracts_data {
   197	            // Convert serde_json::Value to the necessary ABI format
   198	            // Create a Contract with all required fields using serde_json to directly
   199	            // serialize/deserialize to avoid compatibility issues
   200	            
   201	            // First, create the contract JSON structure with the provided ABI
   202	            let contract_json = serde_json::json!({
   203	                "abi": abi,
   204	                "userdoc": {},
   205	                "devdoc": {},
   206	                "evm": null,
   207	                "ewasm": null,
   208	                "ir": null,
   209	                "ir_optimized": null,
   210	                "metadata": null,
   211	                "storage_layout": null
   212	            });
   213	            
   214	            // Deserialize into a Contract
   215	            let contract: Contract = serde_json::from_value(contract_json).unwrap_or_else(|_| {
   216	                // If the direct conversion fails, create a minimal contract manually
   217	                // This is a backup approach with just empty/default values
   218	                let json_obj = serde_json::Map::new();
   219	                let contract: Contract = serde_json::from_value(serde_json::Value::Object(json_obj))
   220	                    .expect("Failed to create empty contract");
   221	                contract
   222	            });
   223	            
   224	            contracts.push((name, contract));
   225	        }
   226	
   227	        contracts
   228	    }
