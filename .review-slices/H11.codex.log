   308	import { SimpleContract } from '@tevm/contract'
   309	import { encodeFunctionData, toBytes } from '@tevm/utils'
   310	import { describe, expect, it } from 'vitest'
   311	import { defineCall } from './defineCall.js'
   312	
   313	describe(defineCall.name, () => {
   314		it('should define a precompile', async () => {
   315			let value = 20n
   316			const call = defineCall(SimpleContract.abi, {
   317				get: async () => ({ returnValue: value, executionGasUsed: 0n }),
   318				set: async ({ args }) => {
   319					value = args[0]
   320					return { returnValue: undefined, executionGasUsed: 0n }
   321				},
   322			})
   323			expect(
   324				await call({
   325					gasLimit: 1n,
   326					data: encodeFunctionData(SimpleContract.read.get()),
   327				}),
   328			).toEqual({ returnValue: toBytes(value, { size: 32 }), executionGasUsed: 0n })
   329			expect(
   330				await call({
   331					gasLimit: 1n,
   332					data: encodeFunctionData(SimpleContract.write.set(10n)),
   333				}),
   334			).toEqual({ returnValue: new Uint8Array(), executionGasUsed: 0n })
   335			expect(
   336				await call({
   337					gasLimit: 1n,
   338					data: encodeFunctionData(SimpleContract.read.get()),
   339				}),
   340			).toEqual({ returnValue: toBytes(10n, { size: 32 }), executionGasUsed: 0n })
   341		})
   342	
   343		it('should correctly process logs', async () => {
   344			let value = 0n
   345			const call = defineCall(SimpleContract.abi, {
   346				set: async ({ args }) => {
   347					value = args[0]
   348					return {
   349						returnValue: undefined,
   350						executionGasUsed: 0n,
   351						logs: [
   352							{
   353								eventName: 'ValueSet',
   354								address: '0x1234567890123456789012345678901234567890',
   355								args: [20n, 30n],
   356							},
   357						],
   358					}
   359				},
   360				get: async () => ({ returnValue: value, executionGasUsed: 0n }),
   361			})
   362			expect(
   363				await call({
   364					gasLimit: 1n,
   365					data: encodeFunctionData(SimpleContract.read.get()),
   366				}),
   367			).toMatchSnapshot()
   368			expect(
   369				await call({
   370					gasLimit: 1n,
   371					data: encodeFunctionData(SimpleContract.write.set(5n)),
   372				}),
   373			).toMatchSnapshot()
   374			expect(
   375				await call({
   376					gasLimit: 1n,
   377					data: encodeFunctionData(SimpleContract.read.get()),
   378				}),
   379			).toMatchSnapshot()
   380		})
   381	
   382		it('should handle errors in the catch block', async () => {
   383			const call = defineCall(SimpleContract.abi, {
   384				get: async () => {
   385					throw new Error('Test Error')
   386				},
   387				set: async () => ({ returnValue: undefined, executionGasUsed: 0n }),
   388			})
   389			const result = await call({
   390				gasLimit: 1n,
   391				data: encodeFunctionData(SimpleContract.read.get()),
   392			})
   393			expect(result.executionGasUsed).toBe(BigInt(0))
   394			expect(result.returnValue).toEqual(new Uint8Array())
   395			expect(result.exceptionError).toBeDefined()
   396			expect(result.exceptionError).toMatchSnapshot()
   397		})
   398	})
   399	import { createContract } from '@tevm/contract'
