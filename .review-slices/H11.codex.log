   219			} as const
   220	
   221			const result = logToEthjsLog(abiWithArray, log)
   222	
   223			expect(result[1].length).toBe(2) // Event signature + 1 indexed parameter
   224			expect(result[2].length).toBeGreaterThan(0) // Non-empty data for array parameter
   225		})
   226	
   227		it('should handle events with bytes and string parameters', () => {
