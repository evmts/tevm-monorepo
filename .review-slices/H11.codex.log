   889	/**
   890	 * Creates the Tevm Evm to execute ethereum bytecode internally.
   891	 * Wraps [ethereumjs EVM](https://github.com/ethereumjs/ethereumjs-monorepo/tree/master/packages/evm)
   892	 * @example
   893	 * ```typescript
   894	 * import { createEvm } from '@tevm/evm'
   895	 * import { mainnet } from '@tevm/common'
   896	 * import { createBlockchain } from '@tevm/blockchain'
   897	 * import { createStateManager } from '@tevm/state-manager'
   898	 * import { EthjsAddress } from '@tevm/utils'
   899	 *
   900	 * const common = mainnet.clone()
   901	 * const stateManager = createStateManager({ common })
   902	 * const blockchain = createBlockchain({ common })
   903	 * const evm = await createEvm({ common, stateManager, blockchain})
   904	 *
   905	 * const runCallResult = await evm.runCall({
   906	 *   to: EthjsAddress.from(`0x${'00'.repeat(20)}`),
   907	 *   value: 420n,
   908	 *   skipBalance: true,
   909	 * })
   910	 * console.log(runCallResult)
   911	 * ````
   912	 * @param {import('./CreateEvmOptions.js').CreateEvmOptions} options
   913	 * @returns {Promise<import('./EvmType.js').Evm>} A tevm Evm instance with tevm specific defaults
   914	 */
   915	export const createEvm = async ({
   916		common,
   917		stateManager,
   918		blockchain,
   919		customPrecompiles,
   920		customPredeploys,
   921		profiler,
   922		allowUnlimitedContractSize,
   923		loggingLevel,
   924	}) => {
   925		const logger = createLogger({
   926			name: '@tevm/evm',
   927			level: loggingLevel ?? 'warn',
   928		})
   929		logger.debug({
   930			allowUnlimitedContractSize,
   931			profiler,
   932			customPrecompiles: customPrecompiles?.map((c) => c.address.toString()),
   933			customPredeploys: customPredeploys?.map((p) => p.contract.address),
   934		})
   935		for (const predeploy of customPredeploys ?? []) {
   936			await stateManager.putCode(createAddressFromString(predeploy.contract.address), hexToBytes(predeploy.contract.deployedBytecode))
   937		}
   938		const evm = await Evm.create({
   939			common: common.ethjsCommon,
   940			stateManager: /** @type {NonNullable<import('@evmts/zevm/evm').EVMOpts['stateManager']>} */ (
   941				/** @type {unknown} */ (stateManager)
   942			),
   943			blockchain,
   944			allowUnlimitedContractSize: allowUnlimitedContractSize ?? false,
   945			allowUnlimitedInitCodeSize: false,
   946			customOpcodes: [],
   947			// TODO uncomment the mapping once we make the api correct
   948			// Edit: nvm not letting this block a stable release maybe update it next major
   949			// @warning Always pass in an empty array if no precompiles as `addPrecompile` method assumes it's there
   950			customPrecompiles: customPrecompiles ?? [],
   951			profiler: {
   952				enabled: profiler ?? false,
   953			},
   954		})
   955		if (loggingLevel === 'trace') {
   956			// we are hacking ethereumjs logger into working with our logger
   957			const evmAny = /** @type {any} */ (evm)
   958			evmAny.DEBUG = true
   959			evmAny._debug = logger
   960		}
   961		evm.addCustomPrecompile = evm.addCustomPrecompile?.bind(evm) ?? Evm.prototype.addCustomPrecompile.bind(evm)
   962		evm.removeCustomPrecompile = evm.removeCustomPrecompile?.bind(evm) ?? Evm.prototype.removeCustomPrecompile.bind(evm)
   963		return evm
   964	}
