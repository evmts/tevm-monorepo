   975	 * @param {import('@tevm/vm').Vm} params.vm
   976	 * @param {bigint} [params.nonce]
   977	 * @param {bigint} [params.balance]
   978	 * @param {import('@tevm/utils').Hex} [params.storageRoot]
   979	 * @param {import('@tevm/utils').Hex} [params.deployedBytecode]
