   990				...(storageRoot !== undefined ? { storageRoot } : {}),
   991				...(deployedBytecode !== undefined ? { codeHash: keccak256(deployedBytecode, 'bytes') } : {}),
   992			}),
   993		)
   994		if (deployedBytecode) {
   995			await vm.stateManager.putCode(ethjsAddress, hexToBytes(deployedBytecode))
   996		}
   997	}
